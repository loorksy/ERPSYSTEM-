<div class="max-w-5xl mx-auto space-y-10" dir="rtl">
  <div>
    <h2 class="text-2xl font-bold text-slate-800 mb-4">مصروف يدوي</h2>
    <form id="expForm" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-3 max-w-md">
      <input type="number" name="amount" step="0.01" required placeholder="المبلغ" class="w-full px-4 py-2.5 rounded-xl border border-slate-200">
      <input type="text" name="category" placeholder="التصنيف (اختياري)" class="w-full px-4 py-2.5 rounded-xl border border-slate-200">
      <textarea name="notes" placeholder="ملاحظات" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" rows="2"></textarea>
      <button type="submit" class="w-full py-3 rounded-xl bg-rose-600 text-white font-semibold">تسجيل مصروف</button>
    </form>
    <p id="expMsg" class="mt-3 text-sm"></p>
  </div>

  <div>
    <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
      <h3 class="text-lg font-bold text-slate-800">سجل المصاريف الموحّد</h3>
      <div class="flex flex-wrap items-center gap-2">
        <label class="text-sm text-slate-600">تصفية حسب المصدر</label>
        <input type="text" id="expUnifiedFilter" list="expSourceHints" placeholder="مثال: salary_swap_discount" class="px-3 py-2 rounded-xl border border-slate-200 text-sm min-w-[12rem]">
        <datalist id="expSourceHints">
          <option value="manual_expense"></option>
          <option value="salary_swap_discount"></option>
          <option value="sub_agency_reward"></option>
        </datalist>
        <button type="button" onclick="expensesLoadUnified()" class="px-4 py-2 rounded-xl bg-slate-100 text-slate-700 text-sm font-medium">تحديث</button>
      </div>
    </div>
    <p class="text-xs text-slate-500 mb-3">يشمل خصومات تبديل الراتب، مكافآت الوكالات الفرعية، والمصاريف المسجّلة في الدفتر.</p>
    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-x-auto">
      <table class="w-full text-right text-sm">
        <thead>
          <tr class="bg-slate-50 text-slate-600 border-b border-slate-200">
            <th class="px-3 py-2 font-semibold">التاريخ</th>
            <th class="px-3 py-2 font-semibold">المبلغ</th>
            <th class="px-3 py-2 font-semibold">المصدر</th>
            <th class="px-3 py-2 font-semibold">النوع</th>
            <th class="px-3 py-2 font-semibold">ملاحظات</th>
          </tr>
        </thead>
        <tbody id="expUnifiedBody">
          <tr><td colspan="5" class="px-3 py-6 text-center text-slate-400">جاري التحميل…</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
