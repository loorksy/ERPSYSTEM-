async function payrollRefreshAuditSession() {
  var sel = document.getElementById('payrollCycleSelect');
  var optionsSection = document.getElementById('payrollOptionsSection');
  var banner = document.getElementById('payrollAuditSessionBanner');
  var btn = document.getElementById('payrollCloseAuditBtn');
  var reopenBtn = document.getElementById('payrollReopenAuditBtn');
  var closedNote = document.getElementById('payrollAuditSessionClosedNote');
  var titleEl = document.getElementById('payrollAuditSessionTitle');
  var subEl = document.getElementById('payrollAuditSessionSub');
  var subOpen = 'يُحفظ اختيار الدورة والجدول والأعمدة في هذا الجهاز. استخدم «إغلاق التدقيق» عند الانتهاء من العمل على هذه الدورة.';
  if (!banner || !sel || !sel.value) {
    if (banner) banner.classList.add('hidden');
    return;
  }
  if (optionsSection && optionsSection.classList.contains('hidden')) {
    if (banner) banner.classList.add('hidden');
    return;
  }
  banner.classList.remove('hidden');
  try {
    var res = await fetch('/api/sheet/cycle/' + encodeURIComponent(sel.value) + '/audit-session', { credentials: 'same-origin' });
    var data = await res.json();
    if (!data.success) {
      if (titleEl) titleEl.textContent = 'جلسة التدقيق';
      if (subEl) subEl.textContent = 'تعذّر تحميل حالة الجلسة من السيرفر. تحقق من الاتصال أو أعد تحميل الصفحة.';
      if (btn) btn.classList.remove('hidden');
      if (reopenBtn) reopenBtn.classList.add('hidden');
      if (closedNote) closedNote.classList.add('hidden');
      return;
    }
    if (data.closed) {
      if (btn) btn.classList.add('hidden');
      if (reopenBtn) reopenBtn.classList.remove('hidden');
      if (closedNote) closedNote.classList.remove('hidden');
      if (titleEl) titleEl.textContent = 'تم إغلاق التدقيق';
      if (subEl) subEl.textContent = 'هذه الدورة مُعلَّمة كمغلقة في النظام. يمكنك إعادة فتح الجلسة للمتابعة، أو متابعة العمل بدون تغيير الحالة.';
    } else {
      if (btn) btn.classList.remove('hidden');
      if (reopenBtn) reopenBtn.classList.add('hidden');
      if (closedNote) closedNote.classList.add('hidden');
      if (titleEl) titleEl.textContent = 'التدقيق نشط لهذه الدورة';
      if (subEl) subEl.textContent = subOpen;
    }
  } catch (_) {
    if (titleEl) titleEl.textContent = 'جلسة التدقيق';
    if (subEl) subEl.textContent = 'تعذّر الاتصال بالسيرفر لتحديث حالة الجلسة. الشريط يبقى ظاهراً — أعد المحاولة بعد قليل.';
    if (btn) btn.classList.remove('hidden');
    if (reopenBtn) reopenBtn.classList.add('hidden');
    if (closedNote) closedNote.classList.add('hidden');
  }
}

