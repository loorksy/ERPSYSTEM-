<div class="sub-agency-detail-page sub-agencies-page w-full max-w-6xl mx-auto min-w-0 px-3 sm:px-6 lg:px-8 pb-8" dir="rtl">
  <div id="subAgencyDashboardPage" data-agency-id="<%= subAgencyId %>" class="sub-agency-profile space-y-3 sm:space-y-4">
    <!-- لوحة واحدة: الهوية + كل الخيارات والإجراءات في الأعلى -->
    <section class="overflow-hidden rounded-xl border border-slate-200/90 bg-white shadow-sm">
      <!-- صف الهوية والرصيد و PDF -->
      <div class="flex flex-wrap items-center gap-2 border-b border-slate-100 bg-slate-50/40 px-3 py-2.5 sm:gap-3 sm:px-4 sm:py-3">
        <a href="/sub-agencies" class="btn-back inline-flex h-9 w-9 shrink-0" title="العودة لقائمة الوكالات" aria-label="العودة لقائمة الوكالات">
          <i class="fas fa-arrow-right text-sm"></i>
        </a>
        <div class="flex min-w-0 flex-1 items-center gap-2 sm:gap-3">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-indigo-600 text-white shadow-sm">
            <i class="fas fa-store text-sm" aria-hidden="true"></i>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-600/90">وكالة فرعية</p>
            <h1 id="subAgencyDashboardTitle" class="truncate text-base font-bold leading-tight text-slate-900 sm:text-lg">ملف الوكالة</h1>
            <div id="subAgencyBalancePill" class="mt-1 flex flex-wrap items-center gap-1.5 text-xs">
              <span class="text-slate-500">رصيد</span>
              <span id="subAgencyBalanceValue" class="font-bold tabular-nums text-slate-900">—</span>
              <span id="subAgencyBalanceStatus" class="rounded px-1.5 py-0 text-[10px] font-bold leading-none"></span>
            </div>
          </div>
        </div>
        <button type="button" onclick="subAgenciesDownloadPdfCurrent()" class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50" title="تقرير PDF">
          <i class="fas fa-file-pdf text-red-500 text-[0.8rem]"></i>
          PDF
        </button>
      </div>

      <!-- شريط الخيارات: دورة + إجراءات + حصة W — حجم مضغوط -->
      <div class="border-b border-slate-100 px-3 py-2 sm:px-4">
        <p class="mb-1.5 text-[10px] font-semibold uppercase tracking-wide text-slate-400">إعدادات الدورة والإجراءات</p>
        <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-2 sm:gap-y-1.5">
          <label for="subAgencyCycleSelect" class="sr-only">الدورة المالية</label>
          <select id="subAgencyCycleSelect" class="input-select w-full min-w-0 rounded-lg border-slate-200 py-1.5 ps-2 pe-8 text-sm sm:max-w-[14rem] sm:flex-none" onchange="subAgenciesLoadDashboard()">
            <option value="">— الدورة —</option>
          </select>

          <span class="hidden h-5 w-px shrink-0 bg-slate-200 sm:block" aria-hidden="true"></span>

          <div class="flex flex-wrap gap-1.5 sm:contents">
            <button type="button" onclick="subAgenciesOpenRewardModal()" class="inline-flex flex-1 items-center justify-center gap-1 rounded-lg bg-emerald-600 px-2.5 py-1.5 text-xs font-semibold text-white shadow-sm transition hover:bg-emerald-700 sm:flex-none">
              <i class="fas fa-gift text-[0.7rem]" aria-hidden="true"></i>
              مكافأة
            </button>
            <button type="button" onclick="subAgenciesOpenDeductModal()" class="inline-flex flex-1 items-center justify-center gap-1 rounded-lg border border-red-200 bg-red-50 px-2.5 py-1.5 text-xs font-semibold text-red-800 transition hover:bg-red-100 sm:flex-none">
              <i class="fas fa-minus-circle text-[0.7rem]" aria-hidden="true"></i>
              خصم
            </button>
          </div>

          <span class="hidden h-5 w-px shrink-0 bg-slate-200 sm:block" aria-hidden="true"></span>

          <div class="flex flex-wrap items-center gap-1.5 sm:ms-0">
            <span class="text-[11px] font-medium text-slate-500 shrink-0">حصة الشركة من W</span>
            <div class="flex items-center gap-0.5 rounded-lg border border-amber-200/80 bg-amber-50/50 px-1.5 py-0.5">
              <input type="number" id="subAgencyPercentInput" step="0.1" min="0" max="100" class="input-percent w-14 min-w-0 border-0 bg-transparent py-0.5 text-center text-sm font-bold text-slate-900 focus:ring-0" placeholder="0" title="نسبة الشركة من عمود W للدورة المختارة">
              <span class="text-xs font-bold text-amber-800">%</span>
            </div>
            <button type="button" onclick="subAgenciesSaveCyclePercent()" class="inline-flex items-center rounded-lg bg-indigo-600 px-2.5 py-1.5 text-xs font-semibold text-white shadow-sm transition hover:bg-indigo-700">
              حفظ
            </button>
          </div>
        </div>
        <p class="mt-1.5 text-[10px] leading-snug text-slate-400">يُحفظ نسبة W للدورة فقط؛ الباقي لربح الوكالة ويُعاد احتساب المزامنة.</p>
      </div>

      <!-- مؤشرات مختصرة بدون بطاقات منفصلة -->
      <div class="grid grid-cols-2 gap-px bg-slate-100 sm:grid-cols-2">
        <div class="bg-white px-3 py-2.5 sm:px-4">
          <p class="text-[10px] font-medium text-slate-500">ربح الدورة</p>
          <p id="subAgencyProfit" class="mt-0.5 text-lg font-bold tabular-nums text-emerald-800 sm:text-xl">0</p>
        </div>
        <button type="button" onclick="subAgenciesShowUsers()" class="group bg-white px-3 py-2.5 text-start transition hover:bg-slate-50 sm:px-4">
          <p class="text-[10px] font-medium text-slate-500">المستخدمون</p>
          <div class="mt-0.5 flex items-baseline justify-between gap-1">
            <p id="subAgencyUsersCount" class="text-lg font-bold tabular-nums text-indigo-900 sm:text-xl">0</p>
            <span class="text-[10px] font-medium text-indigo-500 opacity-0 transition group-hover:opacity-100">قائمة ←</span>
          </div>
        </button>
      </div>
    </section>

    <!-- سجل المعاملات — رأس مضغوط -->
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-3 py-2 sm:px-4">
        <h2 class="text-sm font-bold text-slate-900">سجل المعاملات</h2>
        <p class="text-[10px] text-slate-500">تصفية ثم تطبيق</p>
      </div>
      <div class="p-3 sm:p-4">
        <div class="mb-3 grid grid-cols-1 gap-2 sm:grid-cols-12 sm:items-end sm:gap-2">
          <div class="sm:col-span-4 lg:col-span-3">
            <label for="subAgencyTxTypeFilter" class="mb-0.5 block text-[10px] font-medium text-slate-500">النوع</label>
            <select id="subAgencyTxTypeFilter" class="input-filter w-full rounded-lg border-slate-200 py-1.5 text-sm" onchange="subAgenciesLoadTransactions()">
              <option value="">الكل</option>
              <option value="profit">ربح</option>
              <option value="reward">مكافأة</option>
              <option value="deduction">خصم</option>
              <option value="due">مستحقات</option>
            </select>
          </div>
          <div class="grid grid-cols-2 gap-2 sm:col-span-5 sm:grid-cols-2 lg:col-span-6">
            <div class="min-w-0">
              <label for="subAgencyTxFrom" class="mb-0.5 block text-[10px] font-medium text-slate-500">من</label>
              <input type="date" id="subAgencyTxFrom" class="input-filter w-full min-w-0 rounded-lg border-slate-200 py-1.5 text-sm">
            </div>
            <div class="min-w-0">
              <label for="subAgencyTxTo" class="mb-0.5 block text-[10px] font-medium text-slate-500">إلى</label>
              <input type="date" id="subAgencyTxTo" class="input-filter w-full min-w-0 rounded-lg border-slate-200 py-1.5 text-sm">
            </div>
          </div>
          <div class="sm:col-span-3 lg:col-span-3">
            <button type="button" onclick="subAgenciesLoadTransactions()" class="btn-filter h-8 w-full rounded-lg px-3 text-xs font-semibold">تطبيق</button>
          </div>
        </div>
        <div id="subAgencyTxList" class="sub-agency-tx-list max-h-[min(22rem,48vh)] overflow-y-auto rounded-lg border border-slate-100 bg-slate-50/60 sm:max-h-[min(26rem,52vh)]">
          <p class="py-8 text-center text-xs text-slate-400">جاري التحميل...</p>
        </div>
      </div>
    </section>
  </div>
</div>
<%- include('./sub-agency-modals') %>
