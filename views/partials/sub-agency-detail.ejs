<div class="sub-agency-detail-page sub-agencies-page w-full max-w-6xl mx-auto min-w-0 px-4 sm:px-6 lg:px-8 pb-10 sm:pb-12" dir="rtl">
  <div id="subAgencyDashboardPage" data-agency-id="<%= subAgencyId %>" class="sub-agency-profile space-y-5 sm:space-y-6">
    <!-- ترويسة ملف الوكالة -->
    <section class="relative overflow-hidden rounded-3xl border border-slate-200/80 bg-gradient-to-br from-indigo-50/95 via-white to-slate-50 shadow-sm ring-1 ring-slate-900/[0.04]">
      <div class="pointer-events-none absolute -start-20 -top-24 h-56 w-56 rounded-full bg-indigo-400/15 blur-3xl" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -bottom-16 -end-16 h-48 w-48 rounded-full bg-violet-300/10 blur-3xl" aria-hidden="true"></div>
      <div class="relative p-4 sm:p-6 lg:p-8">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between lg:gap-6">
          <div class="flex min-w-0 flex-1 flex-col gap-3 sm:flex-row sm:items-start sm:gap-4">
            <a href="/sub-agencies" class="btn-back inline-flex h-11 w-11 shrink-0 self-start sm:mt-1" title="العودة لقائمة الوكالات" aria-label="العودة لقائمة الوكالات">
              <i class="fas fa-arrow-right"></i>
            </a>
            <div class="flex min-w-0 flex-1 gap-3 sm:gap-4">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-white shadow-sm ring-1 ring-indigo-500/15 sm:h-16 sm:w-16">
                <i class="fas fa-store text-xl text-indigo-600 sm:text-2xl" aria-hidden="true"></i>
              </div>
              <div class="min-w-0 flex-1 space-y-2">
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-wider text-indigo-600/90 sm:text-xs">وكالة فرعية</p>
                  <h1 id="subAgencyDashboardTitle" class="mt-0.5 break-words text-xl font-bold leading-tight text-slate-900 sm:text-2xl lg:text-[1.65rem]">ملف الوكالة</h1>
                  <p class="mt-1 text-xs leading-relaxed text-slate-600 sm:text-sm">الدورة المالية، الأرباح، والمعاملات — عرض متجاوب للجوال والشاشات الكبيرة</p>
                </div>
                <div id="subAgencyBalancePill" class="inline-flex max-w-full flex-wrap items-center gap-2 rounded-2xl border border-slate-200/90 bg-white/90 px-3 py-2 text-sm shadow-sm ring-1 ring-slate-900/[0.03] backdrop-blur-sm sm:px-4">
                  <span class="text-slate-500">الرصيد الإجمالي</span>
                  <span id="subAgencyBalanceValue" class="font-bold tabular-nums text-slate-900">—</span>
                  <span id="subAgencyBalanceStatus" class="rounded-lg px-2 py-0.5 text-[11px] font-bold sm:text-xs"></span>
                </div>
              </div>
            </div>
          </div>
          <div class="flex w-full shrink-0 flex-col gap-2 sm:flex-row sm:justify-end lg:w-auto lg:min-w-[12rem]">
            <button type="button" onclick="subAgenciesDownloadPdfCurrent()" class="inline-flex w-full items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 active:scale-[0.99] sm:w-auto sm:py-2.5" title="تنزيل تقرير PDF لهذه الوكالة">
              <i class="fas fa-file-pdf text-lg text-red-500"></i>
              تنزيل PDF
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- الدورة المالية -->
    <div class="rounded-2xl border border-slate-100 bg-white p-4 shadow-sm ring-1 ring-slate-900/[0.03] sm:p-5">
      <div class="mb-3 flex flex-wrap items-end justify-between gap-2">
        <label for="subAgencyCycleSelect" class="text-sm font-bold text-slate-800">الدورة المالية</label>
        <span class="text-[11px] text-slate-500">يُحدَّد ربح الدورة والنسب المحفوظة لها</span>
      </div>
      <select id="subAgencyCycleSelect" class="input-select w-full max-w-full rounded-xl border-slate-200 text-base sm:max-w-xl" onchange="subAgenciesLoadDashboard()">
        <option value="">-- اختر الدورة --</option>
      </select>
    </div>

    <!-- مؤشرات الدورة -->
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
      <div class="rounded-2xl border border-emerald-100/90 bg-gradient-to-br from-emerald-50/95 to-white p-4 shadow-sm ring-1 ring-emerald-500/[0.06] sm:p-5">
        <div class="flex items-start justify-between gap-2">
          <p class="text-xs font-bold text-emerald-800/90 sm:text-sm">ربح الوكالة <span class="font-normal text-emerald-700/70">(للدورة المختارة)</span></p>
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-700" aria-hidden="true"><i class="fas fa-chart-line text-sm"></i></span>
        </div>
        <p id="subAgencyProfit" class="mt-3 text-2xl font-bold tabular-nums text-emerald-900 sm:text-3xl">0</p>
      </div>
      <button type="button" onclick="subAgenciesShowUsers()" class="group rounded-2xl border border-indigo-100/90 bg-gradient-to-br from-indigo-50/95 to-white p-4 text-start shadow-sm ring-1 ring-indigo-500/[0.06] transition hover:border-indigo-200 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400 sm:p-5">
        <div class="flex items-start justify-between gap-2">
          <p class="text-xs font-bold text-indigo-900/90 sm:text-sm">المستخدمون المرتبطون</p>
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-700 transition group-hover:bg-indigo-500/15" aria-hidden="true"><i class="fas fa-users text-sm"></i></span>
        </div>
        <div class="mt-3 flex items-end justify-between gap-2">
          <p id="subAgencyUsersCount" class="text-2xl font-bold tabular-nums text-indigo-950 sm:text-3xl">0</p>
          <span class="text-xs font-semibold text-indigo-600 opacity-80 transition group-hover:opacity-100 sm:opacity-0 sm:group-hover:opacity-100">عرض القائمة ←</span>
        </div>
      </button>
    </div>

    <!-- حصة الشركة من عمود و -->
    <div class="rounded-2xl border border-amber-100/90 bg-gradient-to-br from-amber-50/70 to-white p-4 shadow-sm ring-1 ring-amber-500/[0.08] sm:p-5">
      <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="text-sm font-bold text-amber-950">حصة ربح الشركة من عمود و (%)</p>
          <p class="mt-1 text-[11px] leading-relaxed text-amber-900/70 sm:text-xs">القيمة = نسبة الشركة من عمود W؛ الباقي لربح الوكالة. يُحفظ للدورة فقط ويُعاد احتساب أرباح المزامنة.</p>
        </div>
      </div>
      <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
        <div class="flex w-full min-w-0 items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2.5 shadow-inner sm:max-w-xs sm:flex-initial">
          <input type="number" id="subAgencyPercentInput" step="0.1" min="0" max="100" class="input-percent min-w-0 flex-1 border-0 bg-transparent py-1 text-lg font-bold text-slate-900 focus:ring-0 sm:text-xl" placeholder="0" title="مثال: 10 تعني 10 للشركة و90 للوكالة من كل 100 في عمود W">
          <span class="text-base font-bold text-amber-800">%</span>
        </div>
        <button type="button" onclick="subAgenciesSaveCyclePercent()" class="inline-flex w-full items-center justify-center rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white shadow-md shadow-indigo-600/20 transition hover:bg-indigo-700 active:scale-[0.99] sm:w-auto sm:py-2.5">
          حفظ للدورة
        </button>
      </div>
    </div>

    <!-- إجراءات سريعة -->
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
      <button type="button" onclick="subAgenciesOpenRewardModal()" class="inline-flex min-h-[3rem] w-full items-center justify-center gap-2 rounded-2xl bg-emerald-600 px-4 py-3.5 text-sm font-bold text-white shadow-lg shadow-emerald-600/25 transition hover:bg-emerald-700 active:scale-[0.99]">
        <i class="fas fa-gift text-base" aria-hidden="true"></i>
        إضافة مكافأة
      </button>
      <button type="button" onclick="subAgenciesOpenDeductModal()" class="inline-flex min-h-[3rem] w-full items-center justify-center gap-2 rounded-2xl border-2 border-red-200/90 bg-red-50/90 px-4 py-3.5 text-sm font-bold text-red-900 transition hover:bg-red-100 active:scale-[0.99]">
        <i class="fas fa-minus-circle text-base" aria-hidden="true"></i>
        خصم (شحن / راتب)
      </button>
    </div>

    <!-- سجل المعاملات -->
    <section class="overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm ring-1 ring-slate-900/[0.03]">
      <div class="border-b border-slate-100 bg-gradient-to-l from-slate-50 to-white px-4 py-4 sm:px-6 sm:py-5">
        <h2 class="text-base font-bold text-slate-900 sm:text-lg">سجل المعاملات</h2>
        <p class="mt-1 text-xs text-slate-500 sm:text-sm">صفِّ حسب النوع والفترة، ثم اضغط «تطبيق»</p>
      </div>
      <div class="p-4 sm:p-6">
        <div class="mb-4 grid grid-cols-1 gap-3 sm:grid-cols-12 sm:items-end sm:gap-3">
          <div class="sm:col-span-4 lg:col-span-3">
            <label for="subAgencyTxTypeFilter" class="mb-1.5 block text-xs font-medium text-slate-600">النوع</label>
            <select id="subAgencyTxTypeFilter" class="input-filter w-full rounded-xl border-slate-200 py-2.5" onchange="subAgenciesLoadTransactions()">
              <option value="">كل الأنواع</option>
              <option value="profit">ربح</option>
              <option value="reward">مكافأة</option>
              <option value="deduction">خصم</option>
              <option value="due">مستحقات</option>
            </select>
          </div>
          <div class="grid grid-cols-2 gap-2 sm:col-span-5 sm:grid-cols-2 lg:col-span-6">
            <div class="min-w-0">
              <label for="subAgencyTxFrom" class="mb-1.5 block text-xs font-medium text-slate-600">من</label>
              <input type="date" id="subAgencyTxFrom" class="input-filter w-full min-w-0 rounded-xl border-slate-200 py-2.5">
            </div>
            <div class="min-w-0">
              <label for="subAgencyTxTo" class="mb-1.5 block text-xs font-medium text-slate-600">إلى</label>
              <input type="date" id="subAgencyTxTo" class="input-filter w-full min-w-0 rounded-xl border-slate-200 py-2.5">
            </div>
          </div>
          <div class="flex sm:col-span-3 lg:col-span-3">
            <button type="button" onclick="subAgenciesLoadTransactions()" class="btn-filter h-[42px] w-full rounded-xl px-4 py-2.5 text-sm font-bold sm:mt-0">تطبيق</button>
          </div>
        </div>
        <div id="subAgencyTxList" class="sub-agency-tx-list max-h-[min(26rem,50vh)] overflow-y-auto rounded-2xl border border-slate-100 bg-slate-50/50 sm:max-h-[min(28rem,55vh)]">
          <p class="py-10 text-center text-sm text-slate-400">جاري التحميل...</p>
        </div>
      </div>
    </section>
  </div>
</div>
<%- include('./sub-agency-modals') %>
