<div class="sub-agency-detail-page sub-agencies-page w-full max-w-6xl mx-auto min-w-0 px-3 sm:px-6 lg:px-8 pb-8" dir="rtl">
  <div id="subAgencyDashboardPage" data-agency-id="<%= subAgencyId %>" class="sub-agency-profile space-y-4">
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <!-- صف 1: محاذاة ثابتة — رجوع | هوية + رصيد | PDF -->
      <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-3 border-b border-slate-100 bg-slate-50/50 px-3 py-3 sm:px-4">
        <a href="/sub-agencies" class="btn-back inline-flex shrink-0" title="العودة لقائمة الوكالات" aria-label="العودة لقائمة الوكالات">
          <i class="fas fa-arrow-right text-sm"></i>
        </a>
        <div class="flex min-w-0 items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-600 text-white shadow-sm">
            <i class="fas fa-store text-sm" aria-hidden="true"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-600">وكالة فرعية</p>
            <h1 id="subAgencyDashboardTitle" class="truncate text-base font-bold text-slate-900 sm:text-lg">ملف الوكالة</h1>
            <div id="subAgencyBalancePill" class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-0.5 text-xs">
              <span class="text-slate-500">الرصيد</span>
              <span id="subAgencyBalanceValue" class="font-bold tabular-nums text-slate-900">—</span>
              <span id="subAgencyBalanceStatus" class="rounded px-1.5 py-0.5 text-[10px] font-bold leading-none"></span>
            </div>
          </div>
        </div>
        <button type="button" onclick="subAgenciesDownloadPdfCurrent()" class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50" title="تقرير PDF">
          <i class="fas fa-file-pdf text-red-500 text-[0.8rem]"></i>
          PDF
        </button>
      </div>

      <!-- صف 2: الدورة — عمود كامل بعنوان -->
      <div class="border-b border-slate-100 px-3 py-3 sm:px-4">
        <label for="subAgencyCycleSelect" class="mb-1.5 block text-xs font-semibold text-slate-700">الدورة المالية</label>
        <select id="subAgencyCycleSelect" class="input-select w-full rounded-lg border-slate-200 py-2 text-sm sm:max-w-md" onchange="subAgenciesLoadDashboard()">
          <option value="">— اختر الدورة —</option>
        </select>
      </div>

      <!-- صف 3: مكافأة + خصم + نسبة W + حفظ — صف واحد (شبكة 2×2 على الجوال) -->
      <div class="border-b border-slate-100 px-3 py-2.5 sm:px-4">
        <div class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap sm:items-center sm:gap-2">
          <button type="button" onclick="subAgenciesOpenRewardModal()" class="inline-flex min-h-[2.35rem] w-full items-center justify-center gap-1.5 rounded-lg bg-emerald-600 px-3 py-2 text-xs font-semibold text-white shadow-sm transition hover:bg-emerald-700 sm:w-auto sm:min-w-[6.5rem]">
            <i class="fas fa-gift text-[0.7rem]" aria-hidden="true"></i>
            مكافأة
          </button>
          <button type="button" onclick="subAgenciesOpenDeductModal()" class="inline-flex min-h-[2.35rem] w-full items-center justify-center gap-1.5 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-xs font-semibold text-red-800 transition hover:bg-red-100 sm:w-auto sm:min-w-[6.5rem]">
            <i class="fas fa-minus-circle text-[0.7rem]" aria-hidden="true"></i>
            خصم
          </button>
          <label class="sub-agency-percent-field flex min-h-[2.35rem] min-w-0 w-full cursor-text items-center gap-1 rounded-lg border border-amber-200 bg-amber-50 px-2 py-1.5 sm:w-auto sm:max-w-[7rem]" title="حصة الشركة من عمود W للدورة المختارة">
            <span class="sr-only">حصة الشركة من عمود W بالنسبة المئوية</span>
            <input type="number" id="subAgencyPercentInput" step="0.1" min="0" max="100" class="input-percent sub-agency-percent-input min-w-0 flex-1 border-0 bg-transparent py-0.5 text-center text-sm font-bold text-slate-900 focus:ring-0" placeholder="0" title="نسبة الشركة من عمود W">
            <span class="shrink-0 text-xs font-bold text-amber-800">%</span>
          </label>
          <button type="button" onclick="subAgenciesSaveCyclePercent()" class="inline-flex min-h-[2.35rem] w-full items-center justify-center rounded-lg bg-indigo-600 px-3 py-2 text-xs font-semibold text-white shadow-sm transition hover:bg-indigo-700 sm:w-auto sm:px-4">
            حفظ للدورة
          </button>
        </div>
      </div>

      <!-- صف 4: مؤشران — فاصل بكسل واحد (ثابت في RTL) -->
      <div class="grid grid-cols-2 gap-px bg-slate-200">
        <div class="bg-white px-3 py-3 sm:px-4">
          <p class="text-[10px] font-medium uppercase tracking-wide text-slate-500">ربح الدورة</p>
          <p id="subAgencyProfit" class="mt-1 text-lg font-bold tabular-nums text-emerald-800 sm:text-xl">0</p>
        </div>
        <button type="button" onclick="subAgenciesShowUsers()" class="group flex w-full flex-col items-stretch bg-white px-3 py-3 text-start transition hover:bg-slate-50 sm:px-4">
          <p class="text-[10px] font-medium uppercase tracking-wide text-slate-500">المستخدمون</p>
          <div class="mt-1 flex items-baseline justify-between gap-2">
            <p id="subAgencyUsersCount" class="text-lg font-bold tabular-nums text-indigo-900 sm:text-xl">0</p>
            <span class="text-[10px] font-medium text-indigo-500 opacity-0 transition group-hover:opacity-100">قائمة ←</span>
          </div>
        </button>
      </div>
    </section>

    <!-- سجل المعاملات -->
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-3 py-2.5 sm:px-4">
        <h2 class="text-sm font-bold text-slate-900">سجل المعاملات</h2>
        <p class="text-[10px] text-slate-500">اختر النوع والفترة ثم تطبيق</p>
      </div>
      <div class="p-3 sm:p-4">
        <div class="mb-3 grid grid-cols-1 gap-3 sm:grid-cols-12 sm:items-end sm:gap-x-3 sm:gap-y-2">
          <div class="sm:col-span-4 lg:col-span-3">
            <label for="subAgencyTxTypeFilter" class="mb-1 block text-xs font-medium text-slate-600">النوع</label>
            <select id="subAgencyTxTypeFilter" class="input-filter h-9 w-full rounded-lg border-slate-200 text-sm" onchange="subAgenciesLoadTransactions()">
              <option value="">كل الأنواع</option>
              <option value="profit">ربح</option>
              <option value="reward">مكافأة</option>
              <option value="deduction">خصم</option>
              <option value="due">مستحقات</option>
            </select>
          </div>
          <div class="grid grid-cols-2 gap-3 sm:col-span-5 sm:grid-cols-2 lg:col-span-5">
            <div class="min-w-0">
              <label for="subAgencyTxFrom" class="mb-1 block text-xs font-medium text-slate-600">من</label>
              <input type="date" id="subAgencyTxFrom" class="input-filter h-9 w-full min-w-0 rounded-lg border-slate-200 text-sm">
            </div>
            <div class="min-w-0">
              <label for="subAgencyTxTo" class="mb-1 block text-xs font-medium text-slate-600">إلى</label>
              <input type="date" id="subAgencyTxTo" class="input-filter h-9 w-full min-w-0 rounded-lg border-slate-200 text-sm">
            </div>
          </div>
          <div class="sm:col-span-3 lg:col-span-4">
            <label class="mb-1 hidden text-xs font-medium text-slate-600 sm:block sm:invisible" aria-hidden="true">تطبيق</label>
            <button type="button" onclick="subAgenciesLoadTransactions()" class="btn-filter h-9 w-full rounded-lg px-4 text-xs font-semibold">تطبيق</button>
          </div>
        </div>
        <div id="subAgencyTxList" class="sub-agency-tx-list max-h-[min(22rem,48vh)] overflow-y-auto rounded-lg border border-slate-100 bg-slate-50/60 sm:max-h-[min(26rem,52vh)]">
          <p class="py-8 text-center text-xs text-slate-400">جاري التحميل...</p>
        </div>
      </div>
    </section>
  </div>
</div>
<%- include('./sub-agency-modals') %>
