<div class="sub-agencies-page w-full max-w-6xl mx-auto min-w-0 px-4 sm:px-0 pb-10" dir="rtl">
  <div id="subAgenciesList">
    <div class="sub-agencies-toolbar-row mb-6">
      <div class="min-w-0 w-full">
        <label class="block text-xs font-medium text-slate-600 mb-1.5">مزامنة من ملف الإدارة (كل ورقة بعد ورقة الإدارة = وكالة)</label>
        <select id="subAgencySyncCycleSelect" class="input-select w-full max-w-full"></select>
      </div>
      <div class="erp-toolbar-actions w-full min-w-0 md:w-auto">
        <button type="button" onclick="subAgenciesOpenDeliveryModal()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-emerald-600 text-white text-[11px] leading-snug sm:text-sm font-semibold shadow-md hover:bg-emerald-700 active:scale-[0.99] transition text-center touch-manipulation">
          تسليم
        </button>
        <button type="button" onclick="subAgenciesOpenAddModal()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-gradient-to-br from-indigo-600 to-indigo-500 text-white text-[11px] leading-snug sm:text-sm font-semibold shadow-md shadow-indigo-500/25 hover:brightness-105 active:scale-[0.99] transition touch-manipulation">
          <i class="fas fa-plus text-[10px] sm:text-sm shrink-0 opacity-95" aria-hidden="true"></i>
          <span class="text-center">إضافة وكالة</span>
        </button>
        <button type="button" onclick="subAgenciesRunManagementSync()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-indigo-600 text-white text-[10px] leading-tight sm:text-sm font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition text-center touch-manipulation" title="مزامنة من Google">
          <i class="fab fa-google text-[10px] sm:text-sm shrink-0 opacity-95" aria-hidden="true"></i>
          <span class="text-center"><span class="sm:hidden">مزامنة</span><span class="hidden sm:inline">مزامنة من Google</span></span>
        </button>
      </div>
    </div>
    <div id="subAgenciesCards" class="agencies-grid">
      <p class="text-slate-400 col-span-full text-center py-12">جاري التحميل...</p>
    </div>
  </div>
</div>
<%- include('./sub-agency-modals') %>
