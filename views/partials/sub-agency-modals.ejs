<!-- نوافذ مشتركة: قائمة الوكالات + صفحة ملف الوكالة -->
<div id="subAgencyAddModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>إضافة وكالة</h4>
      <button type="button" onclick="subAgenciesCloseAddModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <form id="subAgencyAddForm" class="modal-form">
      <div class="form-group">
        <label>اسم الوكالة</label>
        <input type="text" id="subAgencyAddName" required placeholder="اسم الوكالة">
      </div>
      <div class="form-group">
        <label>حصة ربح الشركة من عمود و (%)</label>
        <input type="number" id="subAgencyAddPercent" step="0.1" min="0" max="100" value="0" placeholder="0" title="مثال: 10 = شركة 10٪ ووكالة 90٪ من كل 100">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-submit">حفظ</button>
        <button type="button" onclick="subAgenciesCloseAddModal()" class="btn-cancel">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<div id="subAgencyRewardModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/50 backdrop-blur-[3px]">
  <div class="relative w-full max-w-md overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl shadow-slate-900/15 ring-1 ring-slate-900/5">
    <div class="flex items-start gap-3 border-b border-emerald-100 bg-gradient-to-l from-emerald-50/90 to-white px-5 py-4">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-emerald-600 text-lg text-white shadow-md shadow-emerald-600/25">
        <i class="fas fa-gift" aria-hidden="true"></i>
      </div>
      <div class="min-w-0 flex-1 pt-0.5">
        <h2 class="text-lg font-bold leading-tight text-slate-900">إضافة مكافأة</h2>
        <p class="mt-0.5 text-xs text-slate-500">تسجيل مكافأة للوكالة المحددة</p>
      </div>
      <button type="button" onclick="subAgenciesCloseRewardModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 transition hover:bg-slate-100 hover:text-slate-600" aria-label="إغلاق">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>
    <form id="subAgencyRewardForm" class="space-y-4 p-5">
      <p id="subAgencyRewardBalanceHint" class="hidden rounded-xl border p-3 text-sm leading-relaxed"></p>
      <div>
        <label for="subAgencyRewardAmount" class="mb-1.5 block text-xs font-semibold text-slate-700">مبلغ المكافأة <span class="font-normal text-slate-400">(USD)</span></label>
        <input type="number" id="subAgencyRewardAmount" step="0.01" min="0.01" required class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-3 py-2.5 text-sm font-semibold tabular-nums text-slate-900 shadow-inner transition focus:border-emerald-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500/20" placeholder="0.00">
      </div>
      <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-100 bg-slate-50/80 p-3 transition hover:bg-slate-50">
        <input type="checkbox" id="subAgencyRewardDeductFromFund" class="mt-0.5 h-4 w-4 shrink-0 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500/30">
        <span class="text-sm leading-relaxed text-slate-700">خصم المبلغ من الصندوق الرئيسي وتسجيله مصروفاً</span>
      </label>
      <div>
        <label for="subAgencyRewardNotes" class="mb-1.5 block text-xs font-semibold text-slate-700">ملاحظة <span class="font-normal text-slate-400">(اختياري)</span></label>
        <textarea id="subAgencyRewardNotes" rows="2" placeholder="تفاصيل إضافية…" class="w-full resize-none rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-800 placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"></textarea>
      </div>
      <div class="flex flex-col-reverse gap-2 border-t border-slate-100 pt-4 sm:flex-row sm:justify-end sm:gap-3">
        <button type="button" onclick="subAgenciesCloseRewardModal()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 sm:min-h-0 sm:w-auto">إلغاء</button>
        <button type="submit" class="inline-flex min-h-[2.75rem] w-full items-center justify-center rounded-xl bg-emerald-600 px-5 text-sm font-bold text-white shadow-lg shadow-emerald-600/25 transition hover:bg-emerald-700 sm:min-h-0 sm:w-auto">تسجيل المكافأة</button>
      </div>
    </form>
  </div>
</div>

<div id="subAgencyDeductModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/50 backdrop-blur-[3px]">
  <div class="relative w-full max-w-md overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl shadow-slate-900/15 ring-1 ring-slate-900/5">
    <div class="flex items-start gap-3 border-b border-rose-100 bg-gradient-to-l from-rose-50/90 to-white px-5 py-4">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-rose-600 text-lg text-white shadow-md shadow-rose-600/25">
        <i class="fas fa-minus-circle" aria-hidden="true"></i>
      </div>
      <div class="min-w-0 flex-1 pt-0.5">
        <h2 class="text-lg font-bold leading-tight text-slate-900">خصم من الوكالة</h2>
        <p class="mt-0.5 text-xs text-slate-500">شحن أو راتب حسب نوع الخصم</p>
      </div>
      <button type="button" onclick="subAgenciesCloseDeductModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 transition hover:bg-slate-100 hover:text-slate-600" aria-label="إغلاق">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>
    <form id="subAgencyDeductForm" class="space-y-4 p-5">
      <div>
        <label for="subAgencyDeductKind" class="mb-1.5 block text-xs font-semibold text-slate-700">نوع الخصم</label>
        <select id="subAgencyDeductKind" class="w-full cursor-pointer rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-medium text-slate-800 shadow-sm transition focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-500/20" onchange="subAgenciesDeductKindChange()">
          <option value="shipping">شحن — فتح بيع مربوط بالوكالة</option>
          <option value="salary">راتب / مستحقات</option>
        </select>
      </div>
      <div id="subAgencyDeductSalaryFields" class="hidden space-y-4 rounded-xl border border-slate-100 bg-slate-50/60 p-4">
        <div>
          <label for="subAgencyDeductAmount" class="mb-1.5 block text-xs font-semibold text-slate-700">المبلغ <span class="font-normal text-slate-400">(USD)</span></label>
          <input type="number" id="subAgencyDeductAmount" step="0.01" min="0.01" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold tabular-nums text-slate-900 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-500/20" placeholder="0.00">
        </div>
        <div>
          <label for="subAgencyDeductPayrollMode" class="mb-1.5 block text-xs font-semibold text-slate-700">طريقة السداد</label>
          <select id="subAgencyDeductPayrollMode" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-800 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-500/20">
            <option value="fund">خصم من الصندوق الرئيسي</option>
            <option value="debt_only">تسجيل دين علينا فقط (بدون صندوق)</option>
          </select>
        </div>
        <div>
          <label for="subAgencyDeductNotes" class="mb-1.5 block text-xs font-semibold text-slate-700">ملاحظة <span class="font-normal text-slate-400">(اختياري)</span></label>
          <textarea id="subAgencyDeductNotes" rows="2" placeholder="تفاصيل…" class="w-full resize-none rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-500/20"></textarea>
        </div>
      </div>
      <p id="subAgencyDeductShipHint" class="rounded-xl border border-amber-100 bg-amber-50/80 px-3 py-2.5 text-sm leading-relaxed text-amber-950/90">سيتم فتح صفحة الشحن لبيع مربوط بهذه الوكالة.</p>
      <div class="flex flex-col-reverse gap-2 border-t border-slate-100 pt-4 sm:flex-row sm:justify-end sm:gap-3">
        <button type="button" onclick="subAgenciesCloseDeductModal()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 sm:min-h-0 sm:w-auto">إلغاء</button>
        <button type="submit" class="inline-flex min-h-[2.75rem] w-full items-center justify-center rounded-xl bg-rose-600 px-5 text-sm font-bold text-white shadow-lg shadow-rose-600/25 transition hover:bg-rose-700 sm:min-h-0 sm:w-auto" id="subAgencyDeductSubmit">متابعة</button>
      </div>
    </form>
  </div>
</div>

<div id="subAgencyUsersModal" class="modal-overlay hidden">
  <div class="modal-box modal-box-tall">
    <div class="modal-header">
      <h4>المستخدمين التابعين للوكالة</h4>
      <button type="button" onclick="subAgenciesCloseUsersModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div id="subAgencyUsersList" class="modal-body">
      <p class="text-slate-400 text-center py-8">جاري التحميل...</p>
    </div>
  </div>
</div>

<div id="subAgencyDeliveryModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>تسليم أرصدة وكالات</h4>
      <button type="button" onclick="subAgenciesCloseDeliveryModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-form space-y-3">
      <div class="form-group">
        <label>الدورة</label>
        <select id="saDeliveryCycle" class="w-full px-3 py-2 rounded-xl border border-slate-200"></select>
      </div>
      <div id="saDeliveryChecks" class="text-sm max-h-48 overflow-y-auto space-y-2"></div>
      <button type="button" onclick="subAgenciesSubmitDelivery()" class="btn-submit w-full">تسليم الراتب</button>
    </div>
  </div>
</div>
