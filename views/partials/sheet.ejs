<div class="max-w-6xl mx-auto px-3 sm:px-4 lg:px-0 pb-10 space-y-6" dir="rtl">
  <!-- رأس الصفحة — نفس أسلوب البحث / لوحة التحكم -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="flex items-center gap-3">
      <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-600 to-indigo-500 text-white shadow-md shadow-indigo-600/25">
        <i class="fas fa-file-excel text-lg"></i>
      </span>
      <div>
        <h2 class="text-lg font-bold text-slate-900 tracking-tight">الدورات المالية</h2>
        <p class="text-xs text-slate-500 mt-0.5">إدارة دورات الإدارة والوكيل — بنفس أسلوب واجهة النظام</p>
      </div>
    </div>
    <button type="button" onclick="openCycleModal()" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm active:scale-[0.98] transition-all">
      <i class="fas fa-plus text-base"></i>
      <span>إنشاء دورة جديدة</span>
    </button>
  </div>

  <div id="cyclesList" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <!-- Cards rendered by JS -->
  </div>

  <div id="cyclesEmpty" class="rounded-2xl border border-slate-200/90 bg-white shadow-sm shadow-slate-200/40 ring-1 ring-slate-100 overflow-hidden">
    <div class="py-14 px-6 text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-500">
        <i class="fas fa-file-excel text-3xl"></i>
      </div>
      <p class="text-slate-800 font-bold mb-1">لا توجد دورات محفوظة</p>
      <p class="text-sm text-slate-500 mb-6 max-w-md mx-auto leading-relaxed">أنشئ دورة مالية جديدة لربط جداول الإدارة والوكيل</p>
      <button type="button" onclick="openCycleModal()" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm active:scale-[0.98] transition-all">
        <i class="fas fa-plus"></i>
        <span>إنشاء أول دورة</span>
      </button>
    </div>
  </div>
</div>

<!-- Modal إنشاء/تعديل دورة -->
<div id="cycleModal" class="fixed inset-0 z-[1200] hidden flex items-end sm:items-center justify-center p-0 sm:p-4 max-lg:pb-[70px] max-lg:pt-[env(safe-area-inset-top,0px)] bg-black/50 backdrop-blur-[2px] overflow-x-hidden overflow-y-auto" onclick="if(event.target===this)closeCycleModal()">
  <!-- عرض أقصى أضيق على اللابتوب (كان max-w-2xl عريضاً جداً)؛ على الموبايل full width مع max-w-lg للاتساق -->
  <div class="bg-white w-full max-w-lg sm:mx-auto sm:rounded-2xl rounded-t-3xl max-h-[90vh] sm:max-h-[85vh] max-lg:max-h-[calc(100vh-70px)] max-lg:h-[calc(100vh-70px)] flex flex-col border border-slate-200/90 shadow-xl shadow-slate-200/50 ring-1 ring-slate-100 min-h-0 min-w-0" onclick="event.stopPropagation()">
    <!-- رأس: زر الإغلاق أولاً في DOM ليظهر يميناً في RTL (أوضح على الموبايل) -->
    <div class="relative z-20 flex items-center gap-3 px-3 sm:px-4 py-3 border-b border-slate-100 bg-gradient-to-l from-slate-50/90 to-white shrink-0 sm:rounded-t-2xl rounded-t-3xl">
      <button type="button" onclick="closeCycleModal()" class="relative z-30 flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-slate-200/80 bg-white text-slate-600 shadow-sm hover:bg-slate-50 hover:text-slate-900 active:scale-[0.98] transition-colors" aria-label="إغلاق">
        <i class="fas fa-times text-lg"></i>
      </button>
      <div class="flex min-w-0 flex-1 items-center gap-2.5">
        <div class="w-10 h-10 shrink-0 rounded-xl bg-indigo-100 flex items-center justify-center">
          <i class="fas fa-file-excel text-indigo-600 text-lg"></i>
        </div>
        <h2 id="cycleModalHeaderTitle" class="min-w-0 flex-1 text-base font-bold text-slate-900 truncate">إنشاء دورة مالية</h2>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1.5 px-2 py-2 bg-slate-50/80 border-b border-slate-100 shrink-0">
      <button type="button" id="tabGoogle" onclick="setCycleTab('google')" class="flex-1 inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-xl font-semibold text-xs transition-all bg-white text-indigo-600 shadow-sm ring-1 ring-slate-200/80">
        <i class="fas fa-cloud text-sm"></i>
        <span>Google Sheets</span>
      </button>
      <button type="button" id="tabUpload" onclick="setCycleTab('upload')" class="flex-1 inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-xl font-semibold text-xs transition-all text-slate-600 hover:bg-white/70">
        <i class="fas fa-upload text-sm"></i>
        <span>رفع ملفات</span>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto overscroll-contain px-3 py-3 space-y-2.5 min-h-0">
      <input type="hidden" id="cycleEditId" value="">

      <!-- Google -->
      <div id="panelGoogle" class="space-y-3">
        <div class="flex items-start gap-2.5 text-xs text-indigo-900 rounded-xl border border-indigo-200/80 bg-indigo-50/80 px-3 py-2.5">
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600 mt-0.5">
            <i class="fas fa-cloud text-[10px]"></i>
          </span>
          <span class="leading-relaxed pt-0.5">اختر الجداول من حسابك في Google Sheets</span>
        </div>

        <div class="rounded-xl border border-amber-200/80 bg-amber-50/40 p-3 shadow-sm">
          <div class="flex items-center gap-2 mb-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-amber-100 text-amber-700">
              <i class="fas fa-building text-xs"></i>
            </span>
            <span class="font-bold text-slate-800 text-sm">الإدارة</span>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1.5">الجدول</label>
              <select id="mgmtSpreadsheetId" class="w-full py-2.5 px-2.5 text-sm border-2 border-slate-200 rounded-xl bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all min-w-0">
                <option value="">— جاري التحميل... —</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1.5">الورقة</label>
              <select id="mgmtSheetName" class="w-full py-2.5 px-2.5 text-sm border-2 border-slate-200 rounded-xl bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all min-w-0">
                <option value="">أول ورقة تلقائياً</option>
              </select>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-indigo-200/70 bg-indigo-50/50 p-3 shadow-sm">
          <div class="flex items-center gap-2 mb-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-100 text-indigo-700">
              <i class="fas fa-user-tie text-xs"></i>
            </span>
            <span class="font-bold text-slate-800 text-sm">الوكيل</span>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1.5">الجدول</label>
              <select id="agentSpreadsheetId" class="w-full py-2.5 px-2.5 text-sm border-2 border-slate-200 rounded-xl bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all min-w-0">
                <option value="">— جاري التحميل... —</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 mb-1.5">الورقة</label>
              <select id="agentSheetName" class="w-full py-2.5 px-2.5 text-sm border-2 border-slate-200 rounded-xl bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all min-w-0">
                <option value="">أول ورقة تلقائياً</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- رفع يدوي -->
      <div id="panelUpload" class="space-y-3 hidden">
        <div class="rounded-xl border border-amber-200/80 bg-amber-50/40 p-3 shadow-sm">
          <div class="flex items-center gap-2 mb-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-amber-100 text-amber-700">
              <i class="fas fa-file text-xs"></i>
            </span>
            <span class="font-bold text-slate-800 text-sm">ملف الإدارة</span>
          </div>
          <input type="file" id="fileManagement" accept=".xlsx,.xls,.csv" class="w-full text-sm border-2 border-slate-200 rounded-xl bg-white p-2.5 file:mr-3 file:py-2 file:px-3 file:border-0 file:bg-amber-100 file:text-amber-900 file:rounded-lg file:text-xs file:font-semibold file:cursor-pointer hover:file:bg-amber-200/80 transition-all cursor-pointer">
        </div>
        <div class="rounded-xl border border-indigo-200/70 bg-indigo-50/50 p-3 shadow-sm">
          <div class="flex items-center gap-2 mb-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-100 text-indigo-700">
              <i class="fas fa-file text-xs"></i>
            </span>
            <span class="font-bold text-slate-800 text-sm">ملف الوكيل</span>
          </div>
          <input type="file" id="fileAgent" accept=".xlsx,.xls,.csv" class="w-full text-sm border-2 border-slate-200 rounded-xl bg-white p-2.5 file:mr-3 file:py-2 file:px-3 file:border-0 file:bg-indigo-100 file:text-indigo-900 file:rounded-lg file:text-xs file:font-semibold file:cursor-pointer hover:file:bg-indigo-200/60 transition-all cursor-pointer">
        </div>
      </div>

      <!-- معاينة + حفظ -->
      <div id="panelSave" class="hidden rounded-xl border border-slate-200/90 bg-gradient-to-br from-slate-50/90 to-white p-4 shadow-sm">
        <div class="flex gap-3 mb-4">
          <div class="flex-1 text-center py-3 bg-white rounded-xl border border-slate-200/90 shadow-sm">
            <p class="text-xs text-slate-500 mb-1 font-medium">الإدارة</p>
            <p id="previewMgmtRows" class="text-2xl font-black text-indigo-600 tabular-nums">0</p>
            <p class="text-xs text-slate-500 font-medium">صف</p>
          </div>
          <div class="flex-1 text-center py-3 bg-white rounded-xl border border-slate-200/90 shadow-sm">
            <p class="text-xs text-slate-500 mb-1 font-medium">الوكيل</p>
            <p id="previewAgentRows" class="text-2xl font-black text-indigo-600 tabular-nums">0</p>
            <p class="text-xs text-slate-500 font-medium">صف</p>
          </div>
        </div>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-bold text-slate-700 mb-1.5">اسم الدورة المالية</label>
            <input type="text" id="cycleName" placeholder="مثال: دورة يناير 2025" class="w-full px-3 py-2.5 text-sm border-2 border-slate-200 rounded-xl bg-white text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all">
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-700 mb-1.5">نسبة الخصم (%)</label>
            <input type="number" id="cycleTransferDiscountPct" min="0" max="100" step="0.1" placeholder="0" class="w-full px-3 py-2.5 text-sm border-2 border-slate-200 rounded-xl bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all">
            <p class="text-[11px] text-slate-500 mt-1.5 leading-relaxed">تُطبّق على جدول الوكيل؛ الجزء المخصوم يُسجّل كربح عند إعادة بناء المؤجل.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer: جلب/تحميل أو إلغاء+حفظ -->
    <div id="cycleModalFooter" class="bg-white/95 border-t border-slate-100 px-3 py-2.5 shrink-0 max-lg:pb-[max(0.5rem,env(safe-area-inset-bottom))]">
      <div id="cycleModalFooterPrimary" class="block">
        <button type="button" id="btnSheetModalPrimary" onclick="sheetModalPrimaryAction()" class="w-full h-11 flex items-center justify-center gap-2 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-sm shadow-sm active:scale-[0.98] transition-all">
          <i class="fas fa-cloud-download-alt"></i>
          <span>جلب البيانات</span>
        </button>
      </div>
      <div id="cycleModalFooterSave" class="hidden flex gap-2">
        <button type="button" onclick="closeCycleModal()" class="flex-1 h-11 flex items-center justify-center rounded-xl bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold text-sm transition-colors">إلغاء</button>
        <button type="button" id="btnSaveCycle" onclick="saveCycle()" class="flex-1 h-11 inline-flex items-center justify-center gap-2 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-semibold text-sm shadow-sm active:scale-[0.98] transition-all">
          <i class="fas fa-save"></i>
          <span>حفظ</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal تأكيد الحذف -->
<div id="deleteConfirmModal" class="fixed inset-0 z-[1200] hidden flex items-center justify-center p-4 bg-black/50 backdrop-blur-[2px]" onclick="if(event.target===this)closeDeleteConfirm()">
  <div class="bg-white rounded-2xl border border-slate-200/90 shadow-xl shadow-slate-200/50 ring-1 ring-slate-100 max-w-md w-full p-6" onclick="event.stopPropagation()">
    <div class="text-center mb-6">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 flex items-center justify-center">
        <i class="fas fa-trash-alt text-red-600 text-2xl"></i>
      </div>
      <h3 class="text-xl font-bold text-slate-900 mb-2">حذف الدورة المالية</h3>
      <p id="deleteConfirmText" class="text-slate-600 text-sm">هل أنت متأكد من حذف هذه الدورة؟ لا يمكن التراجع عن هذا الإجراء.</p>
    </div>
    <div class="flex gap-3">
      <button type="button" onclick="closeDeleteConfirm()" class="flex-1 py-3 rounded-xl font-semibold text-sm bg-slate-100 text-slate-700 hover:bg-slate-200 transition-colors">إلغاء</button>
      <button type="button" id="btnConfirmDelete" onclick="confirmDeleteCycle()" class="flex-1 py-3 rounded-xl font-semibold text-sm inline-flex items-center justify-center gap-2 bg-red-600 text-white shadow-sm hover:bg-red-700 transition-colors">
        <i class="fas fa-trash-alt"></i>
        <span>حذف نهائياً</span>
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  var modal = document.getElementById('cycleModal');
  var deleteModal = document.getElementById('deleteConfirmModal');
  if (!modal) return;

  function hideMobileHeader() {
    document.body.classList.add('cycle-modal-open');
    if (!window.matchMedia('(max-width: 1023px)').matches) return;
    var h = document.getElementById('mobileHeader');
    var n = document.getElementById('mobileBottomNav');
    if (h) h.classList.add('hidden');
    if (n) n.classList.add('hidden');
  }
  function showMobileHeader() {
    document.body.classList.remove('cycle-modal-open');
    if (!window.matchMedia('(max-width: 1023px)').matches) return;
    var h = document.getElementById('mobileHeader');
    var n = document.getElementById('mobileBottomNav');
    if (h) h.classList.remove('hidden');
    if (n) n.classList.remove('hidden');
  }

  window.sheetModalPrimaryAction = function() {
    var pg = document.getElementById('panelGoogle');
    if (pg && !pg.classList.contains('hidden')) {
      return fetchFromGoogle();
    }
    return uploadFiles();
  };

  window.sheetFooterShowPrimary = function() {
    var fp = document.getElementById('cycleModalFooterPrimary');
    var fs = document.getElementById('cycleModalFooterSave');
    if (fp) { fp.classList.remove('hidden'); fp.classList.add('block'); }
    if (fs) { fs.classList.add('hidden'); fs.classList.remove('flex'); }
    sheetUpdatePrimaryButtonLabel();
  };

  window.sheetFooterShowSave = function() {
    var fp = document.getElementById('cycleModalFooterPrimary');
    var fs = document.getElementById('cycleModalFooterSave');
    if (fp) { fp.classList.add('hidden'); fp.classList.remove('block'); }
    if (fs) { fs.classList.remove('hidden'); fs.classList.add('flex'); }
  };

  window.sheetUpdatePrimaryButtonLabel = function() {
    var btn = document.getElementById('btnSheetModalPrimary');
    var fs = document.getElementById('cycleModalFooterSave');
    if (!btn) return;
    if (fs && !fs.classList.contains('hidden')) return;
    var pg = document.getElementById('panelGoogle');
    if (pg && !pg.classList.contains('hidden')) {
      btn.innerHTML = '<i class="fas fa-cloud-download-alt"></i><span>جلب البيانات</span>';
    } else {
      btn.innerHTML = '<i class="fas fa-upload"></i><span>تحميل الملفات</span>';
    }
  };

  window.openCycleModal = function(editId) {
    hideMobileHeader();
    document.getElementById('cycleEditId').value = editId || '';
    var titleEl = document.getElementById('cycleModalHeaderTitle');
    if (titleEl) titleEl.textContent = editId ? 'تعديل الدورة' : 'إنشاء دورة مالية';
    document.getElementById('panelSave').classList.add('hidden');
    sheetFooterShowPrimary();
    document.getElementById('cycleName').value = '';
    var tdp = document.getElementById('cycleTransferDiscountPct');
    if (tdp) tdp.value = '';
    document.getElementById('fileManagement').value = '';
    document.getElementById('fileAgent').value = '';
    currentManagementRows = [];
    currentAgentRows = [];
    setCycleTab('google');
    loadSpreadsheetsList();
    if (editId) {
      loadCycleForEdit(editId).then(function() {
        document.getElementById('panelSave').classList.remove('hidden');
        sheetFooterShowSave();
        document.getElementById('previewMgmtRows').textContent = '—';
        document.getElementById('previewAgentRows').textContent = '—';
      });
    }
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  };

  window.closeCycleModal = function() {
    showMobileHeader();
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  };

  window.setCycleTab = function(tab) {
    var panelGoogle = document.getElementById('panelGoogle');
    var panelUpload = document.getElementById('panelUpload');
    var tabGoogle = document.getElementById('tabGoogle');
    var tabUpload = document.getElementById('tabUpload');
    var active = 'flex-1 inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-xl font-semibold text-xs transition-all bg-white text-indigo-600 shadow-sm ring-1 ring-slate-200/80';
    var idle = 'flex-1 inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-xl font-semibold text-xs transition-all text-slate-600 hover:bg-white/70';
    if (tab === 'google') {
      panelGoogle.classList.remove('hidden');
      panelUpload.classList.add('hidden');
      tabGoogle.className = active;
      tabUpload.className = idle;
      loadSpreadsheetsList();
    } else {
      panelGoogle.classList.add('hidden');
      panelUpload.classList.remove('hidden');
      tabUpload.className = active;
      tabGoogle.className = idle;
    }
    sheetUpdatePrimaryButtonLabel();
  };

  window.openDeleteConfirm = function(cycleId, cycleName) {
    hideMobileHeader();
    window._deleteCycleId = cycleId;
    document.getElementById('deleteConfirmText').textContent = 'هل أنت متأكد من حذف "' + (cycleName || 'الدورة') + '"؟ لا يمكن التراجع عن هذا الإجراء.';
    deleteModal.classList.remove('hidden');
    deleteModal.classList.add('flex');
  };

  window.closeDeleteConfirm = function() {
    showMobileHeader();
    deleteModal.classList.add('hidden');
    deleteModal.classList.remove('flex');
    window._deleteCycleId = null;
  };
})();

async function loadCycleForEdit(cycleId) {
  try {
    var res = await fetch('/api/sheet/cycles/' + cycleId);
    var data = await res.json();
    if (!data.success || !data.cycle) return;
    var c = data.cycle;
    document.getElementById('cycleName').value = c.name || '';
    var tdpEl = document.getElementById('cycleTransferDiscountPct');
    if (tdpEl) tdpEl.value = c.transfer_discount_pct != null && c.transfer_discount_pct !== '' ? c.transfer_discount_pct : '';
    if (c.management_spreadsheet_id) {
      document.getElementById('mgmtSpreadsheetId').value = c.management_spreadsheet_id;
      await loadSheetsForSpreadsheet(c.management_spreadsheet_id, 'mgmt');
      if (c.management_sheet_name) document.getElementById('mgmtSheetName').value = c.management_sheet_name;
    }
    if (c.agent_spreadsheet_id) {
      document.getElementById('agentSpreadsheetId').value = c.agent_spreadsheet_id;
      await loadSheetsForSpreadsheet(c.agent_spreadsheet_id, 'agent');
      if (c.agent_sheet_name) document.getElementById('agentSheetName').value = c.agent_sheet_name;
    }
  } catch (_) {}
}

async function loadSpreadsheetsList() {
  var selMgmt = document.getElementById('mgmtSpreadsheetId');
  var selAgent = document.getElementById('agentSpreadsheetId');
  if (!selMgmt || !selAgent) return;
  selMgmt.innerHTML = '<option value="">— جاري التحميل... —</option>';
  selAgent.innerHTML = '<option value="">— جاري التحميل... —</option>';
  document.getElementById('mgmtSheetName').innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  document.getElementById('agentSheetName').innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  try {
    var res = await fetch('/api/sheet/spreadsheets-list');
    var data = await res.json();
    if (!data.success) {
      selMgmt.innerHTML = '<option value="">' + (data.message || 'لم يتم الربط بـ Google') + '</option>';
      selAgent.innerHTML = '<option value="">' + (data.message || 'لم يتم الربط بـ Google') + '</option>';
      return;
    }
    var list = data.spreadsheets || [];
    var opt = '<option value="">— اختر الجدول —</option>' + list.map(function(f) { return '<option value="' + (f.id || '').replace(/"/g, '&quot;') + '">' + (f.name || f.id) + '</option>'; }).join('');
    selMgmt.innerHTML = opt;
    selAgent.innerHTML = opt;
    if (!window._sheetSelectListenersAdded) {
      window._sheetSelectListenersAdded = true;
      selMgmt.addEventListener('change', function() { loadSheetsForSpreadsheet(this.value, 'mgmt'); });
      selAgent.addEventListener('change', function() { loadSheetsForSpreadsheet(this.value, 'agent'); });
    }
  } catch (_) {
    selMgmt.innerHTML = '<option value="">خطأ في التحميل</option>';
    selAgent.innerHTML = '<option value="">خطأ في التحميل</option>';
  }
}

async function loadSheetsForSpreadsheet(spreadsheetId, which) {
  var sel = document.getElementById(which === 'mgmt' ? 'mgmtSheetName' : 'agentSheetName');
  if (!sel) return;
  sel.innerHTML = '<option value="">جاري التحميل...</option>';
  if (!spreadsheetId) { sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>'; return; }
  try {
    var res = await fetch('/api/sheet/spreadsheet-sheets?spreadsheetId=' + encodeURIComponent(spreadsheetId));
    var data = await res.json();
    if (!data.success || !data.sheets || !data.sheets.length) {
      sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>';
      return;
    }
    sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>' + data.sheets.map(function(s) { return '<option value="' + (s.title || '').replace(/"/g, '&quot;') + '">' + (s.title || '') + '</option>'; }).join('');
  } catch (_) {
    sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  }
}

var currentManagementRows = [];
var currentAgentRows = [];

function showSavePanel(managementRows, agentRows) {
  currentManagementRows = managementRows || [];
  currentAgentRows = agentRows || [];
  document.getElementById('previewMgmtRows').textContent = currentManagementRows.length;
  document.getElementById('previewAgentRows').textContent = currentAgentRows.length;
  document.getElementById('panelSave').classList.remove('hidden');
  if (typeof sheetFooterShowSave === 'function') sheetFooterShowSave();
}

async function fetchFromGoogle() {
  var mgmtId = (document.getElementById('mgmtSpreadsheetId').value || '').trim();
  var agentId = (document.getElementById('agentSpreadsheetId').value || '').trim();
  if (!mgmtId || !agentId) {
    if (typeof showToast === 'function') showToast('اختر جدول الإدارة وجدول الوكيل من القائمة', 'error');
    return;
  }
  var btn = document.getElementById('btnSheetModalPrimary');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>جاري الجلب...</span>';
  try {
    var res = await fetch('/api/sheet/import-google', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        managementSpreadsheetId: mgmtId,
        managementSheetName: (document.getElementById('mgmtSheetName').value || '').trim() || undefined,
        agentSpreadsheetId: agentId,
        agentSheetName: (document.getElementById('agentSheetName').value || '').trim() || undefined
      })
    });
    var data = await res.json();
    if (data.success) {
      btn.disabled = false;
      if (typeof sheetUpdatePrimaryButtonLabel === 'function') sheetUpdatePrimaryButtonLabel();
      showSavePanel(data.managementRows, data.agentRows);
      if (typeof showToast === 'function') showToast('تم جلب البيانات', 'success');
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل الاستيراد', 'error');
    }
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
  btn.disabled = false;
  if (typeof sheetUpdatePrimaryButtonLabel === 'function') sheetUpdatePrimaryButtonLabel();
}

async function uploadFiles() {
  var fileMgmt = document.getElementById('fileManagement').files[0];
  var fileAgent = document.getElementById('fileAgent').files[0];
  if (!fileMgmt || !fileAgent) {
    if (typeof showToast === 'function') showToast('اختر ملف الإدارة وملف الوكيل', 'error');
    return;
  }
  var btn = document.getElementById('btnSheetModalPrimary');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>جاري القراءة...</span>';
  var form = new FormData();
  form.append('managementFile', fileMgmt);
  form.append('agentFile', fileAgent);
  try {
    var res = await fetch('/api/sheet/upload', { method: 'POST', body: form });
    var data = await res.json();
    if (data.success) {
      btn.disabled = false;
      if (typeof sheetUpdatePrimaryButtonLabel === 'function') sheetUpdatePrimaryButtonLabel();
      showSavePanel(data.managementRows, data.agentRows);
      if (typeof showToast === 'function') showToast('تم قراءة الملفات', 'success');
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل قراءة الملفات', 'error');
    }
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
  btn.disabled = false;
  if (typeof sheetUpdatePrimaryButtonLabel === 'function') sheetUpdatePrimaryButtonLabel();
}

async function saveCycle() {
  var name = document.getElementById('cycleName').value.trim();
  if (!name) {
    if (typeof showToast === 'function') showToast('أدخل اسم الدورة', 'error');
    return;
  }
  var editId = document.getElementById('cycleEditId').value.trim();
  var btn = document.getElementById('btnSaveCycle');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>جاري الحفظ...</span>';
  try {
    var mgmtId = (document.getElementById('mgmtSpreadsheetId')?.value || '').trim();
    var agentId = (document.getElementById('agentSpreadsheetId')?.value || '').trim();
    var tdpRaw = document.getElementById('cycleTransferDiscountPct')?.value;
    var payload = {
      name: name,
      managementSpreadsheetId: mgmtId || null,
      managementSheetName: (document.getElementById('mgmtSheetName')?.value || '').trim() || null,
      agentSpreadsheetId: agentId || null,
      agentSheetName: (document.getElementById('agentSheetName')?.value || '').trim() || null,
      transferDiscountPct: tdpRaw !== undefined && tdpRaw !== '' ? Number(tdpRaw) : 0
    };
    if ((!mgmtId || !agentId) && (currentManagementRows.length || currentAgentRows.length)) {
      payload.managementData = currentManagementRows;
      payload.agentData = currentAgentRows;
      payload.managementSpreadsheetId = null;
      payload.agentSpreadsheetId = null;
    }
    var url = editId ? '/api/sheet/cycles/' + editId : '/api/sheet/cycles';
    var method = editId ? 'PUT' : 'POST';
    var res = await fetch(url, {
      method: method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    var data;
    try {
      data = await res.json();
    } catch (parseErr) {
      if (typeof showToast === 'function') showToast('خطأ في استجابة الخادم', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save"></i><span>حفظ</span>';
      return;
    }
    if (res.status === 401) {
      if (typeof showToast === 'function') showToast(data.message || 'انتهت الجلسة. سجّل دخولك مجدداً.', 'error');
      setTimeout(function() { window.location.href = '/login'; }, 1500);
      return;
    }
    if (data.success) {
      if (typeof showToast === 'function') showToast(data.message || 'تم حفظ الدورة', 'success');
      closeCycleModal();
      loadCycles();
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل الحفظ', 'error');
    }
  } catch (err) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال: ' + (err.message || 'تحقق من الاتصال'), 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-save"></i><span>حفظ</span>';
}

async function confirmDeleteCycle() {
  var id = window._deleteCycleId;
  if (!id) return;
  var btn = document.getElementById('btnConfirmDelete');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
  try {
    var res = await fetch('/api/sheet/cycles/' + id, { method: 'DELETE' });
    var data = await res.json();
    if (data.success) {
      if (typeof showToast === 'function') showToast(data.message || 'تم حذف الدورة', 'success');
      closeDeleteConfirm();
      loadCycles();
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل الحذف', 'error');
    }
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-trash-alt"></i><span>حذف نهائياً</span>';
}

function formatDate(d) {
  if (!d) return '—';
  try {
    return new Date(d).toLocaleDateString('ar-SA', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch (_) { return d; }
}

async function loadCycles() {
  try {
    var res = await fetch('/api/sheet/cycles');
    var data = await res.json();
    var list = document.getElementById('cyclesList');
    var empty = document.getElementById('cyclesEmpty');
    if (!data.success || !data.cycles || data.cycles.length === 0) {
      if (list) list.innerHTML = '';
      if (empty) empty.classList.remove('hidden');
      return;
    }
    if (empty) empty.classList.add('hidden');
    if (list) {
      var colors = ['from-indigo-500 to-violet-500', 'from-emerald-500 to-teal-500', 'from-amber-500 to-orange-500', 'from-rose-500 to-pink-500', 'from-purple-500 to-indigo-500'];
      list.innerHTML = data.cycles.map(function(c, i) {
        var gradient = colors[i % colors.length];
        var hasGoogle = !!(c.management_spreadsheet_id && c.agent_spreadsheet_id);
        var badgeGoogle = '<span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[11px] font-semibold border border-emerald-200/70 bg-emerald-50 text-emerald-800"><i class="fas fa-link text-[10px]"></i>مرتبطة بـ Google</span>';
        var badgeLocal = '<span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[11px] font-semibold border border-amber-200/70 bg-amber-50 text-amber-900"><i class="fas fa-file text-[10px]"></i>ملفات محلية</span>';
        var discount = c.transfer_discount_pct > 0
          ? '<div class="flex items-center gap-2 text-slate-600"><span class="text-xs">خصم التحويل:</span><span class="inline-flex rounded-full px-2 py-0.5 text-[11px] font-semibold border border-indigo-200/80 bg-indigo-50 text-indigo-800">' + c.transfer_discount_pct + '%</span></div>'
          : '';
        return '<div class="rounded-2xl border border-slate-200/90 bg-white shadow-sm shadow-slate-200/40 ring-1 ring-slate-100 overflow-hidden group hover:shadow-md hover:border-slate-200 transition-all">' +
          '<div class="h-1 bg-gradient-to-r ' + gradient + '"></div>' +
          '<div class="p-5">' +
            '<div class="flex items-start justify-between gap-3 mb-4">' +
              '<h3 class="font-bold text-slate-900 text-lg flex-1 min-w-0">' + (c.name || 'دورة').replace(/</g, '&lt;') + '</h3>' +
              '<div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">' +
                '<button type="button" onclick="event.stopPropagation(); openCycleModal(' + c.id + ')" class="w-9 h-9 rounded-lg text-slate-500 hover:bg-indigo-50 hover:text-indigo-600 flex items-center justify-center" title="تعديل"><i class="fas fa-edit"></i></button>' +
                '<button type="button" onclick="event.stopPropagation(); openDeleteConfirm(' + c.id + ', \'' + (c.name || '').replace(/'/g, "\\'") + '\')" class="w-9 h-9 rounded-lg text-slate-500 hover:bg-red-50 hover:text-red-600 flex items-center justify-center" title="حذف"><i class="fas fa-trash-alt"></i></button>' +
              '</div>' +
            '</div>' +
            '<div class="space-y-2 text-sm">' +
              '<div class="flex items-center gap-2 text-slate-600"><i class="fas fa-calendar text-slate-400 w-4 text-center"></i><span>' + formatDate(c.created_at) + '</span></div>' +
              '<div class="flex items-center gap-2">' + (hasGoogle ? badgeGoogle : badgeLocal) + '</div>' +
              discount +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
    }
  } catch (_) {}
}

(function initSheetPage() {
  loadCycles();
})();
</script>
