<% 
var homeDashCardBase = 'relative flex flex-col h-full min-h-[7.75rem] sm:min-h-[9rem] min-w-0 overflow-hidden rounded-2xl sm:rounded-3xl border border-slate-200/80 bg-gradient-to-br from-white via-white to-slate-50/95 p-3 sm:p-5 shadow-[0_1px_2px_rgba(15,23,42,0.05),0_4px_12px_-2px_rgba(15,23,42,0.04)] transition-all duration-300 ease-out hover:border-slate-300/90 hover:shadow-[0_4px_6px_-1px_rgba(15,23,42,0.06),0_12px_28px_-8px_rgba(15,23,42,0.1)] hover:-translate-y-0.5';
var homeDashCardA = homeDashCardBase + ' group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400/50 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50';
var homeDashCardGroup = homeDashCardBase + ' group';
var homeDashCardPlain = homeDashCardBase;
var homeDashLine = 'pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-l from-transparent via-slate-200/60 to-transparent';
var homeDashIcon = 'mb-2.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-[0.65rem] sm:mb-3 sm:h-11 sm:w-11 sm:rounded-xl shadow-inner shadow-black/[0.03] transition-all duration-300 group-hover:scale-[1.03]';
var homeDashLabel = 'mb-1 line-clamp-2 text-[0.625rem] font-semibold leading-snug text-slate-500 sm:text-[0.7rem] sm:leading-snug';
var homeDashMetric = 'mt-auto font-mono font-bold tabular-nums tracking-tight transition-colors duration-200 text-sm leading-tight sm:text-base sm:leading-none md:text-lg xl:text-xl';
%>
<div class="max-w-6xl mx-auto px-3 sm:px-4 lg:px-0 pb-10 relative min-w-0" dir="rtl" id="homeDashboardRoot">
  <!-- شريط أدوات: موبايل — عمودان | لابتوب -->
  <div class="mb-5 md:mb-6 flex flex-col items-center md:items-end gap-2 w-full">
    <div class="flex w-full max-md:max-w-lg max-md:mx-auto max-md:flex-row max-md:items-stretch max-md:gap-2 md:inline-flex md:flex-row md:flex-wrap md:items-center md:justify-end md:gap-2.5 md:max-w-full">
      <!-- الدورة -->
      <div class="flex min-w-0 flex-1 flex-col gap-1.5 max-md:rounded-2xl max-md:border max-md:border-slate-200/85 max-md:bg-white max-md:p-2.5 max-md:shadow-sm max-md:shadow-slate-900/[0.04] md:flex-row md:items-center md:gap-1.5 md:flex-none md:rounded-none md:border-0 md:bg-transparent md:p-0 md:shadow-none">
        <div class="flex items-center gap-1 text-slate-500 md:hidden">
          <span class="flex h-6 w-6 items-center justify-center rounded-md bg-indigo-50 text-indigo-600"><i class="fas fa-calendar-check text-[0.65rem]"></i></span>
          <span class="text-[0.65rem] font-semibold leading-tight">الدورة المالية</span>
        </div>
        <span class="hidden md:inline text-[0.65rem] sm:text-xs font-medium text-slate-500 shrink-0">دورة</span>
        <div class="flex min-w-0 flex-1 items-center gap-1">
          <select id="homeCycleSelect" class="min-w-0 flex-1 text-[0.7rem] sm:text-xs py-1.5 px-2 sm:px-2.5 rounded-lg border border-slate-200/90 bg-white/90 text-slate-800 shadow-sm transition focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400/30 md:min-w-[7.5rem] md:max-w-[11rem]" onchange="homeLoadStats()">
            <option value="">— دورة —</option>
          </select>
          <button type="button" onclick="homeLoadStats()" class="inline-flex shrink-0 items-center justify-center gap-1 rounded-lg bg-indigo-600/95 px-2 py-1.5 text-[0.65rem] sm:text-xs font-semibold text-white shadow-sm hover:bg-indigo-700 active:scale-[0.98] transition" title="تحديث الأرقام">
            <i class="fas fa-sync-alt text-[0.6rem]"></i>
            <span class="hidden sm:inline">تحديث</span>
          </button>
        </div>
      </div>
      <span class="hidden md:inline text-slate-200 select-none" aria-hidden="true">|</span>
      <!-- تقرير PDF -->
      <div class="flex min-w-0 flex-1 flex-col gap-1.5 max-md:rounded-2xl max-md:border max-md:border-slate-200/85 max-md:bg-white max-md:p-2.5 max-md:shadow-sm max-md:shadow-slate-900/[0.04] md:flex-row md:items-center md:gap-1.5 md:flex-none md:rounded-none md:border-0 md:bg-transparent md:p-0 md:shadow-none">
        <div class="flex items-center gap-1 text-slate-500 md:hidden">
          <span class="flex h-6 w-6 items-center justify-center rounded-md bg-red-50 text-red-600"><i class="fas fa-file-pdf text-[0.65rem]"></i></span>
          <span class="text-[0.65rem] font-semibold leading-tight">تقرير PDF</span>
        </div>
        <span class="hidden md:inline text-[0.65rem] sm:text-xs font-medium text-slate-500 shrink-0"><i class="fas fa-file-pdf text-red-500 text-[0.6rem] ml-0.5"></i> PDF</span>
        <div class="flex min-w-0 flex-1 items-center gap-1">
          <select id="homeReportType" class="min-w-0 flex-1 text-[0.7rem] sm:text-xs py-1.5 px-2 sm:px-2.5 rounded-lg border border-slate-200/90 bg-white/90 text-slate-800 shadow-sm focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400/30 md:min-w-[6.5rem] md:max-w-[10rem]" aria-label="نوع التقرير">
            <option value="comprehensive">شامل</option>
            <option value="accreditations">اعتمادات</option>
            <option value="transfer-companies">تحويل</option>
            <option value="movements">حركات</option>
          </select>
          <button type="button" onclick="homeDownloadReportPdf()" class="inline-flex shrink-0 items-center justify-center gap-1 rounded-lg bg-red-600 px-2 py-1.5 text-[0.65rem] sm:text-xs font-semibold text-white shadow-sm hover:bg-red-700 transition" title="تنزيل PDF">
            <i class="fas fa-download text-[0.6rem]"></i>
            تنزيل
          </button>
        </div>
      </div>
    </div>
    <p class="text-[0.6rem] sm:text-[0.65rem] text-slate-400 text-center md:text-right max-w-md leading-snug px-1">يُطبَّق اختيار الدورة على التقارير التي تدعم التصفية.</p>
  </div>

  <section class="space-y-6 lg:space-y-8">
    <!-- مؤشرات مالية -->
    <div>
      <h3 class="text-sm font-bold text-slate-800 mb-3 flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-100 text-indigo-700 shrink-0"><i class="fas fa-chart-pie text-sm"></i></span>
        مؤشرات مالية
      </h3>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2.5 sm:gap-4">
        <a href="/profit-sources" class="<%= homeDashCardA %>" title="مصادر الربح">
          <span class="<%= homeDashLine %>" aria-hidden="true"></span>
          <div class="<%= homeDashIcon %> bg-indigo-50 text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white">
            <i class="fas fa-coins text-base sm:text-lg"></i>
          </div>
          <p class="<%= homeDashLabel %>">الربح الصافي</p>
          <p class="<%= homeDashMetric %> text-slate-900" id="netProfit">0.00</p>
        </a>

        <a href="/expenses-manual" class="<%= homeDashCardA %>" title="المصاريف — تسجيل وسجل موحّد">
          <span class="<%= homeDashLine %>" aria-hidden="true"></span>
          <div class="<%= homeDashIcon %> bg-rose-50 text-rose-600 group-hover:bg-rose-600 group-hover:text-white">
            <i class="fas fa-receipt text-base sm:text-lg"></i>
          </div>
          <p class="<%= homeDashLabel %>">المصاريف (مجمّع)</p>
          <p class="<%= homeDashMetric %> text-slate-900" id="totalExpenses">0.00</p>
        </a>

        <a href="/debts" class="<%= homeDashCardA %>" id="homeCardDebt" title="صفحة الديون والملفات">
          <span class="<%= homeDashLine %>" aria-hidden="true"></span>
          <div class="<%= homeDashIcon %> bg-red-50 text-red-600 group-hover:bg-red-600 group-hover:text-white">
            <i class="fas fa-file-invoice-dollar text-base sm:text-lg"></i>
          </div>
          <p class="<%= homeDashLabel %>">إجمالي الديون</p>
          <p class="<%= homeDashMetric %> text-slate-900" id="totalDebts">0.00</p>
        </a>

        <a href="/receivables-to-us" class="<%= homeDashCardA %>" title="ديين لنا">
          <span class="<%= homeDashLine %>" aria-hidden="true"></span>
          <div class="<%= homeDashIcon %> bg-emerald-50 text-emerald-700 group-hover:bg-emerald-600 group-hover:text-white">
            <i class="fas fa-hand-holding-heart text-base sm:text-lg"></i>
          </div>
          <p class="<%= homeDashLabel %>">ديين لنا</p>
          <p class="<%= homeDashMetric %> text-slate-900" id="receivablesToUsHome">—</p>
        </a>
      </div>
    </div>

    <!-- سيولة ومستحقات -->
    <div>
      <h3 class="text-sm font-bold text-slate-800 mb-3 flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-100 text-amber-800 shrink-0"><i class="fas fa-wallet text-sm"></i></span>
        سيولة ومستحقات
      </h3>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2.5 sm:gap-4">
        <a href="/payment-due" class="<%= homeDashCardA %>" title="مطلوب دفع">
          <span class="<%= homeDashLine %>" aria-hidden="true"></span>
          <div class="<%= homeDashIcon %> bg-amber-50 text-amber-700 group-hover:bg-amber-500 group-hover:text-white">
            <i class="fas fa-money-bill-wave text-base sm:text-lg"></i>
          </div>
          <p class="<%= homeDashLabel %>">مطلوب دفع</p>
          <p class="<%= homeDashMetric %> text-slate-900" id="paymentDueHome">—</p>
        </a>

        <div class="<%= homeDashCardGroup %> cursor-pointer" id="homeCardCash" onclick="homeOpenFundModal()" title="مصادر الأموال والصناديق">
          <span class="<%= homeDashLine %>" aria-hidden="true"></span>
          <div class="<%= homeDashIcon %> bg-amber-50 text-amber-600">
            <i class="fas fa-vault text-base sm:text-lg"></i>
          </div>
          <p class="<%= homeDashLabel %>">رصيد الصندوق الرئيسي</p>
          <p class="text-[0.6rem] sm:text-[0.65rem] text-slate-400 mb-0.5">(محاسبي)</p>
          <p class="<%= homeDashMetric %> text-slate-900" id="cashBalance">0.00</p>
        </div>

        <a href="/deferred-balance" id="deferredBalanceLink" class="<%= homeDashCardA %>">
          <span class="<%= homeDashLine %>" aria-hidden="true"></span>
          <div class="<%= homeDashIcon %> bg-sky-50 text-sky-600 group-hover:bg-sky-600 group-hover:text-white">
            <i class="fas fa-clock-rotate-left text-base sm:text-lg"></i>
          </div>
          <p class="<%= homeDashLabel %>">رصيد المؤجل</p>
          <p class="<%= homeDashMetric %> text-slate-900" id="deferredBalance">0.00</p>
        </a>

        <div class="<%= homeDashCardPlain %>">
          <span class="<%= homeDashLine %>" aria-hidden="true"></span>
          <div class="mb-2.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-[0.65rem] sm:mb-3 sm:h-11 sm:w-11 sm:rounded-xl shadow-inner shadow-black/[0.03] transition-all duration-300 bg-violet-50 text-violet-600">
            <i class="fas fa-truck-fast text-base sm:text-lg"></i>
          </div>
          <p class="<%= homeDashLabel %>">رصيد الشحن (كمية)</p>
          <p class="<%= homeDashMetric %> text-slate-900" id="shippingBalance">0.00</p>
        </div>
      </div>
    </div>
  </section>

  <!-- حالة Google Sheets -->
  <div class="mt-5 lg:mt-6 flex justify-center md:justify-end w-full">
    <div class="inline-flex items-center gap-2 sm:gap-2.5 max-w-full flex-wrap justify-center rounded-full border border-slate-200/70 bg-gradient-to-l from-white to-slate-50/90 pl-2.5 pr-1.5 py-1 shadow-sm shadow-slate-900/[0.03]">
      <span class="inline-flex items-center gap-1 text-[0.65rem] sm:text-[0.7rem] font-medium text-slate-500 shrink-0" title="Google Sheets">
        <i class="fas fa-table text-emerald-600/90 text-[0.65rem]"></i>
        <span class="hidden sm:inline">Sheets</span>
      </span>
      <span class="h-3 w-px shrink-0 bg-slate-200/90" aria-hidden="true"></span>
      <span id="homeSheetsStatus" class="inline-flex items-center rounded-full px-2 py-0.5 text-[0.6rem] sm:text-[0.65rem] font-semibold bg-slate-100 text-slate-500">جاري التحقق…</span>
      <a href="/settings" class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-slate-400 transition hover:bg-indigo-50 hover:text-indigo-600" title="إعدادات الربط" aria-label="إعدادات Google Sheets">
        <i class="fas fa-sliders-h text-[0.7rem]"></i>
      </a>
    </div>
  </div>
</div>

<!-- نافذة مصادر الصناديق -->
<div id="homeFundModal" class="fixed inset-0 z-[3000] hidden items-center justify-center p-4 bg-slate-900/50 backdrop-blur-[2px]">
  <div class="bg-white rounded-2xl max-w-lg w-full max-h-[85vh] overflow-hidden shadow-2xl border border-slate-200/80 flex flex-col">
    <div class="flex justify-between items-center gap-3 px-6 py-4 border-b border-slate-100 bg-slate-50/80">
      <h4 class="text-lg font-bold text-slate-900">مصادر الأموال والصناديق</h4>
      <button type="button" onclick="homeCloseFundModal()" class="flex h-9 w-9 items-center justify-center rounded-lg text-slate-400 hover:bg-slate-200 hover:text-slate-700 transition" aria-label="إغلاق">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>
    <div id="homeFundModalBody" class="text-sm text-slate-600 space-y-3 p-6 overflow-y-auto"></div>
  </div>
</div>
