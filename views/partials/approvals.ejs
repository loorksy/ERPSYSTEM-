<style>
  /* معاينة رفع أرصدة الاعتمادات: بطاقات على الموبايل، جدول على الشاشات الأوسع */
  @media (max-width: 767px) {
    .acc-bulk-scroll { overflow-x: hidden !important; }
    .acc-bulk-review { min-width: 0 !important; width: 100% !important; }
    .acc-bulk-review thead.acc-bulk-thead { display: none !important; }
    .acc-bulk-review tbody tr.acc-bulk-tr {
      display: block;
      border: 1px solid rgb(226 232 240);
      border-radius: 0.75rem;
      margin-bottom: 0.75rem;
      background: #fff;
      box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.04);
      overflow: hidden;
    }
    .acc-bulk-review tbody td.acc-bulk-td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.75rem;
      padding: 0.65rem 0.85rem !important;
      border-bottom: 1px solid rgb(241 245 249);
      width: 100%;
      box-sizing: border-box;
    }
    .acc-bulk-review tbody td.acc-bulk-td:last-child { border-bottom: none; }
    .acc-bulk-review tbody td.acc-bulk-td::before {
      content: attr(data-label);
      flex-shrink: 0;
      font-size: 0.75rem;
      font-weight: 600;
      color: rgb(100 116 139);
      max-width: 40%;
    }
    .acc-bulk-review tbody td.acc-bulk-td > *:last-child {
      flex: 1 1 auto;
      min-width: 0;
      text-align: end;
    }
  }
</style>
<div class="w-full max-w-6xl mx-auto" dir="rtl">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-8">
    <div class="flex items-center gap-3 min-w-0">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md">
        <i class="fas fa-stamp text-xl"></i>
      </div>
      <div>
        <h2 class="text-xl sm:text-2xl font-bold text-slate-900">الاعتمادات</h2>
        <p class="text-sm text-slate-500 mt-0.5">المعتمدون، الأرصدة، والتسليم</p>
      </div>
    </div>
    <div class="flex flex-wrap gap-2">
      <button type="button" onclick="accOpenBulk()" class="px-4 py-2.5 rounded-xl bg-slate-600 text-white text-sm font-semibold shadow-md hover:bg-slate-700 active:scale-[0.99] transition">رفع أرصدة</button>
      <button type="button" onclick="accOpenDelivery()" class="px-4 py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-semibold shadow-md hover:bg-emerald-700 active:scale-[0.99] transition">تسليم</button>
      <button type="button" onclick="accOpenAdd()" class="px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">
        <i class="fas fa-plus ml-2"></i> إضافة معتمد
      </button>
    </div>
  </div>
  <div id="accCards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <p class="text-slate-400 col-span-full text-center py-12">جاري التحميل...</p>
  </div>
</div>

<div id="accBulkModal" class="fixed inset-0 z-[2000] hidden items-start sm:items-center justify-center p-3 sm:p-4 bg-slate-900/50 backdrop-blur-[2px] overflow-y-auto overscroll-contain">
  <div class="bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-[min(100vw-1.5rem,80rem)] my-4 sm:my-8 overflow-hidden flex flex-col max-h-[calc(100dvh-2rem)] sm:max-h-[calc(100dvh-3rem)]">
    <div class="border-b border-slate-100 px-4 sm:px-6 py-4 bg-gradient-to-l from-slate-50 to-white shrink-0">
      <h4 class="text-lg font-bold text-slate-900">إضافة أرصدة (دفعة)</h4>
      <p class="text-xs text-slate-500 mt-1 leading-relaxed">أعمدة الملف: A كود، B اسم، C رصيد، D معتمد رئيسي — بعد الرفع تُعرض المعاينة للتعديل قبل الحفظ</p>
    </div>
    <div class="p-4 sm:p-6 space-y-4 sm:space-y-5 overflow-y-auto flex-1 min-h-0">
      <div class="grid sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-1.5">الدورة المالية</label>
          <select id="accBulkCycle" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400"><option value="">— دورة مالية —</option></select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-1.5">نسبة وساطة افتراضية (0–100)</label>
          <input type="number" id="accBulkBroker" min="0" max="100" step="0.01" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 text-sm" placeholder="0">
        </div>
      </div>

      <div id="accBulkStaging" class="hidden rounded-2xl border border-emerald-200/80 bg-gradient-to-b from-emerald-50/90 to-white p-4 sm:p-5 space-y-4 shadow-sm ring-1 ring-emerald-100/60">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div class="min-w-0">
            <p class="text-base font-bold text-slate-900">مراجعة الصفوف</p>
            <p class="text-xs sm:text-sm text-slate-600 mt-1">اضبط الوساطة واتجاه الرصيد ونوع المبلغ لكل معتمد، أو احذف الصف قبل الحفظ.</p>
          </div>
          <span id="accBulkStagingBadge" class="inline-flex shrink-0 items-center justify-center rounded-full bg-emerald-600 text-white text-xs font-bold px-3 py-1.5 shadow-sm">0 صف</span>
        </div>
        <div id="accBulkStagingTable" class="rounded-xl border border-slate-200/90 bg-white shadow-inner overflow-hidden"></div>
        <div class="flex flex-col-reverse gap-2 sm:flex-row sm:flex-wrap sm:items-center">
          <button type="button" onclick="accClearBulkStaging()" class="w-full sm:w-auto px-4 py-3 sm:py-2.5 rounded-xl bg-slate-100 text-slate-800 text-sm font-semibold hover:bg-slate-200 transition">إلغاء المعاينة</button>
          <button type="button" onclick="accCommitBulk()" class="w-full sm:w-auto px-4 py-3 sm:py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-semibold hover:bg-emerald-700 shadow-md transition">حفظ الكل</button>
        </div>
      </div>

      <div id="accBulkSourceWrap" class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4 sm:p-5 space-y-4">
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">مصادر البيانات</p>
        <div class="rounded-xl border border-slate-200/80 bg-white p-4 space-y-3 shadow-sm">
          <p class="text-sm font-bold text-slate-900 flex items-center gap-2">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600 text-xs font-bold">1</span>
            ملف من الجهاز
          </p>
          <input type="file" id="accBulkFile" accept=".csv,.xlsx,.xls" class="w-full min-h-[44px] text-sm file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-indigo-50 file:text-indigo-700 file:font-semibold">
          <button type="button" onclick="accSubmitBulk()" class="w-full min-h-[44px] py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">تحميل ومعاينة</button>
        </div>
        <div class="rounded-xl border border-slate-200/80 bg-white p-4 space-y-3 shadow-sm">
          <p class="text-sm font-bold text-slate-900 flex items-center gap-2">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600 text-xs font-bold">2</span>
            لصق CSV / نص
          </p>
          <textarea id="accBulkPaste" rows="5" class="w-full min-h-[120px] px-3 py-2.5 rounded-xl border border-slate-200 text-xs sm:text-sm font-mono focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" placeholder="الصق الصفوف من Excel أو CSV…"></textarea>
          <button type="button" onclick="accSubmitBulkText()" class="w-full min-h-[44px] py-2.5 rounded-xl bg-white border border-slate-200 text-slate-800 text-sm font-semibold hover:bg-slate-50 transition">معاينة من النص</button>
        </div>
        <div class="rounded-xl border border-slate-200/80 bg-white p-4 space-y-3 shadow-sm">
          <p class="text-sm font-bold text-slate-900 flex items-center gap-2">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600 text-xs font-bold">3</span>
            رابط Google Sheet
          </p>
          <p class="text-xs text-indigo-900 bg-indigo-50 border border-indigo-100 rounded-xl px-3 py-2 leading-relaxed">يتطلب ربط Google من إعدادات الجداول (Sheet).</p>
          <input type="url" id="accBulkSheetUrl" class="w-full min-h-[44px] px-3 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" placeholder="https://docs.google.com/spreadsheets/d/...">
          <input type="text" id="accBulkSheetName" class="w-full min-h-[44px] px-3 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" placeholder="اسم الورقة (اختياري)">
          <button type="button" onclick="accSubmitBulkSheetUrl()" class="w-full min-h-[44px] py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">معاينة من الرابط</button>
        </div>
      </div>

      <button type="button" onclick="accCloseBulk()" class="w-full py-2.5 rounded-xl bg-slate-100 text-slate-800 text-sm font-semibold hover:bg-slate-200 transition">إغلاق</button>
    </div>
  </div>
</div>
<div id="accDeliveryModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl p-6 max-w-md w-full max-h-[85vh] overflow-y-auto">
    <h4 class="font-bold mb-3">تسليم معتمدين</h4>
    <select id="accDelCycle" class="w-full mb-2 px-3 py-2 rounded-lg border border-slate-200 text-sm"><option value="">— دورة —</option></select>
    <div id="accDelList" class="text-sm space-y-2 mb-3 max-h-48 overflow-y-auto"></div>
    <div class="flex gap-2">
      <button type="button" onclick="accSubmitDelivery()" class="flex-1 py-2 rounded-lg bg-emerald-600 text-white text-sm font-semibold hover:bg-emerald-700">تسليم</button>
      <button type="button" onclick="accCloseDelivery()" class="px-4 py-2 rounded-lg bg-slate-100">إلغاء</button>
    </div>
  </div>
</div>

<div id="accAddModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl p-6 max-w-md w-full">
    <h4 class="font-bold mb-4">معتمد جديد</h4>
    <form id="accAddForm" class="space-y-3">
      <input type="text" id="accName" placeholder="الاسم" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
      <input type="text" id="accCode" placeholder="الكود" class="w-full px-4 py-2.5 rounded-xl border border-slate-200">
      <div class="flex gap-2">
        <button type="submit" class="flex-1 py-3 rounded-xl bg-indigo-600 text-white font-semibold">حفظ</button>
        <button type="button" onclick="accCloseAdd()" class="px-4 py-3 rounded-xl bg-slate-100">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<div id="accDetailModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h4 id="accDetailTitle" class="text-lg font-bold"></h4>
        <p id="accDetailBal" class="text-indigo-600 font-semibold mt-1"></p>
      </div>
      <button type="button" onclick="accCloseDetail()" class="text-slate-400"><i class="fas fa-times text-xl"></i></button>
    </div>
    <div class="flex gap-2 mb-4">
      <button type="button" onclick="accShowAddAmount()" class="flex-1 py-2 rounded-xl bg-emerald-600 text-white text-sm font-semibold">إضافة مبلغ</button>
      <button type="button" onclick="accShowTransfer()" class="flex-1 py-2 rounded-xl bg-slate-600 text-white text-sm font-semibold hover:bg-slate-700">تحويل</button>
      <button type="button" id="accPinBtn" onclick="accTogglePin()" class="py-2 px-3 rounded-xl bg-amber-100 text-amber-800 text-sm">تثبيت</button>
    </div>
    <div id="accAddAmountPanel" class="hidden space-y-2 mb-4 p-4 rounded-xl bg-slate-50">
      <select id="accAmountKind" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="accAmountKindChange()">
        <option value="salary">راتب (وساطة + صندوق حسب الاتجاه)</option>
        <option value="debt_to_us">دين لنا — على المعتمد (بدون وساطة/صندوق)</option>
      </select>
      <select id="accSalaryDir" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm acc-salary-only">
        <option value="to_us">راتب لنا</option>
        <option value="to_them">راتب علينا</option>
      </select>
      <input type="number" id="accAmt" step="0.01" placeholder="المبلغ" class="w-full px-3 py-2 rounded-lg border border-slate-200">
      <input type="number" id="accBroker" step="0.1" placeholder="نسبة الوساطة %" class="w-full px-3 py-2 rounded-lg border border-slate-200 acc-salary-only">
      <select id="accCycle" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm"><option value="">— دورة مالية —</option></select>
      <button type="button" onclick="accSubmitAmount()" class="w-full py-2 rounded-lg bg-indigo-600 text-white text-sm">تسجيل</button>
    </div>
    <div id="accTransferPanel" class="hidden space-y-2 mb-4 p-4 rounded-xl bg-slate-50">
      <select id="accTfType" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="accTfTypeChange()">
        <option value="manual">تسليم يدوي</option>
        <option value="fund">تحويل صندوق</option>
        <option value="company">تحويل (شركة)</option>
        <option value="shipping">شحن</option>
      </select>
      <input type="number" id="accTfAmt" step="0.01" placeholder="المبلغ" class="w-full px-3 py-2 rounded-lg border border-slate-200">
      <select id="accTfFund" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm hidden"></select>
      <select id="accTfCompany" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm hidden"></select>
      <p id="accTfShipHint" class="text-xs text-slate-500 hidden">سجّل عملية الشحن من قسم الشحن ثم اربطها لاحقاً إن لزم.</p>
      <button type="button" onclick="accSubmitTransfer()" class="w-full py-2 rounded-lg bg-indigo-600 text-white text-sm">تنفيذ</button>
    </div>
    <h5 class="font-bold text-slate-800 mb-2">السجل</h5>
    <div id="accLedger" class="text-sm space-y-2 max-h-48 overflow-y-auto"></div>
  </div>
</div>
