<div class="acc-approvals-page w-full max-w-6xl mx-auto min-w-0 px-4 sm:px-0 pb-10" dir="rtl">
  <!-- أزرار مدمجة — erp-toolbar-actions: Grid موبايل موحّد بين المتصفحات -->
  <div class="mb-6 erp-toolbar-actions">
    <button type="button" onclick="accOpenBulk()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-slate-700 text-white text-[11px] leading-snug sm:text-sm font-semibold shadow-md hover:bg-slate-800 active:scale-[0.99] transition text-center touch-manipulation">رفع أرصدة</button>
    <button type="button" onclick="accOpenDelivery()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-emerald-600 text-white text-[11px] leading-snug sm:text-sm font-semibold shadow-md hover:bg-emerald-700 active:scale-[0.99] transition text-center touch-manipulation">تسليم</button>
    <button type="button" onclick="accOpenAdd()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-gradient-to-br from-indigo-600 to-indigo-500 text-white text-[11px] leading-snug sm:text-sm font-semibold shadow-md shadow-indigo-500/25 hover:brightness-105 active:scale-[0.99] transition touch-manipulation">
      <i class="fas fa-plus text-[10px] sm:text-sm shrink-0 opacity-95" aria-hidden="true"></i>
      <span class="text-center">إضافة معتمد</span>
    </button>
  </div>
  <div id="accCards" class="agencies-grid">
    <div class="col-span-full acc-approvals-empty text-slate-400 text-center py-12 flex flex-col items-center gap-2">
      <i class="fas fa-spinner fa-spin text-3xl text-indigo-400" aria-hidden="true"></i>
      <span class="text-sm font-medium">جاري التحميل...</span>
    </div>
  </div>
</div>

<div id="accBulkModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 md:p-8 max-lg:p-2 max-lg:items-stretch max-lg:justify-start bg-slate-900/60 backdrop-blur-sm transition-opacity" dir="rtl" data-acc-step="import">
  <div class="acc-bulk-modal-shell bg-white rounded-2xl sm:rounded-[2rem] max-lg:rounded-xl shadow-2xl w-full flex flex-col min-h-0 relative transform transition-all overflow-hidden mx-auto">
    
    <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-start sm:items-center bg-white/80 backdrop-blur-md z-10 shrink-0">
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 flex items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 shrink-0">
          <i class="fas fa-file-import text-lg"></i>
        </div>
        <div>
          <h4 class="text-base sm:text-lg font-bold text-slate-800">رفع أرصدة</h4>
          <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">استيراد من Excel أو نص أو Google Sheets</p>
        </div>
      </div>
      <button type="button" onclick="accCloseBulk()" class="text-slate-400 hover:text-slate-600 hover:bg-slate-100 p-2 rounded-xl transition-colors shrink-0" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
    </div>

    <div id="accBulkStepper" class="flex items-center justify-center px-4 py-3 bg-slate-50/80 border-b border-slate-100 shrink-0 gap-2 sm:gap-4 relative z-0">
      <div class="flex items-center gap-2">
        <span class="acc-bulk-step-dot-1 flex h-8 w-8 items-center justify-center rounded-full border-2 text-sm font-bold transition-all duration-300"><i class="fas fa-file-import text-xs"></i></span>
        <span class="acc-bulk-step-label-1 text-sm font-semibold transition-all duration-300">استيراد</span>
      </div>
      <div class="w-12 sm:w-16 h-px bg-slate-300"></div>
      <div class="flex items-center gap-2">
        <span class="acc-bulk-step-dot-2 flex h-8 w-8 items-center justify-center rounded-full border-2 text-sm font-bold transition-all duration-300"><i class="fas fa-list-check text-xs"></i></span>
        <span class="acc-bulk-step-label-2 text-sm font-semibold transition-all duration-300">مراجعة</span>
      </div>
    </div>

    <div id="accBulkModalBody" class="acc-bulk-modal-body p-4 sm:p-6 overflow-y-auto flex-1 min-h-0 overscroll-contain bg-slate-50/30">
      
      <div id="accBulkSettingsWrap" class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 mb-5 shadow-sm">
        <h5 class="text-sm font-bold text-slate-700 mb-4 flex items-center gap-2">
          <i class="fas fa-sliders text-indigo-500"></i> إعدادات الاعتماد الأساسية
        </h5>
        <div class="max-w-xl">
          <label class="block text-xs font-semibold text-slate-600 mb-1.5">الدورة المالية (اختياري)</label>
          <select id="accBulkCycle" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-sm focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all outline-none"><option value="">— دورة مالية —</option></select>
        </div>
      </div>

      <div id="accBulkSourceWrap" class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 shadow-sm transition-all duration-300">
        <div class="flex bg-slate-100 p-1 rounded-xl mb-5" role="tablist">
          <button type="button" class="acc-bulk-src-btn flex-1 py-2 text-xs sm:text-sm font-semibold rounded-lg text-slate-500 transition-all" data-acc-source="file">ملف</button>
          <button type="button" class="acc-bulk-src-btn flex-1 py-2 text-xs sm:text-sm font-semibold rounded-lg text-slate-500 transition-all" data-acc-source="paste">لصق نص</button>
          <button type="button" class="acc-bulk-src-btn flex-1 py-2 text-xs sm:text-sm font-semibold rounded-lg text-slate-500 transition-all" data-acc-source="sheet">رابط Sheet</button>
        </div>
        <select id="accBulkSourceMethod" class="hidden"><option value="file" selected></option><option value="paste"></option><option value="sheet"></option></select>

        <div id="accBulkPanelFile" class="acc-bulk-source-panel space-y-4">
          <input type="file" id="accBulkFile" accept=".csv,.xlsx,.xls" class="hidden">
          <label for="accBulkFile" id="accBulkDropzone" class="acc-bulk-dropzone flex flex-col items-center justify-center p-8 border-2 border-dashed border-indigo-200 rounded-xl bg-indigo-50/30 hover:bg-indigo-50/80 cursor-pointer transition-all group">
            <div class="h-12 w-12 bg-white rounded-full flex items-center justify-center shadow-sm text-indigo-500 mb-3 group-hover:scale-110 transition-transform">
              <i class="fas fa-file-excel text-xl"></i>
            </div>
            <span class="text-sm font-bold text-slate-700">اختر أو اسحب ملف Excel/CSV</span>
            <span class="text-xs text-slate-500 mt-1">يجب أن يحتوي على (كود، اسم، رصيد)</span>
            <span id="accBulkFileName" class="hidden mt-3 px-3 py-1 bg-indigo-100 text-indigo-700 text-xs rounded-full font-mono max-w-full truncate"></span>
          </label>
          <button type="button" onclick="accSubmitBulk()" class="w-full py-3 rounded-xl bg-indigo-600 text-white font-bold shadow-md shadow-indigo-200 hover:bg-indigo-700 hover:shadow-lg hover:-translate-y-0.5 transition-all">تحميل ومعاينة <i class="fas fa-arrow-left mr-1 text-xs opacity-80"></i></button>
        </div>

        <div id="accBulkPanelPaste" class="acc-bulk-source-panel hidden space-y-4">
          <textarea id="accBulkPaste" rows="5" class="w-full p-4 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all outline-none resize-none font-mono" placeholder="الصق بيانات الأعمدة هنا..."></textarea>
          <button type="button" onclick="accSubmitBulkText()" class="w-full py-3 rounded-xl bg-indigo-600 text-white font-bold shadow-md shadow-indigo-200 hover:bg-indigo-700 hover:shadow-lg hover:-translate-y-0.5 transition-all">معاينة النص <i class="fas fa-arrow-left mr-1 text-xs opacity-80"></i></button>
        </div>

        <div id="accBulkPanelSheet" class="acc-bulk-source-panel hidden space-y-4">
          <div class="bg-indigo-50/50 border border-indigo-100 rounded-xl p-3 flex gap-3 text-indigo-700 text-xs">
            <i class="fas fa-info-circle mt-0.5"></i>
            <p>تأكد من أن رابط Google Sheet متاح للمشاهدة.</p>
          </div>
          <input type="url" id="accBulkSheetUrl" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none" placeholder="رابط Google Sheet">
          <input type="text" id="accBulkSheetName" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none" placeholder="اسم الورقة (اختياري)">
          <button type="button" onclick="accSubmitBulkSheetUrl()" class="w-full py-3 rounded-xl bg-indigo-600 text-white font-bold shadow-md shadow-indigo-200 hover:bg-indigo-700 hover:shadow-lg hover:-translate-y-0.5 transition-all">معاينة الرابط <i class="fas fa-arrow-left mr-1 text-xs opacity-80"></i></button>
        </div>
      </div>

      <div id="accBulkStaging" class="hidden animate-fade-in mx-auto w-full flex flex-col min-h-0">
        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm flex flex-col min-h-0 overflow-visible relative">
          <div class="p-4 sm:p-5 border-b border-slate-100 flex flex-wrap gap-4 justify-between items-center bg-slate-50/50">
            <div>
              <h3 class="text-base font-bold text-slate-800">مراجعة البيانات</h3>
              <p class="text-xs text-slate-500 mt-0.5">تأكد من صحة الحقول قبل الحفظ</p>
            </div>
            <span id="accBulkStagingBadge" class="bg-emerald-100 text-emerald-700 px-3 py-1.5 rounded-full text-xs font-bold flex items-center gap-1.5 border border-emerald-200 shadow-sm">
              <i class="fas fa-check-circle"></i> <span class="acc-bulk-badge-text">0</span>
            </span>
          </div>

          <div id="accBulkReviewKindWrap" class="px-4 sm:px-5 py-3 border-b border-slate-100 bg-white">
            <select id="accBulkReviewKind" aria-label="نوع الدين" class="w-full max-w-xl px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-sm focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all outline-none">
              <option value="debt_receivable">لنا — دين على المعتمد</option>
              <option value="debt_payable">علينا — صندوق + مطلوب دفع</option>
              <option value="debt_payable_no_fund">لهم — مطلوب دفع + ربح خصم (بدون صندوق رئيسي)</option>
            </select>
          </div>
          
          <div id="accBulkStagingTable" class="w-full"></div>

          <div class="acc-bulk-staging-footer shrink-0 border-t border-slate-200 bg-gradient-to-b from-slate-50/95 to-white px-4 sm:px-6 py-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 w-full max-w-2xl mx-auto">
              <button type="button" onclick="accClearBulkStaging()" class="order-2 sm:order-1 px-6 py-3 sm:py-2.5 rounded-xl border border-slate-300 text-slate-700 font-bold hover:bg-slate-100 transition-colors text-sm w-full flex items-center justify-center gap-2"><i class="fas fa-undo"></i> تراجع وإلغاء</button>
              <button type="button" onclick="accCommitBulk()" class="order-1 sm:order-2 px-6 py-3 sm:py-2.5 rounded-xl bg-emerald-600 text-white font-bold shadow-md shadow-emerald-200 hover:bg-emerald-700 hover:shadow-lg hover:-translate-y-0.5 transition-all text-sm w-full flex items-center justify-center gap-2"><i class="fas fa-save"></i> حفظ واعتماد</button>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</div>
<div id="accDeliveryModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 md:p-8 max-lg:p-2 max-lg:items-stretch max-lg:justify-start bg-slate-900/60 backdrop-blur-sm transition-opacity" dir="rtl">
  <div class="acc-delivery-modal-shell bg-white rounded-2xl sm:rounded-[2rem] max-lg:rounded-xl shadow-2xl w-full flex flex-col min-h-0 overflow-hidden mx-auto">
    <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-start sm:items-center bg-white/80 backdrop-blur-md z-10 shrink-0">
      <div class="flex items-center gap-3 min-w-0">
        <div class="h-10 w-10 flex items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 shrink-0">
          <i class="fas fa-hand-holding-dollar text-lg"></i>
        </div>
        <div class="min-w-0">
          <h4 class="text-base sm:text-lg font-bold text-slate-800">تسليم معتمدين</h4>
          <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">اختر الدورة، حدّد ذوي الرصيد، ثم نفّذ التسليم</p>
        </div>
      </div>
      <button type="button" onclick="accCloseDelivery()" class="text-slate-400 hover:text-slate-600 hover:bg-slate-100 p-2 rounded-xl transition-colors shrink-0" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
    </div>

    <div id="accDeliveryModalBody" class="p-4 sm:p-6 overflow-y-auto flex-1 min-h-0 overscroll-contain bg-slate-50/30">
      <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 shadow-sm mb-4">
        <label for="accDelCycle" class="block text-xs font-semibold text-slate-600 mb-2 flex items-center gap-2">
          <i class="fas fa-calendar-day text-indigo-500"></i> دورة مالية
        </label>
        <select id="accDelCycle" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-sm focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all outline-none">
          <option value="">— دورة —</option>
        </select>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-3 mb-2 px-1">
        <span class="text-xs font-semibold text-slate-600">معتمدون برصيد</span>
        <label class="flex items-center gap-2 text-xs font-medium text-slate-600 cursor-pointer select-none">
          <input type="checkbox" id="accDelSelectAll" class="acc-del-select-all h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" checked>
          <span>تحديد الكل</span>
        </label>
      </div>
      <div id="accDelList" class="space-y-2 rounded-2xl border border-slate-200 bg-white p-3 shadow-sm"></div>
    </div>

    <div class="px-4 sm:px-6 py-4 border-t border-slate-100 bg-white sm:bg-slate-50/50 flex flex-col-reverse sm:flex-row justify-end gap-3 shrink-0">
      <button type="button" onclick="accCloseDelivery()" class="w-full sm:w-auto px-6 py-3 sm:py-2.5 rounded-xl border border-slate-300 text-slate-700 font-bold hover:bg-slate-100 transition-colors text-sm flex items-center justify-center gap-2">إلغاء</button>
      <button type="button" onclick="accSubmitDelivery()" class="w-full sm:flex-1 px-8 py-3 sm:py-2.5 rounded-xl bg-emerald-600 text-white font-bold shadow-md shadow-emerald-200 hover:bg-emerald-700 hover:shadow-lg hover:-translate-y-0.5 transition-all text-sm flex items-center justify-center gap-2"><i class="fas fa-check"></i> تسليم</button>
    </div>
  </div>
</div>

<!-- تأكيد بنمط النظام (فوق نافذة رفع الأرصدة z-[10050]) -->
<div id="accConfirmModal" class="fixed inset-0 z-[10060] hidden items-center justify-center p-4 sm:p-6 max-lg:p-2 bg-slate-900/60 backdrop-blur-sm" dir="rtl" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="accConfirmTitle">
  <div class="bg-white rounded-2xl border border-slate-200/80 shadow-2xl max-w-md w-full p-5 sm:p-6 max-lg:my-auto">
    <div class="flex items-start gap-3 mb-5">
      <span id="accConfirmIcon" class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 border border-indigo-100">
        <i class="fas fa-circle-question text-lg" aria-hidden="true"></i>
      </span>
      <div class="min-w-0 flex-1">
        <h4 id="accConfirmTitle" class="text-lg font-bold text-slate-900 leading-snug">تأكيد</h4>
        <p id="accConfirmMessage" class="text-sm text-slate-600 mt-2 leading-relaxed whitespace-pre-wrap"></p>
      </div>
    </div>
    <div class="flex flex-col-reverse sm:flex-row gap-2 sm:justify-end sm:gap-3">
      <button type="button" id="accConfirmCancel" class="w-full sm:w-auto px-5 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 font-bold hover:bg-slate-50 transition-colors text-sm">لا</button>
      <button type="button" id="accConfirmOk" class="w-full sm:w-auto px-6 py-3 rounded-xl font-bold text-sm text-white shadow-md transition-colors bg-emerald-600 hover:bg-emerald-700 shadow-emerald-200/50">نعم</button>
    </div>
  </div>
</div>

<div id="accAddModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 max-lg:p-2 max-lg:items-stretch max-lg:justify-start bg-slate-900/50 backdrop-blur-[2px]" dir="rtl">
  <div class="bg-white rounded-2xl border border-slate-100 shadow-xl p-6 max-w-md w-full max-lg:max-h-full max-lg:flex max-lg:flex-col">
    <div class="flex items-start gap-3 mb-5">
      <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-600 border border-slate-100">
        <i class="fas fa-user-plus"></i>
      </span>
      <div>
        <h4 class="text-lg font-bold text-slate-900">معتمد جديد</h4>
        <p class="text-xs text-slate-500 mt-0.5">أدخل الاسم والكود اختيارياً</p>
      </div>
    </div>
    <form id="accAddForm" class="space-y-3">
      <div>
        <label class="block text-xs font-semibold text-slate-600 mb-1.5">الاسم</label>
        <input type="text" id="accName" placeholder="الاسم" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-800 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" required>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-600 mb-1.5">الكود</label>
        <input type="text" id="accCode" placeholder="الكود" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-800 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400">
      </div>
      <div class="flex flex-col-reverse sm:flex-row gap-2 pt-2">
        <button type="button" onclick="accCloseAdd()" class="w-full sm:w-auto px-5 py-3 rounded-xl border border-slate-200 bg-white text-slate-700 font-semibold hover:bg-slate-50">إلغاء</button>
        <button type="submit" class="w-full sm:flex-1 py-3 rounded-xl bg-indigo-600 text-white font-bold shadow-sm hover:bg-indigo-700">حفظ</button>
      </div>
    </form>
  </div>
</div>
