<div class="max-w-6xl" dir="rtl">
  <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
    <h2 class="text-2xl font-bold text-slate-800">الاعتمادات</h2>
    <div class="flex flex-wrap gap-2">
      <button type="button" onclick="accOpenBulk()" class="px-4 py-2.5 rounded-xl bg-slate-700 text-white text-sm font-semibold">رفع أرصدة</button>
      <button type="button" onclick="accOpenDelivery()" class="px-4 py-2.5 rounded-xl bg-teal-600 text-white text-sm font-semibold">تسليم</button>
      <button type="button" onclick="accOpenAdd()" class="px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700">
        <i class="fas fa-plus ml-2"></i> إضافة معتمد
      </button>
    </div>
  </div>
  <div id="accCards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <p class="text-slate-400 col-span-full text-center py-12">جاري التحميل...</p>
  </div>
</div>

<div id="accBulkModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50 overflow-y-auto">
  <div class="bg-white rounded-2xl p-6 max-w-lg w-full my-8">
    <h4 class="font-bold mb-3">إضافة أرصدة (دفعة)</h4>
    <p class="text-xs text-slate-500 mb-4">أعمدة الملف: A كود، B اسم، C رصيد، D معتمد رئيسي</p>
    <select id="accBulkCycle" class="w-full mb-4 px-3 py-2 rounded-lg border border-slate-200 text-sm"><option value="">— دورة مالية —</option></select>

    <div class="space-y-4 border-t border-slate-100 pt-4">
      <p class="text-sm font-semibold text-slate-700">1) ملف من الجهاز</p>
      <input type="file" id="accBulkFile" accept=".csv,.xlsx,.xls" class="w-full text-sm">
      <button type="button" onclick="accSubmitBulk()" class="w-full py-2 rounded-lg bg-indigo-600 text-white text-sm">رفع الملف</button>
    </div>

    <div class="space-y-2 border-t border-slate-100 pt-4 mt-4">
      <p class="text-sm font-semibold text-slate-700">2) لصق CSV / نص</p>
      <textarea id="accBulkPaste" rows="5" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-xs font-mono" placeholder="الصق الصفوف من Excel أو CSV…"></textarea>
      <button type="button" onclick="accSubmitBulkText()" class="w-full py-2 rounded-lg bg-slate-100 text-slate-800 text-sm font-medium">استيراد من النص</button>
    </div>

    <div class="space-y-2 border-t border-slate-100 pt-4 mt-4">
      <p class="text-sm font-semibold text-slate-700">3) رابط Google Sheet</p>
      <p class="text-xs text-amber-800 bg-amber-50 border border-amber-100 rounded-lg p-2">يتطلب ربط Google من إعدادات الجداول (Sheet).</p>
      <input type="url" id="accBulkSheetUrl" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" placeholder="https://docs.google.com/spreadsheets/d/...">
      <input type="text" id="accBulkSheetName" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" placeholder="اسم الورقة (اختياري)">
      <button type="button" onclick="accSubmitBulkSheetUrl()" class="w-full py-2 rounded-lg bg-emerald-600 text-white text-sm">جلب من الرابط</button>
    </div>

    <div class="flex gap-2 mt-6 pt-2 border-t border-slate-100">
      <button type="button" onclick="accCloseBulk()" class="flex-1 py-2 rounded-lg bg-slate-100">إغلاق</button>
    </div>
  </div>
</div>
<div id="accDeliveryModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl p-6 max-w-md w-full max-h-[85vh] overflow-y-auto">
    <h4 class="font-bold mb-3">تسليم معتمدين</h4>
    <select id="accDelCycle" class="w-full mb-2 px-3 py-2 rounded-lg border border-slate-200 text-sm"><option value="">— دورة —</option></select>
    <div id="accDelList" class="text-sm space-y-2 mb-3 max-h-48 overflow-y-auto"></div>
    <div class="flex gap-2">
      <button type="button" onclick="accSubmitDelivery()" class="flex-1 py-2 rounded-lg bg-teal-600 text-white text-sm">تسليم</button>
      <button type="button" onclick="accCloseDelivery()" class="px-4 py-2 rounded-lg bg-slate-100">إلغاء</button>
    </div>
  </div>
</div>

<div id="accAddModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl p-6 max-w-md w-full">
    <h4 class="font-bold mb-4">معتمد جديد</h4>
    <form id="accAddForm" class="space-y-3">
      <input type="text" id="accName" placeholder="الاسم" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
      <input type="text" id="accCode" placeholder="الكود" class="w-full px-4 py-2.5 rounded-xl border border-slate-200">
      <div class="flex gap-2">
        <button type="submit" class="flex-1 py-3 rounded-xl bg-indigo-600 text-white font-semibold">حفظ</button>
        <button type="button" onclick="accCloseAdd()" class="px-4 py-3 rounded-xl bg-slate-100">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<div id="accDetailModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h4 id="accDetailTitle" class="text-lg font-bold"></h4>
        <p id="accDetailBal" class="text-indigo-600 font-semibold mt-1"></p>
      </div>
      <button type="button" onclick="accCloseDetail()" class="text-slate-400"><i class="fas fa-times text-xl"></i></button>
    </div>
    <div class="flex gap-2 mb-4">
      <button type="button" onclick="accShowAddAmount()" class="flex-1 py-2 rounded-xl bg-emerald-600 text-white text-sm font-semibold">إضافة مبلغ</button>
      <button type="button" onclick="accShowTransfer()" class="flex-1 py-2 rounded-xl bg-slate-700 text-white text-sm font-semibold">تحويل</button>
      <button type="button" id="accPinBtn" onclick="accTogglePin()" class="py-2 px-3 rounded-xl bg-amber-100 text-amber-800 text-sm">تثبيت</button>
    </div>
    <div id="accAddAmountPanel" class="hidden space-y-2 mb-4 p-4 rounded-xl bg-slate-50">
      <select id="accSalaryDir" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm">
        <option value="to_us">راتب لنا</option>
        <option value="to_them">راتب علينا</option>
      </select>
      <input type="number" id="accAmt" step="0.01" placeholder="المبلغ" class="w-full px-3 py-2 rounded-lg border border-slate-200">
      <input type="number" id="accBroker" step="0.1" placeholder="نسبة الوساطة %" class="w-full px-3 py-2 rounded-lg border border-slate-200">
      <select id="accCycle" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm"><option value="">— دورة مالية —</option></select>
      <button type="button" onclick="accSubmitAmount()" class="w-full py-2 rounded-lg bg-indigo-600 text-white text-sm">تسجيل</button>
    </div>
    <div id="accTransferPanel" class="hidden space-y-2 mb-4 p-4 rounded-xl bg-slate-50">
      <select id="accTfType" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="accTfTypeChange()">
        <option value="manual">تسليم يدوي</option>
        <option value="fund">تحويل صندوق</option>
        <option value="company">تحويل (شركة)</option>
        <option value="shipping">شحن</option>
      </select>
      <input type="number" id="accTfAmt" step="0.01" placeholder="المبلغ" class="w-full px-3 py-2 rounded-lg border border-slate-200">
      <select id="accTfFund" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm hidden"></select>
      <select id="accTfCompany" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm hidden"></select>
      <p id="accTfShipHint" class="text-xs text-slate-500 hidden">سجّل عملية الشحن من قسم الشحن ثم اربطها لاحقاً إن لزم.</p>
      <button type="button" onclick="accSubmitTransfer()" class="w-full py-2 rounded-lg bg-indigo-600 text-white text-sm">تنفيذ</button>
    </div>
    <h5 class="font-bold text-slate-800 mb-2">السجل</h5>
    <div id="accLedger" class="text-sm space-y-2 max-h-48 overflow-y-auto"></div>
  </div>
</div>
