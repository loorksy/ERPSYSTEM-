<div class="member-adjustments-page w-full max-w-6xl mx-auto min-w-0 px-3 pb-8 sm:px-6 lg:px-8" dir="rtl">
  <header class="mb-4 pt-1 sm:mb-5">
    <div class="flex flex-wrap items-start gap-3">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-sm">
        <i class="fas fa-balance-scale text-lg" aria-hidden="true"></i>
      </div>
      <div class="min-w-0 flex-1">
        <h1 class="text-xl font-bold leading-tight text-slate-900 sm:text-2xl">إضافات وخصومات ومكافآت</h1>
        <p class="mt-1 max-w-2xl text-sm leading-relaxed text-slate-500">سجّل خصماً أو إضافة أو مكافأة لرقم مستخدم. يُستحسن اختيار دورة مالية عند ربط التحديث بجدول Google.</p>
      </div>
    </div>
  </header>

  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <!-- بيانات العملية -->
    <section class="px-4 py-5 sm:px-6 sm:py-6">
      <h2 class="mb-4 flex items-center gap-2 text-sm font-bold text-slate-800">
        <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-slate-100 text-xs font-bold text-slate-600">١</span>
        بيانات العملية
      </h2>
      <div class="flex flex-col gap-4 sm:gap-5">
        <div>
          <label for="maMemberId" class="mb-1.5 block text-xs font-semibold text-slate-600">رقم المستخدم</label>
          <div class="flex gap-2">
            <input type="text" id="maMemberId" inputmode="numeric" autocomplete="off" placeholder="مثال: 12345"
              class="h-11 min-w-0 flex-1 rounded-xl border border-slate-200 bg-white px-3 text-sm tabular-nums shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
            <button type="button" id="maPasteBtn"
              class="h-11 shrink-0 rounded-xl border border-slate-200 bg-slate-50 px-4 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 active:scale-[0.99]">لصق</button>
          </div>
        </div>

        <div>
          <span class="mb-1.5 block text-xs font-semibold text-slate-600" id="maKindLabel">نوع العملية</span>
          <select id="maKind" class="sr-only" aria-labelledby="maKindLabel">
            <option value="deduct">خصم</option>
            <option value="add">إضافة</option>
            <option value="reward">مكافأة</option>
          </select>
          <div id="maKindPills" class="grid grid-cols-3 gap-2" role="group" aria-label="نوع العملية">
            <button type="button" data-ma-kind="deduct" class="ma-kind-btn flex min-h-[2.75rem] flex-col items-center justify-center gap-0.5 rounded-xl border-2 border-transparent bg-slate-100 px-2 py-2 text-center text-xs font-bold text-slate-600 transition hover:bg-slate-200/80 sm:text-sm">
              <i class="fas fa-minus-circle text-sm text-red-500" aria-hidden="true"></i>
              خصم
            </button>
            <button type="button" data-ma-kind="add" class="ma-kind-btn flex min-h-[2.75rem] flex-col items-center justify-center gap-0.5 rounded-xl border-2 border-transparent bg-slate-100 px-2 py-2 text-center text-xs font-bold text-slate-600 transition hover:bg-slate-200/80 sm:text-sm">
              <i class="fas fa-plus-circle text-sm text-emerald-600" aria-hidden="true"></i>
              إضافة
            </button>
            <button type="button" data-ma-kind="reward" class="ma-kind-btn flex min-h-[2.75rem] flex-col items-center justify-center gap-0.5 rounded-xl border-2 border-transparent bg-slate-100 px-2 py-2 text-center text-xs font-bold text-slate-600 transition hover:bg-slate-200/80 sm:text-sm">
              <i class="fas fa-gift text-sm text-amber-600" aria-hidden="true"></i>
              مكافأة
            </button>
          </div>
        </div>

        <div>
          <label for="maAmount" class="mb-1.5 block text-xs font-semibold text-slate-600">المبلغ (USD)</label>
          <input type="number" id="maAmount" min="0" step="0.01" placeholder="0.00" dir="ltr"
            class="h-11 w-full max-w-xs rounded-xl border border-slate-200 bg-white px-3 text-base font-semibold tabular-nums shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
        </div>
      </div>
    </section>

    <!-- الدورة و Google -->
    <section class="border-t border-slate-100 bg-slate-50/70 px-4 py-5 sm:px-6 sm:py-6">
      <h2 class="mb-4 flex items-center gap-2 text-sm font-bold text-slate-800">
        <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-white text-xs font-bold text-slate-600 shadow-sm ring-1 ring-slate-200/80">٢</span>
        الدورة المالية والربط مع Google
      </h2>
      <div class="flex flex-col gap-4">
        <div>
          <label for="maCycleId" class="mb-1.5 block text-xs font-semibold text-slate-600">دورة مالية <span class="font-normal text-slate-400">(مُستحسَن لتحديث Google)</span></label>
          <select id="maCycleId"
            class="h-11 w-full max-w-xl rounded-xl border border-slate-200 bg-white px-3 text-sm shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
            <option value="">— اختر الدورة —</option>
          </select>
        </div>

        <div class="rounded-xl border border-slate-200/80 bg-white p-3 sm:p-4">
          <label class="flex cursor-pointer items-start gap-3">
            <input type="checkbox" id="maSyncSheet" class="mt-0.5 h-4 w-4 shrink-0 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" checked>
            <span class="text-sm leading-relaxed text-slate-700">تحديث عمود الراتب في جدول <strong class="font-semibold text-slate-900">معلومات المستخدمين</strong> (Google Sheet)</span>
          </label>
          <div class="mt-4 grid max-w-md grid-cols-2 gap-3 sm:gap-4">
            <div>
              <label for="maUiUidCol" class="mb-1 block text-[0.65rem] font-semibold uppercase tracking-wide text-slate-500">عمود رقم المستخدم</label>
              <input type="text" id="maUiUidCol" value="C" maxlength="3" dir="ltr"
                class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50/50 px-2 text-center text-sm font-bold uppercase tabular-nums tracking-wider focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
            </div>
            <div>
              <label for="maUiSalCol" class="mb-1 block text-[0.65rem] font-semibold uppercase tracking-wide text-slate-500">عمود الراتب</label>
              <input type="text" id="maUiSalCol" value="L" maxlength="3" dir="ltr"
                class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50/50 px-2 text-center text-sm font-bold uppercase tabular-nums tracking-wider focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ملاحظات وتسجيل -->
    <section class="border-t border-slate-100 px-4 py-5 sm:px-6 sm:py-6">
      <h2 class="mb-4 flex items-center gap-2 text-sm font-bold text-slate-800">
        <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-slate-100 text-xs font-bold text-slate-600">٣</span>
        ملاحظات وتأكيد
      </h2>
      <label for="maNotes" class="mb-1.5 block text-xs font-semibold text-slate-600">ملاحظات <span class="font-normal text-slate-400">(اختياري)</span></label>
      <textarea id="maNotes" rows="3" placeholder="تفاصيل إضافية للسجل المحاسبي…"
        class="w-full resize-y rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm leading-relaxed shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 min-h-[5rem]"></textarea>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
        <button type="button" id="maSubmitBtn"
          class="inline-flex h-12 min-w-[10rem] items-center justify-center rounded-xl bg-indigo-600 px-8 text-sm font-bold text-white shadow-sm transition hover:bg-indigo-700 active:scale-[0.99] sm:min-w-[12rem]">
          تسجيل العملية
        </button>
        <p id="maMsg" class="min-h-[1.25rem] flex-1 text-center text-sm text-slate-500 sm:text-end" role="status" aria-live="polite"></p>
      </div>
    </section>
  </div>
</div>
