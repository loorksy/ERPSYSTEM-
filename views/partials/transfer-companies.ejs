<div class="tc-page w-full max-w-6xl mx-auto min-w-0 px-4 sm:px-0 pb-10" dir="rtl">
  <div class="mb-6 erp-toolbar-actions erp-toolbar-actions--2">
    <button type="button" onclick="tcOpenAdd()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-gradient-to-br from-violet-600 to-violet-500 text-white text-[11px] leading-snug sm:text-sm font-semibold shadow-md shadow-violet-500/25 hover:brightness-105 active:scale-[0.99] transition touch-manipulation">
      <i class="fas fa-plus text-[10px] sm:text-sm shrink-0 opacity-95" aria-hidden="true"></i>
      <span class="text-center">إضافة شركة</span>
    </button>
  </div>

  <div class="mb-4 flex min-w-0 flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between sm:gap-3">
    <div class="relative w-full min-w-0 sm:max-w-md sm:shrink-0">
      <i class="fas fa-search pointer-events-none absolute right-3 top-1/2 z-[1] -translate-y-1/2 text-sm text-slate-400" aria-hidden="true"></i>
      <input
        type="search"
        id="tcCardsSearch"
        autocomplete="off"
        class="h-11 w-full rounded-xl border border-slate-200 bg-white py-2 pl-4 pr-10 text-sm text-slate-800 shadow-sm placeholder:text-slate-400 focus:border-violet-400 focus:outline-none focus:ring-2 focus:ring-violet-500/20 sm:h-auto sm:py-2.5"
        placeholder="بحث بالاسم أو الدولة…"
        aria-label="بحث في شركات التحويل"
      />
    </div>
    <p class="text-[11px] leading-relaxed text-slate-500 sm:max-w-xs">
      <i class="fas fa-arrows-alt ml-1 text-slate-400" aria-hidden="true"></i>
      اسحب من المقبض لترتيب البطاقات — يُحفظ الترتيب في هذا المتصفح.
    </p>
  </div>

  <div id="tcCards" class="agencies-grid">
    <div class="col-span-full acc-approvals-empty flex flex-col items-center gap-2 py-12 text-center text-slate-400">
      <i class="fas fa-spinner fa-spin text-3xl text-violet-400" aria-hidden="true"></i>
      <span class="text-sm font-medium">جاري التحميل...</span>
    </div>
  </div>
</div>

<!-- إضافة شركة -->
<div id="tcAddModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-sm" dir="rtl" onclick="if(event.target===this)tcCloseAdd()">
  <div class="tc-modal-shell relative flex max-h-[min(92vh,760px)] w-full max-w-lg flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl shadow-slate-900/15 ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
    <div class="flex shrink-0 items-center gap-3 border-b border-violet-100 bg-gradient-to-l from-violet-50/90 to-white px-5 py-4">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-violet-600 text-white shadow-md shadow-violet-600/25">
        <i class="fas fa-money-bill-wave" aria-hidden="true"></i>
      </div>
      <div class="min-w-0 flex-1">
        <h4 class="text-lg font-bold text-slate-900">إضافة شركة تحويل</h4>
        <p class="mt-0.5 text-xs text-slate-500">البيانات الأساسية وأنواع التحويل المدعومة</p>
      </div>
      <button type="button" onclick="tcCloseAdd()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 transition hover:bg-slate-100 hover:text-slate-600" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
    </div>
    <form id="tcAddForm" class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain p-5 sm:p-6">
      <div>
        <label class="text-sm font-semibold text-slate-700">اسم الشركة</label>
        <input type="text" id="tcName" class="mt-1 w-full rounded-xl border border-slate-200 px-4 py-2.5 focus:border-violet-400 focus:outline-none focus:ring-2 focus:ring-violet-500/20" required>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">الدولة</label>
        <select id="tcCountry" class="mt-1 w-full rounded-xl border border-slate-200 px-4 py-2.5 focus:border-violet-400 focus:outline-none focus:ring-2 focus:ring-violet-500/20"></select>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">الرصيد (موجب لنا / سالب علينا)</label>
        <div class="mt-1 flex gap-2">
          <input type="number" id="tcBal" step="0.01" class="flex-1 rounded-xl border border-slate-200 px-4 py-2.5 focus:border-violet-400 focus:outline-none focus:ring-2 focus:ring-violet-500/20" value="0">
          <select id="tcBalCur" class="w-28 rounded-xl border border-slate-200 px-2 focus:border-violet-400 focus:outline-none focus:ring-2 focus:ring-violet-500/20"><option value="USD">USD</option><option value="TRY">TRY</option><option value="SYP">SYP</option></select>
        </div>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">أنواع التحويل (اختر عدة)</label>
        <div id="tcTypesWrap" class="mt-2 flex flex-wrap gap-2"></div>
      </div>
      <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
        <button type="button" onclick="tcCloseAdd()" class="w-full rounded-xl border border-slate-200 bg-white px-5 py-3 font-semibold text-slate-700 hover:bg-slate-50 sm:w-auto">إلغاء</button>
        <button type="submit" class="w-full rounded-xl bg-violet-600 px-6 py-3 font-bold text-white shadow-md hover:bg-violet-700 sm:w-auto">حفظ</button>
      </div>
    </form>
  </div>
</div>
<script>
  window.FUNDS_COUNTRIES = ['سوريا','تركيا','مصر','العراق','الجزائر','الأردن','المغرب','فلسطين','لبنان','السعودية','الإمارات','الكويت','قطر','البحرين','عُمان','اليمن','السودان','تونس','ليبيا','موريتانيا'];
</script>
