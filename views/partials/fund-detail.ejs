<div id="fundDetailPage" data-fund-id="<%= fundId %>" class="fund-detail-page funds-detail-page w-full max-w-6xl mx-auto min-w-0 px-3 sm:px-6 lg:px-8 pb-8" dir="rtl">
  <div class="space-y-4">
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <!-- صف 1: رجوع | هوية | PDF -->
      <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-3 border-b border-slate-100 bg-slate-50/50 px-3 py-3 sm:px-4">
        <a href="/funds" class="btn-back inline-flex shrink-0" title="العودة لقائمة الصناديق" aria-label="العودة لقائمة الصناديق">
          <i class="fas fa-arrow-right text-sm"></i>
        </a>
        <div class="flex min-w-0 items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-600 text-white shadow-sm">
            <i class="fas fa-vault text-sm" aria-hidden="true"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-600">صندوق</p>
            <h1 id="fundDetailTitle" class="truncate text-base font-bold text-slate-900 sm:text-lg">—</h1>
          </div>
        </div>
        <button type="button" onclick="fundsDownloadLedgerPdf()" class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50" title="تنزيل سجل الحركات PDF">
          <i class="fas fa-file-pdf text-red-500 text-[0.8rem]" aria-hidden="true"></i>
          PDF
        </button>
      </div>

      <!-- صف 2: مؤشران — مثل ملف الوكالة الفرعية -->
      <div class="grid grid-cols-2 gap-px bg-slate-200">
        <div class="bg-white px-3 py-3 sm:px-4">
          <p class="text-[10px] font-medium uppercase tracking-wide text-slate-500">رقم الصندوق</p>
          <p id="fundDetailNumberDisplay" class="mt-1 text-sm font-bold tabular-nums text-slate-900 sm:text-base">—</p>
        </div>
        <div class="bg-white px-3 py-3 sm:px-4">
          <p class="text-[10px] font-medium uppercase tracking-wide text-slate-500">الموقع</p>
          <p id="fundDetailLocationDisplay" class="mt-1 text-sm font-semibold leading-snug text-slate-800 sm:text-base">—</p>
        </div>
      </div>

      <!-- صف 3: أرصدة + تنبيه + أزرار — عمود على الجوال، صف من lg -->
      <div class="border-b border-slate-100 px-3 py-2.5 sm:px-4">
        <div class="flex flex-col gap-3 lg:flex-row lg:flex-wrap lg:items-center lg:gap-3">
          <div class="flex w-full min-w-0 flex-col gap-2 lg:flex-1 lg:flex-row lg:flex-wrap lg:items-center lg:gap-2">
            <div id="fundDetailPayables" class="hidden w-full rounded-lg border border-red-100 bg-red-50/90 px-2.5 py-1.5 text-[11px] font-semibold leading-snug text-red-800 lg:w-auto lg:max-w-md"></div>
            <div id="fundDetailBalances" class="flex flex-wrap gap-1.5"></div>
          </div>
          <div class="grid min-w-0 flex-1 grid-cols-2 gap-2 sm:flex sm:flex-wrap sm:items-center sm:gap-2 lg:max-w-none lg:flex-none lg:justify-end">
            <button type="button" onclick="fundsSetMain()" class="inline-flex min-h-[2.35rem] w-full items-center justify-center gap-1.5 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-900 transition hover:bg-amber-100 sm:w-auto sm:min-w-[7.5rem]">
              <i class="fas fa-star text-[0.7rem]" aria-hidden="true"></i>
              رئيسي
            </button>
          </div>
        </div>
      </div>

      <!-- ترحيل: عمود على الجوال، شبكة 12 على sm+ -->
      <div class="border-b border-slate-100 px-3 py-2.5 sm:px-4">
        <p class="mb-2 text-[10px] font-bold uppercase tracking-wide text-slate-500">ترحيل إلى صندوق آخر</p>
        <div class="mb-3 grid grid-cols-1 gap-2 sm:grid-cols-12 sm:items-end sm:gap-x-3 sm:gap-y-2">
          <div class="sm:col-span-5 lg:col-span-4">
            <label for="fundTransferTo" class="mb-1 block text-xs font-medium text-slate-600">صندوق المقصد</label>
            <select id="fundTransferTo" class="h-9 w-full rounded-lg border border-slate-200 bg-white px-2.5 text-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"></select>
          </div>
          <div class="sm:col-span-3 lg:col-span-2">
            <label for="fundTransferAmt" class="mb-1 block text-xs font-medium text-slate-600">مبلغ (USD)</label>
            <input type="number" id="fundTransferAmt" step="0.01" placeholder="0.00" dir="ltr" class="h-9 w-full rounded-lg border border-slate-200 px-2.5 text-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
          </div>
          <div class="sm:col-span-4 lg:col-span-3">
            <label class="mb-1 hidden text-xs font-medium text-slate-600 sm:block sm:invisible" aria-hidden="true">تنفيذ</label>
            <button type="button" onclick="fundsDoTransfer()" class="h-9 w-full rounded-lg bg-indigo-600 px-4 text-xs font-bold text-white shadow-sm transition hover:bg-indigo-700">ترحيل</button>
          </div>
        </div>
      </div>

      <!-- مرتجع -->
      <div class="border-b border-slate-100 bg-emerald-50/30 px-3 py-2.5 sm:px-4">
        <p class="mb-2 text-[10px] font-bold uppercase tracking-wide text-emerald-800">تسجيل مرتجع</p>
        <div class="mb-2 grid grid-cols-1 gap-2 sm:grid-cols-12 sm:items-end sm:gap-x-3 sm:gap-y-2">
          <div class="sm:col-span-3 lg:col-span-2">
            <label for="fundReturnAmt" class="mb-1 block text-xs font-medium text-slate-600">المبلغ</label>
            <input type="number" id="fundReturnAmt" step="0.01" min="0" placeholder="0.00" dir="ltr" class="h-9 w-full rounded-lg border border-slate-200 bg-white px-2.5 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
          </div>
          <div class="sm:col-span-3 lg:col-span-2">
            <label for="fundReturnCur" class="mb-1 block text-xs font-medium text-slate-600">العملة</label>
            <select id="fundReturnCur" class="h-9 w-full rounded-lg border border-slate-200 bg-white px-2.5 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
              <option value="USD">USD</option>
              <option value="TRY">TRY</option>
              <option value="SYP">SYP</option>
            </select>
          </div>
          <div class="sm:col-span-6 lg:col-span-4">
            <label for="fundReturnDisposition" class="mb-1 block text-xs font-medium text-slate-600">التصرف</label>
            <select id="fundReturnDisposition" class="h-9 w-full rounded-lg border border-slate-200 bg-white px-2.5 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
              <option value="remain_at_entity">يبقى بالصندوق</option>
              <option value="transfer_to_fund">ترحيل لصندوق آخر</option>
            </select>
          </div>
          <div id="fundReturnTargetWrap" class="hidden sm:col-span-12">
            <label for="fundReturnTarget" class="mb-1 block text-xs font-medium text-slate-600">صندوق المقصد</label>
            <select id="fundReturnTarget" class="h-9 w-full rounded-lg border border-slate-200 bg-white px-2.5 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"></select>
          </div>
        </div>
        <input type="text" id="fundReturnNotes" class="mb-2 h-9 w-full rounded-lg border border-slate-200 bg-white px-2.5 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" placeholder="ملاحظات (اختياري)">
        <button type="button" onclick="fundsSubmitReturn()" class="inline-flex h-9 w-full items-center justify-center rounded-lg bg-emerald-600 px-4 text-xs font-bold text-white shadow-sm transition hover:bg-emerald-700 sm:w-auto">تسجيل المرتجع</button>
      </div>
    </section>

    <!-- سجل الحركات — قسم مستقل مثل سجل الوكالة -->
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-3 py-2.5 sm:px-4">
        <h2 class="text-sm font-bold text-slate-900">سجل الحركات</h2>
        <p class="text-[10px] text-slate-500">المبالغ والرصيد بعد كل حركة</p>
      </div>
      <div id="fundDetailLedger" class="fund-detail-ledger mx-3 mb-3 max-h-[min(22rem,48vh)] overflow-y-auto rounded-lg border border-slate-100 bg-slate-50/60 p-3 text-sm sm:mx-4 sm:mb-4 sm:max-h-[min(26rem,52vh)] sm:p-4"></div>
    </section>
  </div>
</div>
