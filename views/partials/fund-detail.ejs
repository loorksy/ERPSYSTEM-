<div id="fundDetailPage" data-fund-id="<%= fundId %>" class="fund-detail-page funds-detail-page fund-profile w-full max-w-6xl mx-auto min-w-0 px-3 pb-8 sm:px-6 lg:px-8" dir="rtl">
  <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
    <div class="grid grid-cols-[auto_minmax(0,1fr)] items-center gap-3 border-b border-slate-100 bg-slate-50/50 px-3 py-3 sm:px-4">
      <a href="/funds" class="btn-back inline-flex shrink-0" title="العودة لقائمة الصناديق" aria-label="العودة لقائمة الصناديق">
        <i class="fas fa-arrow-right text-sm"></i>
      </a>
      <div class="flex min-w-0 items-center gap-3">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gradient-to-br from-indigo-600 to-sky-600 text-white shadow-sm">
          <i class="fas fa-vault text-sm" aria-hidden="true"></i>
        </div>
        <div class="min-w-0">
          <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-600">صندوق</p>
          <h1 id="fundDetailTitle" class="truncate text-base font-bold text-slate-900 sm:text-lg">جاري التحميل…</h1>
        </div>
      </div>
    </div>

    <div class="border-b border-slate-100 bg-white px-3 py-3 sm:px-4">
      <p class="mb-2 text-[11px] font-semibold text-slate-500 sm:hidden">إجراءات سريعة</p>
      <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 sm:gap-2 lg:max-w-4xl lg:ms-auto">
        <button type="button" onclick="fundsOpenTransferModal()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center gap-1.5 rounded-xl bg-indigo-600 px-2 py-2 text-[11px] font-bold text-white shadow-md shadow-indigo-600/25 transition hover:bg-indigo-700 active:scale-[0.99] sm:min-h-[2.35rem] sm:text-xs">
          <i class="fas fa-right-left shrink-0 text-[0.75rem]" aria-hidden="true"></i>
          <span class="text-center leading-tight">ترحيل</span>
        </button>
        <button type="button" onclick="fundsOpenReturnModal()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center gap-1.5 rounded-xl bg-emerald-600 px-2 py-2 text-[11px] font-bold text-white shadow-md shadow-emerald-600/20 transition hover:bg-emerald-700 active:scale-[0.99] sm:min-h-[2.35rem] sm:text-xs">
          <i class="fas fa-rotate-left shrink-0 text-[0.75rem]" aria-hidden="true"></i>
          <span class="text-center leading-tight">مرتجع</span>
        </button>
        <button type="button" onclick="fundsDownloadLedgerPdf()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center gap-1.5 rounded-xl border border-slate-200 bg-white px-2 py-2 text-[11px] font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 active:scale-[0.99] sm:min-h-[2.35rem] sm:text-xs">
          <i class="fas fa-file-pdf text-red-500 shrink-0" aria-hidden="true"></i>
          <span>PDF</span>
        </button>
        <button type="button" onclick="fundsReloadDetail()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center gap-1.5 rounded-xl border border-indigo-200 bg-indigo-50 px-2 py-2 text-[11px] font-semibold text-indigo-900 shadow-sm transition hover:bg-indigo-100 active:scale-[0.99] sm:min-h-[2.35rem] sm:text-xs">
          <i class="fas fa-rotate shrink-0" aria-hidden="true"></i>
          <span>تحديث</span>
        </button>
      </div>
    </div>

    <div class="space-y-4 p-3 sm:p-4">
      <div id="fundDetailMetricsRow" class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:items-stretch sm:gap-4">
        <div id="fundDetailBalanceShell" class="relative overflow-hidden rounded-2xl border border-indigo-200/70 bg-gradient-to-br from-indigo-50 via-white to-slate-50/90 px-4 py-4 shadow-sm ring-1 ring-indigo-900/[0.04] sm:px-5 sm:py-5">
          <span class="pointer-events-none absolute -left-8 -top-8 h-24 w-24 rounded-full bg-indigo-400/10 blur-2xl" aria-hidden="true"></span>
          <div class="relative flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-semibold text-slate-600">رصيد الصندوق</p>
              <p class="mt-0.5 text-[10px] text-slate-500">حسب العملة</p>
            </div>
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-indigo-100 text-indigo-600 sm:h-10 sm:w-10" aria-hidden="true"><i class="fas fa-wallet text-sm"></i></span>
          </div>
          <div id="fundDetailBalancesSection" class="relative mt-3">
            <div id="fundDetailBalances" role="list" class="flex flex-col gap-0"></div>
          </div>
        </div>

        <div id="fundDetailPayablesShell" class="hidden relative overflow-hidden rounded-2xl border border-rose-200/80 bg-gradient-to-br from-rose-50/95 via-white to-slate-50/90 px-4 py-4 shadow-sm ring-1 ring-rose-900/[0.06] sm:px-5 sm:py-5">
          <span class="pointer-events-none absolute -right-6 -top-6 h-20 w-20 rounded-full bg-rose-400/15 blur-2xl" aria-hidden="true"></span>
          <div class="relative flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-semibold text-rose-900/90">دين علينا</p>
              <p class="mt-0.5 text-[10px] text-rose-600/85">التزام مسجّل تجاه الصندوق</p>
            </div>
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-rose-100 text-rose-600 sm:h-10 sm:w-10" aria-hidden="true"><i class="fas fa-scale-balanced text-sm"></i></span>
          </div>
          <p id="fundDetailPayables" class="relative mt-3 text-2xl font-bold tabular-nums text-rose-900 sm:text-3xl"></p>
        </div>
      </div>

      <div class="flex flex-col gap-3 rounded-xl border border-slate-200/90 bg-white px-3 py-3 sm:flex-row sm:items-start sm:justify-between sm:gap-6 sm:px-4 sm:py-3.5">
        <div class="min-w-0 flex-1">
          <p class="text-[10px] font-medium uppercase tracking-wide text-slate-500">رقم الصندوق</p>
          <p id="fundDetailNumberDisplay" class="mt-0.5 text-base font-bold tabular-nums text-slate-900 sm:text-lg">—</p>
        </div>
        <div class="min-w-0 flex-1 border-t border-slate-100 pt-3 sm:border-t-0 sm:border-s sm:border-slate-200 sm:pt-0 sm:ps-6">
          <p class="text-[10px] font-medium uppercase tracking-wide text-slate-500">الموقع</p>
          <p id="fundDetailLocationDisplay" class="mt-0.5 text-sm font-semibold leading-relaxed text-slate-800 sm:text-base">—</p>
        </div>
      </div>

      <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-100 bg-slate-50/50 px-3 py-2.5 sm:px-4">
          <h2 class="text-sm font-bold text-slate-900">سجل الحركات</h2>
          <p class="text-[10px] text-slate-500">المبالغ والرصيد بعد كل حركة — اضغط على سطر للتفاصيل أو إلغاء التحويل</p>
        </div>
        <div id="fundDetailLedger" class="fund-detail-ledger mx-3 mb-3 max-h-[min(22rem,48vh)] overflow-y-auto overscroll-contain rounded-xl border border-slate-100 bg-slate-50/60 p-3 text-sm [-webkit-overflow-scrolling:touch] sm:mx-4 sm:mb-4 sm:max-h-[min(26rem,52vh)] sm:p-4"></div>
      </section>
    </div>
  </section>

  <!-- ترحيل لصندوق -->
  <div id="fundTransferModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-sm" dir="rtl" onclick="if(event.target===this)fundsCloseTransferModal()">
    <div class="tc-modal-shell relative flex max-h-[min(88vh,640px)] w-full max-w-md flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
      <div class="flex shrink-0 items-center justify-between gap-3 border-b border-indigo-100 bg-gradient-to-l from-indigo-50/90 to-white px-4 py-3 sm:px-5">
        <div class="min-w-0">
          <h3 class="text-base font-bold text-slate-900">ترحيل لصندوق آخر</h3>
          <p class="text-[11px] text-slate-500">يُخصم من هذا الصندوق ويُضاف للمقصد</p>
        </div>
        <button type="button" onclick="fundsCloseTransferModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
      </div>
      <div class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain p-4 sm:p-5">
        <div>
          <label for="fundTransferTo" class="mb-1 block text-xs font-medium text-slate-600">الصندوق المقصد</label>
          <select id="fundTransferTo" class="input-select h-11 w-full max-w-full rounded-xl border-slate-200 py-2 text-sm"></select>
        </div>
        <div>
          <label for="fundTransferAmt" class="mb-1 block text-xs font-medium text-slate-600">المبلغ (USD)</label>
          <input type="number" id="fundTransferAmt" step="0.01" placeholder="0.00" dir="ltr" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm tabular-nums focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/20">
        </div>
        <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
          <button type="button" onclick="fundsCloseTransferModal()" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 hover:bg-slate-50 sm:w-auto">إلغاء</button>
          <button type="button" onclick="fundsDoTransfer()" class="h-11 w-full rounded-xl bg-indigo-600 px-5 text-sm font-bold text-white shadow-md hover:bg-indigo-700 sm:w-auto sm:min-w-[8rem]">ترحيل</button>
        </div>
      </div>
    </div>
  </div>

  <!-- مرتجع -->
  <div id="fundReturnModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-sm" dir="rtl" onclick="if(event.target===this)fundsCloseReturnModal()">
    <div class="tc-modal-shell relative flex max-h-[min(90vh,720px)] w-full max-w-md flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
      <div class="flex shrink-0 items-center justify-between gap-3 border-b border-emerald-100 bg-gradient-to-l from-emerald-50/90 to-white px-4 py-3 sm:px-5">
        <div class="min-w-0">
          <h3 class="text-base font-bold text-emerald-950">تسجيل مرتجع</h3>
          <p class="text-[11px] text-emerald-800/80">نقدي أو ترحيل لصندوق آخر</p>
        </div>
        <button type="button" onclick="fundsCloseReturnModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
      </div>
      <div class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain p-4 sm:p-5">
        <div class="grid grid-cols-2 gap-2">
          <div class="col-span-2 sm:col-span-1">
            <label for="fundReturnAmt" class="mb-1 block text-xs font-medium text-slate-600">المبلغ</label>
            <input type="number" id="fundReturnAmt" step="0.01" min="0" placeholder="0" dir="ltr" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15">
          </div>
          <div class="col-span-2 sm:col-span-1">
            <label for="fundReturnCur" class="mb-1 block text-xs font-medium text-slate-600">العملة</label>
            <select id="fundReturnCur" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15">
              <option value="USD">USD</option>
              <option value="TRY">TRY</option>
              <option value="SYP">SYP</option>
            </select>
          </div>
          <div class="col-span-2">
            <label for="fundReturnDisposition" class="mb-1 block text-xs font-medium text-slate-600">التصرف</label>
            <select id="fundReturnDisposition" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15">
              <option value="remain_at_entity">يبقى بالصندوق</option>
              <option value="transfer_to_fund">ترحيل لصندوق آخر</option>
            </select>
          </div>
          <div id="fundReturnTargetWrap" class="col-span-2 hidden">
            <label for="fundReturnTarget" class="mb-1 block text-xs font-medium text-slate-600">صندوق المقصد</label>
            <select id="fundReturnTarget" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15"></select>
          </div>
          <div class="col-span-2">
            <label for="fundReturnNotes" class="mb-1 block text-xs font-medium text-slate-600">ملاحظات <span class="font-normal text-slate-400">(اختياري)</span></label>
            <input type="text" id="fundReturnNotes" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15" placeholder="">
          </div>
        </div>
        <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
          <button type="button" onclick="fundsCloseReturnModal()" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 hover:bg-slate-50 sm:w-auto">إلغاء</button>
          <button type="button" onclick="fundsSubmitReturn()" class="h-11 w-full rounded-xl bg-emerald-600 px-5 text-sm font-bold text-white shadow-md hover:bg-emerald-700 sm:w-auto sm:min-w-[8rem]">تسجيل</button>
        </div>
      </div>
    </div>
  </div>

  <div id="fundLedgerMoveModal" class="fixed inset-0 z-[10060] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-sm" dir="rtl" onclick="if(event.target===this)fundsCloseLedgerModal()">
    <div class="relative w-full max-w-md overflow-hidden rounded-2xl border border-slate-200/90 bg-white p-6 shadow-2xl ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
      <h4 id="fundLedgerMoveModalTitle" class="mb-3 text-lg font-bold text-slate-900">تفاصيل الحركة</h4>
      <div id="fundLedgerMoveModalBody" class="mb-6 min-h-[4rem] space-y-2 text-sm text-slate-700"></div>
      <div class="flex flex-col-reverse gap-2 sm:flex-row">
        <button type="button" onclick="fundsCloseLedgerModal()" class="w-full rounded-xl bg-slate-100 py-3 font-semibold text-slate-800">إغلاق</button>
        <button type="button" id="fundLedgerMoveModalCancelBtn" onclick="fundsConfirmCancelLedger()" class="hidden w-full rounded-xl bg-red-600 py-3 font-semibold text-white">إلغاء التحويل</button>
      </div>
    </div>
  </div>
</div>
