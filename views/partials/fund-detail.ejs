<div id="fundDetailPage" data-fund-id="<%= fundId %>" class="fund-detail-page funds-detail-page fund-profile w-full max-w-6xl mx-auto min-w-0 px-3 pb-8 sm:px-6 lg:px-8" dir="rtl">
  <div class="flex flex-col gap-3 sm:gap-4">
    <!-- شريط علوي خفيف: رجوع + الاسم فقط (بدون تكدس مع الرصيد) -->
    <header class="flex min-h-[2.75rem] items-center gap-2 pt-1">
      <a href="/funds" class="btn-back inline-flex shrink-0" title="العودة لقائمة الصناديق" aria-label="العودة لقائمة الصناديق">
        <i class="fas fa-arrow-right text-sm"></i>
      </a>
      <div class="min-w-0 flex-1">
        <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-600">صندوق</p>
        <h1 id="fundDetailTitle" class="truncate text-lg font-bold leading-tight text-slate-900 sm:text-xl">—</h1>
      </div>
    </header>

    <!-- الرصيد: منطقة عرض واحدة، بصرياً منفصلة عن باقي الصفحة — أولوية للموبايل -->
    <div id="fundDetailBalanceShell" class="rounded-2xl border border-indigo-200/70 bg-gradient-to-br from-indigo-50 via-white to-slate-50/90 px-4 py-4 shadow-sm sm:px-5 sm:py-5">
      <div id="fundDetailBalancesSection">
        <p class="text-xs font-semibold text-slate-600">رصيد الصندوق</p>
        <div id="fundDetailBalances" role="list" class="mt-3 flex flex-col gap-0"></div>
      </div>
      <div id="fundDetailPayables" class="mt-3 hidden border-t border-red-200/60 pt-3 text-sm font-medium leading-snug text-red-800"></div>
    </div>

    <div class="sm:max-w-xs">
      <button type="button" onclick="fundsDownloadLedgerPdf()" class="inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white px-3 text-xs font-semibold text-slate-700 shadow-sm transition active:scale-[0.99] hover:bg-slate-50" title="تقرير PDF">
        <i class="fas fa-file-pdf text-red-500" aria-hidden="true"></i>
        PDF
      </button>
    </div>

    <!-- رقم وموقع: سطر بسيط دون شبكة ثقيلة -->
    <div class="flex flex-col gap-3 rounded-xl border border-slate-200/90 bg-white px-3 py-3 sm:flex-row sm:items-start sm:justify-between sm:gap-6 sm:px-4 sm:py-3.5">
      <div class="min-w-0 flex-1">
        <p class="text-[10px] font-medium uppercase tracking-wide text-slate-500">رقم الصندوق</p>
        <p id="fundDetailNumberDisplay" class="mt-0.5 text-base font-bold tabular-nums text-slate-900 sm:text-lg">—</p>
      </div>
      <div class="min-w-0 flex-1 border-t border-slate-100 pt-3 sm:border-t-0 sm:border-s sm:border-slate-200 sm:pt-0 sm:ps-6">
        <p class="text-[10px] font-medium uppercase tracking-wide text-slate-500">الموقع</p>
        <p id="fundDetailLocationDisplay" class="mt-0.5 text-sm font-semibold leading-relaxed text-slate-800 sm:text-base">—</p>
      </div>
    </div>

    <!-- العمليات: بطاقة واحدة، فصل بسيط بين ترحيل ومرتجع -->
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-3 py-3 sm:px-4">
        <h2 class="text-sm font-bold text-slate-900">ترحيل</h2>
        <p class="mt-0.5 text-[10px] text-slate-500">تحويل إلى صندوق آخر</p>
        <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end sm:gap-3">
          <div class="min-w-0 flex-1 sm:min-w-[14rem]">
            <label for="fundTransferTo" class="mb-1 block text-xs font-medium text-slate-600">الصندوق المقصد</label>
            <select id="fundTransferTo" class="input-select h-11 w-full max-w-full rounded-xl border-slate-200 py-2 text-sm"></select>
          </div>
          <div class="w-full sm:w-28">
            <label for="fundTransferAmt" class="mb-1 block text-xs font-medium text-slate-600">USD</label>
            <input type="number" id="fundTransferAmt" step="0.01" placeholder="0.00" dir="ltr" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm tabular-nums focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/20">
          </div>
          <button type="button" onclick="fundsDoTransfer()" class="h-11 w-full shrink-0 rounded-xl bg-indigo-600 px-4 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-700 sm:w-auto sm:min-w-[7rem]">ترحيل</button>
        </div>
      </div>

      <div class="bg-emerald-50/40 px-3 py-3 sm:px-4">
        <h2 class="text-sm font-bold text-emerald-900">مرتجع</h2>
        <p class="mt-0.5 text-[10px] text-emerald-800/80">تسجيل مرتجع نقدي أو ترحيله</p>
        <div class="mt-3 flex flex-col gap-3">
          <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 sm:gap-3">
            <div class="min-w-0 sm:col-span-1">
              <label for="fundReturnAmt" class="mb-1 block text-xs font-medium text-slate-600">المبلغ</label>
              <input type="number" id="fundReturnAmt" step="0.01" min="0" placeholder="0" dir="ltr" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15">
            </div>
            <div class="min-w-0 sm:col-span-1">
              <label for="fundReturnCur" class="mb-1 block text-xs font-medium text-slate-600">العملة</label>
              <select id="fundReturnCur" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15">
                <option value="USD">USD</option>
                <option value="TRY">TRY</option>
                <option value="SYP">SYP</option>
              </select>
            </div>
            <div class="col-span-2 min-w-0 sm:col-span-2">
              <label for="fundReturnDisposition" class="mb-1 block text-xs font-medium text-slate-600">التصرف</label>
              <select id="fundReturnDisposition" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15">
                <option value="remain_at_entity">يبقى بالصندوق</option>
                <option value="transfer_to_fund">ترحيل لصندوق آخر</option>
              </select>
            </div>
          </div>
          <div id="fundReturnTargetWrap" class="hidden min-w-0">
            <label for="fundReturnTarget" class="mb-1 block text-xs font-medium text-slate-600">صندوق المقصد</label>
            <select id="fundReturnTarget" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15"></select>
          </div>
          <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:gap-3">
            <div class="min-w-0 flex-1">
              <label for="fundReturnNotes" class="mb-1 block text-xs font-medium text-slate-600">ملاحظات <span class="font-normal text-slate-400">(اختياري)</span></label>
              <input type="text" id="fundReturnNotes" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/15" placeholder="">
            </div>
            <button type="button" onclick="fundsSubmitReturn()" class="h-11 w-full shrink-0 rounded-xl bg-emerald-600 px-5 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700 sm:w-auto sm:min-w-[7.5rem]">تسجيل</button>
          </div>
        </div>
      </div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-3 py-2.5 sm:px-4">
        <h2 class="text-sm font-bold text-slate-900">سجل الحركات</h2>
        <p class="text-[10px] text-slate-500">المبالغ والرصيد بعد كل حركة — اضغط على سطر لعرض التفاصيل أو إلغاء التحويل</p>
      </div>
      <div id="fundDetailLedger" class="fund-detail-ledger mx-3 mb-3 max-h-[min(22rem,48vh)] overflow-y-auto rounded-xl border border-slate-100 bg-slate-50/60 p-3 text-sm sm:mx-4 sm:mb-4 sm:max-h-[min(26rem,52vh)] sm:p-4"></div>
    </section>
  </div>

  <div id="fundLedgerMoveModal" class="fixed inset-0 z-[2100] hidden items-center justify-center p-4 bg-black/50" onclick="if(event.target===this)fundsCloseLedgerModal()">
    <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6" onclick="event.stopPropagation()">
      <h4 id="fundLedgerMoveModalTitle" class="text-lg font-bold mb-3 text-slate-900">تفاصيل الحركة</h4>
      <div id="fundLedgerMoveModalBody" class="space-y-2 text-sm text-slate-700 mb-6 min-h-[4rem]"></div>
      <div class="flex flex-col-reverse gap-2 sm:flex-row">
        <button type="button" onclick="fundsCloseLedgerModal()" class="w-full py-3 rounded-xl bg-slate-100 font-semibold text-slate-800">إغلاق</button>
        <button type="button" id="fundLedgerMoveModalCancelBtn" onclick="fundsConfirmCancelLedger()" class="hidden w-full py-3 rounded-xl bg-red-600 text-white font-semibold">إلغاء التحويل</button>
      </div>
    </div>
  </div>
</div>
