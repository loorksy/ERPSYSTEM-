<div id="fundDetailPage" data-fund-id="<%= fundId %>" class="fund-detail-page w-full max-w-6xl mx-auto min-w-0 px-3 sm:px-6 lg:px-8 pb-8" dir="rtl">
  <div class="space-y-4">
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <!-- رأس: رجوع | هوية | تنزيل -->
      <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-3 border-b border-slate-100 bg-slate-50/50 px-3 py-3 sm:px-4">
        <a href="/funds" class="btn-back inline-flex shrink-0" title="العودة لقائمة الصناديق" aria-label="العودة لقائمة الصناديق">
          <i class="fas fa-arrow-right text-sm"></i>
        </a>
        <div class="flex min-w-0 items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-600 text-white shadow-sm">
            <i class="fas fa-vault text-sm" aria-hidden="true"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-600">صندوق</p>
            <h1 id="fundDetailTitle" class="truncate text-base font-bold text-slate-900 sm:text-lg">—</h1>
          </div>
        </div>
        <button type="button" onclick="fundsDownloadLedgerPdf()" class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-2.5 py-2 text-xs font-bold text-slate-800 shadow-sm transition hover:bg-slate-50" title="تنزيل سجل الحركات PDF">
          <i class="fas fa-file-pdf text-red-500 text-[0.85rem]" aria-hidden="true"></i>
          <span class="hidden sm:inline">PDF</span>
        </button>
      </div>

      <!-- إجراء سريع -->
      <div class="border-b border-slate-100 px-3 py-2.5 sm:px-4">
        <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end">
          <button type="button" onclick="fundsSetMain()" class="inline-flex min-h-[2.35rem] w-full items-center justify-center gap-1.5 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-900 transition hover:bg-amber-100 sm:w-auto sm:min-w-[10rem]">
            <i class="fas fa-star text-[0.7rem]" aria-hidden="true"></i>
            تعيين كصندوق رئيسي
          </button>
        </div>
      </div>

      <div class="p-3 sm:p-4 space-y-4">
        <div id="fundDetailMeta" class="text-sm text-slate-600"></div>
        <div id="fundDetailPayables" class="hidden rounded-xl border border-red-100 bg-red-50/70 px-3 py-2.5 text-sm font-semibold text-red-800"></div>
        <div id="fundDetailBalances" class="flex flex-wrap gap-2"></div>

        <!-- ترحيل -->
        <div class="rounded-xl border border-slate-200 bg-slate-50/60 p-4">
          <h3 class="mb-3 text-xs font-bold text-slate-800">ترحيل إلى صندوق آخر</h3>
          <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end">
            <div class="min-w-0 flex-1 sm:max-w-xs">
              <label class="mb-1 block text-[11px] font-medium text-slate-600">صندوق المقصد</label>
              <select id="fundTransferTo" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"></select>
            </div>
            <div class="w-full sm:w-36">
              <label class="mb-1 block text-[11px] font-medium text-slate-600">المبلغ (USD)</label>
              <input type="number" id="fundTransferAmt" step="0.01" placeholder="0.00" dir="ltr" class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
            </div>
            <button type="button" onclick="fundsDoTransfer()" class="inline-flex w-full items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white shadow-md shadow-indigo-600/15 transition hover:bg-indigo-700 sm:w-auto">
              ترحيل
            </button>
          </div>
        </div>

        <!-- مرتجع -->
        <div class="space-y-3 rounded-xl border border-emerald-100 bg-emerald-50/40 p-4">
          <h3 class="text-xs font-bold text-emerald-900">تسجيل مرتجع</h3>
          <div class="grid gap-3 sm:grid-cols-2">
            <div>
              <label class="mb-1 block text-[11px] font-medium text-slate-600">المبلغ</label>
              <input type="number" id="fundReturnAmt" step="0.01" min="0" placeholder="0.00" dir="ltr" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm focus:border-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
            </div>
            <div>
              <label class="mb-1 block text-[11px] font-medium text-slate-600">العملة</label>
              <select id="fundReturnCur" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm focus:border-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                <option value="USD">USD</option>
                <option value="TRY">TRY</option>
                <option value="SYP">SYP</option>
              </select>
            </div>
            <div class="sm:col-span-2">
              <label class="mb-1 block text-[11px] font-medium text-slate-600">التصرف</label>
              <select id="fundReturnDisposition" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm focus:border-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                <option value="remain_at_entity">يبقى بالصندوق</option>
                <option value="transfer_to_fund">ترحيل لصندوق آخر</option>
              </select>
            </div>
            <div id="fundReturnTargetWrap" class="hidden sm:col-span-2">
              <label class="mb-1 block text-[11px] font-medium text-slate-600">صندوق المقصد</label>
              <select id="fundReturnTarget" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm focus:border-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"></select>
            </div>
          </div>
          <input type="text" id="fundReturnNotes" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm focus:border-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" placeholder="ملاحظات (اختياري)">
          <button type="button" onclick="fundsSubmitReturn()" class="w-full rounded-xl bg-emerald-600 py-2.5 text-sm font-bold text-white shadow-md shadow-emerald-600/20 transition hover:bg-emerald-700 sm:w-auto sm:px-8">
            تسجيل المرتجع
          </button>
        </div>

        <!-- سجل -->
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
          <div class="border-b border-slate-100 bg-gradient-to-l from-slate-50 to-white px-3 py-2.5 sm:px-4">
            <h2 class="text-sm font-bold text-slate-900">سجل الحركات</h2>
            <p class="text-[10px] text-slate-500">المبالغ والرصيد التقريبي بعد كل حركة</p>
          </div>
          <div id="fundDetailLedger" class="max-h-[min(24rem,50vh)] overflow-y-auto p-3 text-sm sm:max-h-[min(28rem,55vh)] sm:p-4"></div>
        </div>
      </div>
    </section>
  </div>
</div>
