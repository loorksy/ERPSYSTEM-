<div class="acc-detail-page acc-approvals-page w-full max-w-6xl mx-auto min-w-0 px-3 sm:px-6 lg:px-8 pb-8" dir="rtl">
  <button type="button" id="accNavPrev" class="acc-profile-nav-btn acc-profile-nav-btn--prev" aria-label="المعتمد السابق في القائمة" title="السابقة">
    <i class="fas fa-chevron-right text-sm" aria-hidden="true"></i>
  </button>
  <button type="button" id="accNavNext" class="acc-profile-nav-btn acc-profile-nav-btn--next" aria-label="المعتمد التالي في القائمة" title="التالية">
    <i class="fas fa-chevron-left text-sm" aria-hidden="true"></i>
  </button>
  <div id="accDetailPage" data-accreditation-id="<%= accreditationId %>" class="space-y-4">
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <!-- رأس: رجوع | هوية + أرصدة | تثبيت -->
      <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-3 border-b border-slate-100 bg-slate-50/50 px-3 py-3 sm:px-4">
        <a href="/approvals" class="btn-back inline-flex shrink-0" title="العودة لقائمة المعتمدين" aria-label="العودة لقائمة المعتمدين">
          <i class="fas fa-arrow-right text-sm"></i>
        </a>
        <div class="flex min-w-0 items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-600 text-white shadow-sm">
            <i class="fas fa-user-check text-sm" aria-hidden="true"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-600">معتمد</p>
            <h1 id="accDetailTitle" class="truncate text-base font-bold text-slate-900 sm:text-lg">—</h1>
          </div>
        </div>
        <button type="button" id="accPinBtn" onclick="accTogglePin()" class="inline-flex shrink-0 items-center gap-1 rounded-lg border border-amber-200 bg-amber-100 px-2.5 py-2 text-xs font-bold text-amber-900 transition hover:bg-amber-200" title="تثبيت في القائمة">تثبيت</button>
      </div>

      <div class="border-b border-slate-100 bg-white px-3 py-3 sm:px-4">
        <p class="mb-2 text-[11px] font-semibold text-slate-500 sm:hidden">إجراءات سريعة</p>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 sm:gap-2 lg:max-w-4xl lg:ms-auto">
          <button type="button" onclick="accShowAddAmount()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center gap-1.5 rounded-xl bg-emerald-600 px-2 py-2 text-[11px] font-bold text-white shadow-md shadow-emerald-600/20 transition hover:bg-emerald-700 active:scale-[0.99] sm:min-h-[2.35rem] sm:text-xs">
            <i class="fas fa-plus-circle shrink-0 text-[0.75rem]" aria-hidden="true"></i>
            <span class="text-center leading-tight">إضافة مبلغ</span>
          </button>
          <button type="button" onclick="accShowTransfer()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center gap-1.5 rounded-xl border-2 border-slate-600 bg-slate-700 px-2 py-2 text-[11px] font-bold text-white shadow-sm transition hover:bg-slate-800 active:scale-[0.99] sm:min-h-[2.35rem] sm:text-xs">
            <i class="fas fa-right-left shrink-0 text-[0.75rem]" aria-hidden="true"></i>
            <span class="text-center leading-tight">تحويل</span>
          </button>
          <button type="button" onclick="accDownloadAccDetailPdf()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center gap-1.5 rounded-xl border border-slate-200 bg-white px-2 py-2 text-[11px] font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 active:scale-[0.99] sm:min-h-[2.35rem] sm:text-xs">
            <i class="fas fa-file-pdf text-red-500 shrink-0" aria-hidden="true"></i>
            <span>PDF</span>
          </button>
          <button type="button" onclick="accReloadDetail()" class="inline-flex min-h-[2.75rem] w-full items-center justify-center gap-1.5 rounded-xl border border-indigo-200 bg-indigo-50 px-2 py-2 text-[11px] font-semibold text-indigo-900 shadow-sm transition hover:bg-indigo-100 active:scale-[0.99] sm:min-h-[2.35rem] sm:text-xs">
            <i class="fas fa-rotate shrink-0" aria-hidden="true"></i>
            <span>تحديث</span>
          </button>
        </div>
      </div>

      <div class="p-3 sm:p-4">
        <div id="accPendingRecvOffsetBanner" class="mb-4 hidden rounded-xl border border-sky-200 bg-sky-50/95 px-3 py-3 shadow-sm">
          <p class="text-center text-[11px] font-semibold text-sky-950">عملية «إضافة مبلغ» معلّقة — اختر خصم الدين أو التأجيل</p>
          <div class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-center sm:gap-3">
            <button type="button" onclick="accResumeReceivableOffsetModal(Number(document.getElementById('accDetailPage').dataset.accreditationId))" class="inline-flex min-h-[2.5rem] w-full items-center justify-center gap-2 rounded-xl border border-sky-400 bg-white px-4 py-2 text-sm font-bold text-sky-900 shadow-sm transition hover:bg-sky-100 sm:w-auto">
              <i class="fas fa-scale-balanced text-sky-600" aria-hidden="true"></i>
              متابعة اختيار خصم الدين
            </button>
            <button type="button" onclick="accDismissPendingReceivableBanner()" class="text-xs font-semibold text-slate-500 underline-offset-2 hover:text-slate-800 hover:underline">إزالة التذكير</button>
          </div>
        </div>
        <div id="accBalanceSummary" class="mb-4 grid gap-2 rounded-xl border border-slate-200 bg-slate-50/90 p-3 sm:grid-cols-3 sm:gap-3">
          <div class="rounded-lg border border-emerald-200 bg-white px-3 py-2.5 shadow-sm">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-emerald-800">لنا</p>
            <p id="accDetailRec" class="mt-1 text-base font-bold tabular-nums text-emerald-700">—</p>
            <p class="mt-0.5 text-[10px] leading-snug text-slate-500">دين لنا (ما للمعتمد علينا)</p>
          </div>
          <div class="rounded-lg border border-rose-200 bg-white px-3 py-2.5 shadow-sm">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-rose-800">علينا</p>
            <p id="accDetailPay" class="mt-1 text-base font-bold tabular-nums text-rose-700">—</p>
            <p class="mt-0.5 text-[10px] leading-snug text-slate-500">دين علينا (رصيد له / مطلوب دفع)</p>
          </div>
          <div class="rounded-lg border border-slate-200 bg-white px-3 py-2.5 shadow-sm">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-600">الصافي (علينا)</p>
            <p id="accDetailNet" class="mt-1 text-base font-bold tabular-nums text-slate-900">—</p>
            <p class="mt-0.5 text-[10px] leading-snug text-slate-500">نفس رقم «علينا» ومبلغ التسليم من زر تسليم</p>
          </div>
        </div>
        <div id="accSettlementPanel" class="mb-4 hidden rounded-xl border border-amber-200 bg-amber-50/90 p-4 shadow-sm">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div class="min-w-0">
              <p class="text-xs font-bold text-amber-950">
                <i class="fas fa-triangle-exclamation ml-1 text-amber-600" aria-hidden="true"></i>
                يوجد دين لنا ودين علينا معًا
              </p>
              <p id="accSettlementExplain" class="mt-1 text-[11px] leading-relaxed text-amber-900/90"></p>
            </div>
          </div>
          <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-end">
            <label class="block min-w-0 flex-1 text-[11px] font-medium text-amber-950">
              مبلغ التسوية من الائتمان نحو «دين لنا» (حتى <span id="accSettlementMax" class="tabular-nums font-bold">0</span>)
              <input type="number" id="accSettlementAmt" step="0.01" min="0" dir="ltr" class="mt-1 w-full rounded-xl border border-amber-200 bg-white px-3 py-2 text-sm tabular-nums" placeholder="0.00" />
            </label>
            <button type="button" onclick="accSubmitSettlement()" class="w-full shrink-0 rounded-xl bg-amber-700 px-4 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-amber-800 sm:w-auto">
              تنفيذ التسوية
            </button>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
          <div class="border-b border-slate-100 bg-gradient-to-l from-slate-50 to-white px-3 py-2.5 sm:px-4">
            <h2 class="text-sm font-bold text-slate-900">سجل الحركات</h2>
            <p class="text-[10px] text-slate-500">المبلغ بألوان (+ أخضر / − أحمر)، ورصيد الصافي بعد كل حركة</p>
          </div>
          <div id="accLedger" class="max-h-[min(24rem,50vh)] overflow-y-auto overscroll-contain p-3 text-sm [-webkit-overflow-scrolling:touch] sm:max-h-[min(28rem,55vh)] sm:p-4"></div>
        </div>
      </div>
    </section>
  </div>

  <!-- إضافة مبلغ — منبثق -->
  <div id="accDetailAddAmountModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-sm" dir="rtl" onclick="if(event.target===this)accCloseDetailAddAmountModal()">
    <div class="tc-modal-shell relative flex max-h-[min(92vh,720px)] w-full max-w-md flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
      <div class="flex shrink-0 items-center justify-between gap-3 border-b border-emerald-100 bg-gradient-to-l from-emerald-50/90 to-white px-4 py-3 sm:px-5">
        <div class="min-w-0">
          <h3 class="text-base font-bold text-slate-900">إضافة مبلغ</h3>
          <p class="text-[11px] text-slate-500">تسجيل لنا / علينا / لهم</p>
        </div>
        <button type="button" onclick="accCloseDetailAddAmountModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
      </div>
      <div class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain p-4 sm:p-5">
        <select id="accAmountKind" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm" onchange="accAmountKindChange()">
          <option value="debt_receivable">لنا — دين على المعتمد (بدون صندوق)</option>
          <option value="debt_payable">علينا — صندوق رئيسي + مطلوب دفع</option>
          <option value="debt_payable_no_fund">لهم — مطلوب دفع + ربح خصم (بدون صندوق رئيسي)</option>
        </select>
        <label class="block text-[11px] font-medium text-slate-600">المبلغ</label>
        <div class="flex overflow-hidden rounded-xl border border-slate-200 bg-white focus-within:ring-2 focus-within:ring-indigo-500/25 focus-within:border-indigo-400">
          <input type="number" id="accAmt" step="0.01" dir="ltr" class="min-w-0 flex-1 border-0 bg-transparent px-3 py-2.5 text-sm focus:ring-0" placeholder="0.00">
          <span class="acc-currency-sym flex items-center border-s border-slate-200 bg-slate-50 px-3 text-sm font-semibold tabular-nums text-slate-600" aria-hidden="true">$</span>
        </div>
        <div id="accDiscountWrap" class="hidden">
          <label id="accDiscountLabel" class="mb-1 block text-[11px] font-medium text-slate-600">خصم %</label>
          <input type="number" id="accDiscountPct" step="0.1" min="0" max="100" placeholder="اتركه فارغاً إن لم يكن هناك خصم" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm">
        </div>
        <label class="block text-[11px] font-medium text-slate-600">دورة مالية</label>
        <select id="accCycle" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm"><option value="">— دورة —</option></select>
        <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
          <button type="button" onclick="accCloseDetailAddAmountModal()" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 hover:bg-slate-50 sm:w-auto">إلغاء</button>
          <button type="button" onclick="accSubmitAmount()" class="h-11 w-full rounded-xl bg-indigo-600 px-5 text-sm font-bold text-white shadow-md hover:bg-indigo-700 sm:w-auto sm:min-w-[8rem]">تسجيل</button>
        </div>
      </div>
    </div>
  </div>

  <!-- تحويل — منبثق -->
  <div id="accDetailTransferModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-sm" dir="rtl" onclick="if(event.target===this)accCloseDetailTransferModal()">
    <div class="tc-modal-shell relative flex max-h-[min(92vh,760px)] w-full max-w-md flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
      <div class="flex shrink-0 items-center justify-between gap-3 border-b border-slate-200 bg-gradient-to-l from-slate-50 to-white px-4 py-3 sm:px-5">
        <div class="min-w-0">
          <h3 class="text-base font-bold text-slate-900">تحويل</h3>
          <p class="text-[11px] text-slate-500">تسليم أو صندوق أو شركة</p>
        </div>
        <button type="button" onclick="accCloseDetailTransferModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
      </div>
      <div class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain p-4 sm:p-5">
        <select id="accTfType" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm" onchange="accTfTypeChange()">
          <option value="manual">تسليم يدوي</option>
          <option value="fund">تحويل صندوق</option>
          <option value="company">تحويل (شركة)</option>
          <option value="shipping">شحن</option>
        </select>
        <label class="block text-[11px] font-medium text-slate-600">المبلغ</label>
        <div class="flex overflow-hidden rounded-xl border border-slate-200 bg-white focus-within:ring-2 focus-within:ring-indigo-500/25 focus-within:border-indigo-400">
          <input type="number" id="accTfAmt" step="0.01" dir="ltr" class="min-w-0 flex-1 border-0 bg-transparent px-3 py-2.5 text-sm focus:ring-0" placeholder="0.00">
          <span class="acc-currency-sym flex items-center border-s border-slate-200 bg-slate-50 px-3 text-sm font-semibold tabular-nums text-slate-600" aria-hidden="true">$</span>
        </div>
        <select id="accTfFund" class="hidden w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm"></select>
        <select id="accTfCompany" class="hidden w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm"></select>
        <div id="accTfModeWrap" class="hidden space-y-2 rounded-xl border border-indigo-100 bg-indigo-50/50 p-3">
          <p class="text-[11px] font-semibold text-indigo-900">طريقة التحويل نحو الصندوق أو الشركة</p>
          <label class="flex cursor-pointer items-start gap-2 rounded-lg border border-white/80 bg-white p-2.5 shadow-sm">
            <input type="radio" name="accTfMode" id="accTfModePayable" value="payable" class="mt-0.5 h-4 w-4 shrink-0 text-indigo-600">
            <span class="text-xs leading-relaxed text-slate-800"><strong class="text-slate-900">دين علينا</strong> — تسجيل التزام (مطلوب دفع) لصالح الكيان دون زيادة الرصيد النقدي لديه؛ يُعتبر المبلغ مصروفاً من جهتكم.</span>
          </label>
          <label class="flex cursor-pointer items-start gap-2 rounded-lg border border-white/80 bg-white p-2.5 shadow-sm">
            <input type="radio" name="accTfMode" id="accTfModeMainFund" value="main_fund" class="mt-0.5 h-4 w-4 shrink-0 text-indigo-600" checked>
            <span class="text-xs leading-relaxed text-slate-800"><strong class="text-slate-900">خصم من الصندوق الرئيسي</strong> — يُخصم من الصندوق الرئيسي ويُودَع لرصيد الصندوق/الشركة المختارة (بدون تسجيل دين علينا لهذا المبلغ).</span>
          </label>
        </div>
        <p id="accTfShipHint" class="hidden rounded-lg border border-amber-100 bg-amber-50/80 px-3 py-2 text-xs text-amber-950">سجّل عملية الشحن من قسم الشحن ثم اربطها لاحقاً إن لزم.</p>
        <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
          <button type="button" onclick="accCloseDetailTransferModal()" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-700 hover:bg-slate-50 sm:w-auto">إلغاء</button>
          <button type="button" onclick="accSubmitTransfer()" class="h-11 w-full rounded-xl bg-indigo-600 px-5 text-sm font-bold text-white shadow-md hover:bg-indigo-700 sm:w-auto sm:min-w-[8rem]">تنفيذ</button>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('acc-receivable-offset-modal') %>
