<div id="accDetailPage" data-accreditation-id="<%= accreditationId %>" class="acc-approvals-page w-full max-w-2xl mx-auto min-w-0 px-4 sm:px-0 pb-10" dir="rtl">
  <div class="mb-6 flex flex-wrap items-center gap-3">
    <a href="/approvals" class="btn-back inline-flex" title="العودة لقائمة المعتمدين" aria-label="العودة لقائمة المعتمدين">
      <i class="fas fa-arrow-right"></i>
    </a>
    <h1 class="text-xl font-bold text-slate-800">ملف المعتمد</h1>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 sm:p-6">
    <div class="flex justify-between items-start mb-4 gap-3">
      <div>
        <h2 id="accDetailTitle" class="text-lg font-bold text-slate-900"></h2>
        <div id="accDetailBal" class="text-indigo-600 font-semibold mt-1"></div>
      </div>
    </div>
    <div class="flex gap-2 mb-4 flex-wrap">
      <button type="button" onclick="accShowAddAmount()" class="flex-1 min-w-[8rem] py-2 rounded-xl bg-emerald-600 text-white text-sm font-semibold">إضافة مبلغ</button>
      <button type="button" onclick="accShowTransfer()" class="flex-1 min-w-[8rem] py-2 rounded-xl bg-slate-600 text-white text-sm font-semibold hover:bg-slate-700">تحويل</button>
      <button type="button" id="accPinBtn" onclick="accTogglePin()" class="py-2 px-3 rounded-xl bg-amber-100 text-amber-800 text-sm">تثبيت</button>
    </div>
    <div id="accAddAmountPanel" class="hidden space-y-2 mb-4 p-4 rounded-xl bg-slate-50">
      <select id="accAmountKind" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="accAmountKindChange()">
        <option value="debt_receivable">لنا — دين على المعتمد (بدون صندوق)</option>
        <option value="debt_payable">علينا — صندوق رئيسي + مطلوب دفع</option>
        <option value="debt_payable_no_fund">لهم — مطلوب دفع + ربح خصم (بدون صندوق رئيسي)</option>
      </select>
      <label class="block text-[11px] text-slate-500 mb-0.5">المبلغ</label>
      <div class="flex rounded-lg border border-slate-200 bg-white overflow-hidden focus-within:ring-2 focus-within:ring-indigo-500/25 focus-within:border-indigo-400">
        <input type="number" id="accAmt" step="0.01" dir="ltr" class="flex-1 min-w-0 border-0 px-3 py-2 text-sm bg-transparent focus:ring-0" placeholder="0.00">
        <span class="acc-currency-sym flex items-center px-3 border-s border-slate-200 bg-slate-50 text-slate-600 text-sm font-semibold tabular-nums shrink-0" aria-hidden="true">$</span>
      </div>
      <div id="accDiscountWrap" class="hidden">
        <label id="accDiscountLabel" class="block text-[11px] text-slate-500 mb-0.5">خصم %</label>
        <input type="number" id="accDiscountPct" step="0.1" min="0" max="100" placeholder="اتركه فارغاً إن لم يكن هناك خصم" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm">
      </div>
      <select id="accCycle" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm"><option value="">— دورة مالية —</option></select>
      <button type="button" onclick="accSubmitAmount()" class="w-full py-2 rounded-lg bg-indigo-600 text-white text-sm">تسجيل</button>
    </div>
    <div id="accTransferPanel" class="hidden space-y-2 mb-4 p-4 rounded-xl bg-slate-50">
      <select id="accTfType" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="accTfTypeChange()">
        <option value="manual">تسليم يدوي</option>
        <option value="fund">تحويل صندوق</option>
        <option value="company">تحويل (شركة)</option>
        <option value="shipping">شحن</option>
      </select>
      <label class="block text-[11px] text-slate-500 mb-0.5">المبلغ</label>
      <div class="flex rounded-lg border border-slate-200 bg-white overflow-hidden focus-within:ring-2 focus-within:ring-indigo-500/25 focus-within:border-indigo-400">
        <input type="number" id="accTfAmt" step="0.01" dir="ltr" class="flex-1 min-w-0 border-0 px-3 py-2 text-sm bg-transparent focus:ring-0" placeholder="0.00">
        <span class="acc-currency-sym flex items-center px-3 border-s border-slate-200 bg-slate-50 text-slate-600 text-sm font-semibold tabular-nums shrink-0" aria-hidden="true">$</span>
      </div>
      <select id="accTfFund" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm hidden"></select>
      <select id="accTfCompany" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm hidden"></select>
      <p id="accTfShipHint" class="text-xs text-slate-500 hidden">سجّل عملية الشحن من قسم الشحن ثم اربطها لاحقاً إن لزم.</p>
      <button type="button" onclick="accSubmitTransfer()" class="w-full py-2 rounded-lg bg-indigo-600 text-white text-sm">تنفيذ</button>
    </div>
    <h5 class="font-bold text-slate-800 mb-2">السجل</h5>
    <div id="accLedger" class="text-sm space-y-2 max-h-80 overflow-y-auto"></div>
  </div>
</div>
