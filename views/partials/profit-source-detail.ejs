    <a href="/profit-sources" class="text-sm font-semibold text-indigo-600 hover:text-indigo-800">← مصادر الربح</a>
  </div>
  <header>
    <h2 class="text-xl sm:text-2xl font-bold text-slate-900" id="profitDetailTitle">تفاصيل المصدر</h2>
    <p class="text-xs text-slate-500 mt-1 font-mono" id="profitDetailCode"></p>
  </header>
  <div id="profitDetailBox" class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden min-h-[120px]">
