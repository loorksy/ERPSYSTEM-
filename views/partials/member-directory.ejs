<div class="member-directory-page touch-manipulation w-full max-w-6xl mx-auto min-w-0 overflow-x-clip px-4 pb-12 sm:px-6 lg:px-0 [-webkit-tap-highlight-color:transparent]" dir="rtl">

  <header class="mb-8 sm:mb-10">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:gap-6">
      <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-700 text-white shadow-lg shadow-indigo-900/20 sm:h-14 sm:w-14" aria-hidden="true">
        <i class="fas fa-address-book text-xl sm:text-2xl"></i>
      </span>
      <div class="min-w-0 flex-1">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">بيانات المستخدمين</h1>
        <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">يُبنى الملف من التدقيق، المؤجل، والوكالات — ابحث برقم المستخدم أو جزء من الاسم.</p>
        <div class="mt-5 h-px max-w-xs bg-gradient-to-l from-indigo-400/50 via-slate-200 to-transparent" aria-hidden="true"></div>
      </div>
    </div>
  </header>

  <div class="mb-8 flex flex-col gap-5 border-b border-slate-200/70 pb-8 sm:mb-10 sm:flex-row sm:items-end sm:justify-between sm:gap-8 sm:pb-10">
    <div class="min-w-0 w-full sm:max-w-xl sm:flex-1">
      <label for="mdSearchInput" class="block text-xs font-semibold uppercase tracking-wide text-slate-500">رقم المستخدم أو الاسم</label>
      <input type="text" id="mdSearchInput" placeholder="مثال: 12345 أو جزء من الاسم" autocomplete="off"
        class="mt-2 w-full rounded-xl border-0 bg-slate-100/80 px-4 py-3.5 text-sm text-slate-900 shadow-inner ring-1 ring-slate-200/80 transition placeholder:text-slate-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/30 sm:py-3">
    </div>
    <div class="flex w-full flex-wrap items-stretch gap-2 sm:w-auto sm:flex-nowrap sm:justify-end">
      <button type="button" id="mdPasteBtn"
        class="inline-flex min-h-[44px] flex-1 items-center justify-center gap-1.5 rounded-xl bg-slate-800 px-4 text-xs font-semibold text-white shadow-sm transition hover:bg-slate-900 active:scale-[0.99] sm:min-h-0 sm:flex-none sm:px-5 sm:text-sm">
        لصق من الحافظة
      </button>
      <button type="button" id="mdSearchBtn"
        class="inline-flex min-h-[44px] flex-1 items-center justify-center gap-2 rounded-xl bg-gradient-to-l from-indigo-600 to-indigo-500 px-4 text-xs font-semibold text-white shadow-md shadow-indigo-500/20 transition hover:brightness-105 active:scale-[0.99] sm:min-h-0 sm:flex-none sm:px-6 sm:text-sm">
        <i class="fas fa-search text-[11px] opacity-95 sm:text-sm" aria-hidden="true"></i>
        بحث
      </button>
    </div>
  </div>

  <div class="overflow-x-auto [-webkit-overflow-scrolling:touch]">
    <table class="w-full min-w-[720px] border-collapse text-right text-sm">
      <thead>
        <tr class="border-b-2 border-slate-200/90 text-[11px] font-bold uppercase tracking-wide text-slate-500">
          <th scope="col" class="pb-3 pl-3 pr-2 pt-0 sm:pr-4">رقم المستخدم</th>
          <th scope="col" class="pb-3 px-2 pt-0 sm:px-4">الاسم</th>
          <th scope="col" class="pb-3 px-2 pt-0 sm:px-4">راتب (تدقيق)</th>
          <th scope="col" class="pb-3 px-2 pt-0 sm:px-4">مؤجل</th>
          <th scope="col" class="pb-3 px-2 pt-0 sm:px-4">دين</th>
          <th scope="col" class="pb-3 px-2 pt-0 sm:px-4">آخر تحديث</th>
          <th scope="col" class="pb-3 pr-2 pl-4 pt-0 sm:pl-4"><span class="sr-only">إجراء</span></th>
        </tr>
      </thead>
      <tbody id="mdTableBody" class="divide-y divide-slate-100 text-slate-800"></tbody>
    </table>
  </div>

  <div class="mt-6 flex flex-col gap-4 border-t border-slate-200/70 pt-6 sm:flex-row sm:items-center sm:justify-between">
    <span id="mdPageInfo" class="text-center text-xs text-slate-500 sm:text-right"></span>
    <div class="flex items-center justify-center gap-2 sm:justify-end">
      <button type="button" id="mdPrevBtn" class="min-h-[40px] min-w-[5.5rem] rounded-xl border border-slate-200/90 bg-white px-4 text-xs font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-35">السابق</button>
      <button type="button" id="mdNextBtn" class="min-h-[40px] min-w-[5.5rem] rounded-xl border border-indigo-200 bg-indigo-50 px-4 text-xs font-semibold text-indigo-900 shadow-sm transition hover:bg-indigo-100 disabled:cursor-not-allowed disabled:opacity-35">التالي</button>
    </div>
  </div>
</div>
