<div class="member-directory-page md-detail-page touch-manipulation w-full max-w-6xl mx-auto min-w-0 overflow-x-clip px-4 pb-12 sm:px-6 lg:px-0 [-webkit-tap-highlight-color:transparent]" dir="rtl" id="mdDetailRoot"
  data-member-id="<%= typeof memberUserId !== 'undefined' ? memberUserId : '' %>">

  <button type="button" id="mdNavPrev" class="md-profile-nav-btn md-profile-nav-btn--prev" aria-label="المستخدم السابق في القائمة" title="السابقة">
    <i class="fas fa-chevron-right text-sm" aria-hidden="true"></i>
  </button>
  <button type="button" id="mdNavNext" class="md-profile-nav-btn md-profile-nav-btn--next" aria-label="المستخدم التالي في القائمة" title="التالية">
    <i class="fas fa-chevron-left text-sm" aria-hidden="true"></i>
  </button>

  <header class="mb-8 sm:mb-10">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:gap-6">
      <a href="/member-directory" class="md-toolbar-btn md-toolbar-btn--neutral inline-flex min-h-[44px] shrink-0 items-center justify-center gap-2 self-start rounded-xl border border-slate-600 bg-slate-700 px-5 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800 hover:border-slate-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2" title="العودة لقائمة المستخدمين" aria-label="العودة لقائمة المستخدمين">
        <i class="fas fa-arrow-right text-sm" aria-hidden="true"></i>
        القائمة
      </a>
      <div class="flex min-w-0 flex-1 items-start gap-4">
        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-700 text-white shadow-lg shadow-indigo-900/20 sm:h-14 sm:w-14" aria-hidden="true">
          <i class="fas fa-user text-xl sm:text-2xl"></i>
        </span>
        <div class="min-w-0 flex-1">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-indigo-600">ملف مستخدم</p>
          <h1 class="mt-1 break-all font-mono text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl" id="mdDetailMemberId">—</h1>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">تدقيق، مؤجل، أحداث، تعديلات وشحن — في صفحة واحدة متصلة.</p>
          <div class="mt-5 h-px max-w-xs bg-gradient-to-l from-indigo-400/50 via-slate-200 to-transparent" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </header>

  <section class="mb-8 border-b border-slate-200/70 pb-8 sm:mb-10 sm:pb-10" aria-labelledby="md-summary-heading">
    <h2 id="md-summary-heading" class="sr-only">نظرة سريعة</h2>
    <div class="mb-4 flex items-center gap-2">
      <span class="h-px max-w-[2rem] flex-1 rounded-full bg-indigo-200"></span>
      <span class="text-[11px] font-bold uppercase tracking-wide text-slate-500">نظرة سريعة</span>
      <span class="h-px flex-1 bg-slate-200/80"></span>
    </div>
    <div id="mdDetailSummary"></div>
  </section>

  <section class="mb-8 border-b border-slate-200/70 pb-8 sm:mb-10 sm:pb-10" aria-labelledby="md-def-heading">
    <div class="mb-4 flex items-center gap-3">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-sky-100 text-sky-700 ring-1 ring-sky-200/60" aria-hidden="true"><i class="fas fa-clock-rotate-left text-sm"></i></span>
      <h2 id="md-def-heading" class="text-base font-bold text-slate-900 sm:text-lg">المؤجل <span class="font-normal text-slate-500">(الدورات)</span></h2>
    </div>
    <div id="mdDeferredBlock" class="text-sm text-slate-700"></div>
  </section>

  <section class="mb-8 border-b border-slate-200/70 pb-8 sm:mb-10 sm:pb-10" aria-labelledby="md-audit-heading">
    <div class="mb-4 flex items-center gap-3">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-emerald-100 text-emerald-700 ring-1 ring-emerald-200/60" aria-hidden="true"><i class="fas fa-clipboard-check text-sm"></i></span>
      <h2 id="md-audit-heading" class="text-base font-bold text-slate-900 sm:text-lg">سجل التدقيق</h2>
    </div>
    <div id="mdAuditBlock" class="overflow-x-auto [-webkit-overflow-scrolling:touch] text-sm"></div>
  </section>

  <section class="mb-8 border-b border-slate-200/70 pb-8 sm:mb-10 sm:pb-10" aria-labelledby="md-events-heading">
    <div class="mb-4 flex items-center gap-3">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-violet-100 text-violet-700 ring-1 ring-violet-200/60" aria-hidden="true"><i class="fas fa-bolt text-sm"></i></span>
      <h2 id="md-events-heading" class="text-base font-bold text-slate-900 sm:text-lg">أحداث الملف</h2>
    </div>
    <div id="mdEventsBlock" class="text-sm"></div>
  </section>

  <section class="mb-8 border-b border-slate-200/70 pb-8 sm:mb-10 sm:pb-10" aria-labelledby="md-adj-heading">
    <div class="mb-4 flex items-center gap-3">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-amber-100 text-amber-800 ring-1 ring-amber-200/60" aria-hidden="true"><i class="fas fa-sliders text-sm"></i></span>
      <h2 id="md-adj-heading" class="text-base font-bold text-slate-900 sm:text-lg">إضافات وخصومات</h2>
    </div>
    <div id="mdAdjBlock" class="text-sm"></div>
  </section>

  <section class="mb-0 pb-2" aria-labelledby="md-ship-heading">
    <div class="mb-4 flex items-center gap-3">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-cyan-100 text-cyan-800 ring-1 ring-cyan-200/60" aria-hidden="true"><i class="fas fa-truck-fast text-sm"></i></span>
      <h2 id="md-ship-heading" class="text-base font-bold text-slate-900 sm:text-lg">الشحن <span class="font-normal text-slate-500">(مبيعات للمستخدم)</span></h2>
    </div>
    <div id="mdShippingBlock" class="overflow-x-auto [-webkit-overflow-scrolling:touch] text-sm"></div>
  </section>
</div>
