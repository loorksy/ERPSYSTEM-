<div class="md-detail-page md-member-profile w-full max-w-6xl mx-auto min-w-0 px-3 sm:px-6 lg:px-8 pb-8" dir="rtl" id="mdDetailRoot"
  data-member-id="<%= typeof memberUserId !== 'undefined' ? memberUserId : '' %>">

  <button type="button" id="mdNavPrev" class="md-profile-nav-btn md-profile-nav-btn--prev" aria-label="المستخدم السابق في القائمة" title="السابقة">
    <i class="fas fa-chevron-right text-sm" aria-hidden="true"></i>
  </button>
  <button type="button" id="mdNavNext" class="md-profile-nav-btn md-profile-nav-btn--next" aria-label="المستخدم التالي في القائمة" title="التالية">
    <i class="fas fa-chevron-left text-sm" aria-hidden="true"></i>
  </button>

  <div class="space-y-4">
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-3 border-b border-slate-100 bg-slate-50/50 px-3 py-3 sm:px-4">
        <a href="/member-directory" class="btn-back inline-flex shrink-0" title="العودة لقائمة المستخدمين" aria-label="العودة لقائمة المستخدمين">
          <i class="fas fa-arrow-right text-sm"></i>
        </a>
        <div class="flex min-w-0 items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-600 text-white shadow-sm">
            <i class="fas fa-user text-sm" aria-hidden="true"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-600">ملف مستخدم</p>
            <h1 class="truncate font-mono text-base font-bold text-slate-900 sm:text-lg" id="mdDetailMemberId">—</h1>
            <p class="mt-0.5 text-[11px] text-slate-500 leading-snug hidden sm:block">ملخص من التدقيق، المؤجل، والأحداث المرتبطة بهذا الرقم.</p>
          </div>
        </div>
        <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-slate-200/80 bg-white text-slate-400" title="" aria-hidden="true">
          <i class="fas fa-id-card text-sm opacity-60"></i>
        </span>
      </div>

      <div class="border-b border-slate-100 px-3 py-3 sm:px-4">
        <h2 class="text-xs font-bold uppercase tracking-wide text-slate-500 mb-2">ملخص</h2>
        <div id="mdDetailSummary"></div>
      </div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 bg-slate-50/90 px-3 py-3 sm:px-4 flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-sky-100 text-sky-700"><i class="fas fa-clock-rotate-left text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-800">المؤجل (الدورات)</h2>
      </div>
      <div id="mdDeferredBlock" class="p-3 sm:p-4 text-sm text-slate-700"></div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 bg-slate-50/90 px-3 py-3 sm:px-4 flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-100 text-emerald-700"><i class="fas fa-clipboard-check text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-800">سجل التدقيق</h2>
      </div>
      <div id="mdAuditBlock" class="p-3 sm:p-4 text-sm overflow-x-auto"></div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 bg-slate-50/90 px-3 py-3 sm:px-4 flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-violet-100 text-violet-700"><i class="fas fa-bolt text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-800">أحداث الملف</h2>
      </div>
      <div id="mdEventsBlock" class="p-3 sm:p-4 text-sm space-y-2"></div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 bg-slate-50/90 px-3 py-3 sm:px-4 flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-100 text-amber-800"><i class="fas fa-sliders text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-800">إضافات وخصومات</h2>
      </div>
      <div id="mdAdjBlock" class="p-3 sm:p-4 text-sm space-y-2"></div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 bg-slate-50/90 px-3 py-3 sm:px-4 flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-cyan-100 text-cyan-800"><i class="fas fa-truck-fast text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-800">الشحن (مبيعات للمستخدم)</h2>
      </div>
      <div id="mdShippingBlock" class="p-3 sm:p-4 text-sm overflow-x-auto"></div>
    </section>
  </div>
</div>
