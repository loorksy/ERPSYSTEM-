<div class="md-detail-page md-member-profile w-full max-w-5xl mx-auto min-w-0 px-3 pb-10 pt-1 sm:px-5 sm:pt-2 lg:px-6" dir="rtl" id="mdDetailRoot"
  data-member-id="<%= typeof memberUserId !== 'undefined' ? memberUserId : '' %>">

  <button type="button" id="mdNavPrev" class="md-profile-nav-btn md-profile-nav-btn--prev" aria-label="المستخدم السابق في القائمة" title="السابقة">
    <i class="fas fa-chevron-right text-sm" aria-hidden="true"></i>
  </button>
  <button type="button" id="mdNavNext" class="md-profile-nav-btn md-profile-nav-btn--next" aria-label="المستخدم التالي في القائمة" title="التالية">
    <i class="fas fa-chevron-left text-sm" aria-hidden="true"></i>
  </button>

  <article class="relative mb-6 overflow-hidden rounded-3xl border border-slate-200/90 bg-white shadow-[0_8px_32px_-14px_rgba(15,23,42,0.18)] ring-1 ring-slate-900/[0.04]">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_90%_80%_at_100%_0%,rgba(99,102,241,0.11),transparent_55%)]"></div>
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_0%_100%,rgba(14,165,233,0.06),transparent_50%)]"></div>
    <div class="relative px-4 pb-1 pt-6 sm:px-7 sm:pt-8">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between sm:gap-6">
        <div class="flex min-w-0 flex-1 items-start gap-3 sm:gap-4">
          <a href="/member-directory" class="btn-back mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-slate-200/80 bg-white text-slate-600 shadow-sm transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" title="العودة لقائمة المستخدمين" aria-label="العودة لقائمة المستخدمين">
            <i class="fas fa-arrow-right text-sm"></i>
          </a>
          <div class="relative shrink-0">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-600 via-indigo-700 to-violet-800 text-white shadow-lg shadow-indigo-900/25 sm:h-16 sm:w-16">
              <i class="fas fa-user text-xl sm:text-2xl" aria-hidden="true"></i>
            </div>
            <span class="absolute -bottom-0.5 -left-0.5 flex h-6 w-6 items-center justify-center rounded-full border-2 border-white bg-emerald-500 text-[10px] text-white shadow-sm" title="معرّف النظام" aria-hidden="true">
              <i class="fas fa-id-badge"></i>
            </span>
          </div>
          <div class="min-w-0 flex-1 pt-0.5">
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-indigo-600">ملف مستخدم</p>
            <h1 class="mt-1 break-all font-mono text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl" id="mdDetailMemberId">—</h1>
            <p class="mt-2 max-w-xl text-sm leading-relaxed text-slate-500">تدقيق، مؤجل، أحداث، وتعديلات وشحن — في صفحة واحدة.</p>
          </div>
        </div>
      </div>
      <div class="mt-6 border-t border-slate-100/90 bg-gradient-to-b from-slate-50/90 to-slate-50/40 px-3 py-5 sm:-mx-0 sm:mt-8 sm:rounded-b-2xl sm:px-6 sm:py-7">
        <div class="mb-3 flex items-center gap-2">
          <span class="h-px flex-1 max-w-[2rem] rounded-full bg-indigo-200"></span>
          <h2 class="text-[11px] font-bold uppercase tracking-wide text-slate-500">نظرة سريعة</h2>
          <span class="h-px flex-1 bg-slate-200/80"></span>
        </div>
        <div id="mdDetailSummary"></div>
      </div>
    </div>
  </article>

  <div class="space-y-4 sm:space-y-5">
    <section class="overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-sm ring-1 ring-slate-900/[0.03]">
      <div class="flex items-center gap-3 border-b border-slate-100/90 bg-gradient-to-l from-sky-50/95 to-white px-4 py-3.5 sm:px-5">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-sky-100 text-sky-700 shadow-sm ring-1 ring-sky-200/50"><i class="fas fa-clock-rotate-left text-sm"></i></span>
        <div>
          <h2 class="text-sm font-bold text-slate-900 sm:text-base">المؤجل <span class="font-normal text-slate-500">(الدورات)</span></h2>
        </div>
      </div>
      <div id="mdDeferredBlock" class="p-4 text-sm text-slate-700 sm:p-5"></div>
    </section>

    <section class="overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-sm ring-1 ring-slate-900/[0.03]">
      <div class="flex items-center gap-3 border-b border-slate-100/90 bg-gradient-to-l from-emerald-50/95 to-white px-4 py-3.5 sm:px-5">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700 shadow-sm ring-1 ring-emerald-200/50"><i class="fas fa-clipboard-check text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-900 sm:text-base">سجل التدقيق</h2>
      </div>
      <div id="mdAuditBlock" class="p-4 text-sm sm:p-5 overflow-x-auto"></div>
    </section>

    <section class="overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-sm ring-1 ring-slate-900/[0.03]">
      <div class="flex items-center gap-3 border-b border-slate-100/90 bg-gradient-to-l from-violet-50/95 to-white px-4 py-3.5 sm:px-5">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-violet-100 text-violet-700 shadow-sm ring-1 ring-violet-200/50"><i class="fas fa-bolt text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-900 sm:text-base">أحداث الملف</h2>
      </div>
      <div id="mdEventsBlock" class="space-y-2.5 p-4 text-sm sm:p-5"></div>
    </section>

    <section class="overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-sm ring-1 ring-slate-900/[0.03]">
      <div class="flex items-center gap-3 border-b border-slate-100/90 bg-gradient-to-l from-amber-50/95 to-white px-4 py-3.5 sm:px-5">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 text-amber-800 shadow-sm ring-1 ring-amber-200/50"><i class="fas fa-sliders text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-900 sm:text-base">إضافات وخصومات</h2>
      </div>
      <div id="mdAdjBlock" class="space-y-2.5 p-4 text-sm sm:p-5"></div>
    </section>

    <section class="overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-sm ring-1 ring-slate-900/[0.03]">
      <div class="flex items-center gap-3 border-b border-slate-100/90 bg-gradient-to-l from-cyan-50/95 to-white px-4 py-3.5 sm:px-5">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-100 text-cyan-800 shadow-sm ring-1 ring-cyan-200/50"><i class="fas fa-truck-fast text-sm"></i></span>
        <h2 class="text-sm font-bold text-slate-900 sm:text-base">الشحن <span class="font-normal text-slate-500">(مبيعات للمستخدم)</span></h2>
      </div>
      <div id="mdShippingBlock" class="p-4 text-sm sm:p-5 overflow-x-auto"></div>
    </section>
  </div>
</div>
