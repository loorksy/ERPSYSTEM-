<div class="max-w-6xl mx-auto px-4 sm:px-0 pb-10" dir="rtl">
  <header class="relative overflow-hidden rounded-2xl border border-sky-200/70 bg-gradient-to-br from-sky-50/90 via-white to-slate-50 shadow-sm mb-6">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_0%_0%,rgba(14,165,233,0.1),transparent)] pointer-events-none"></div>
    <div class="relative flex items-start gap-4 p-5 sm:p-7">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-sky-600 to-blue-700 text-white shadow-md">
        <i class="fas fa-clock-rotate-left text-xl"></i>
      </div>
      <div class="min-w-0">
        <p class="text-xs font-semibold text-sky-700 mb-0.5">رواتب غير مدققة</p>
        <h2 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight">الرصيد المؤجل</h2>
        <p class="text-sm text-slate-600 mt-1 leading-relaxed">المستخدمون الذين لم يتم تدقيق رواتبهم من جدول الوكيل. الأرصدة <strong>تُرحَّل بين الدورات</strong> حتى يتم التدقيق أو الدمج.</p>
      </div>
    </div>
  </header>

  <div class="rounded-2xl border border-slate-200/90 bg-white shadow-sm overflow-hidden">
    <div class="p-5 sm:p-6 space-y-8">
      <div class="rounded-2xl border border-slate-200 bg-slate-50/60 p-4 sm:p-5">
        <h4 class="font-bold text-slate-900 mb-3 flex items-center gap-2 text-sm sm:text-base">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-600"><i class="fas fa-search text-sm"></i></span>
          بحث عن مستخدم — كل رواتبه المؤجلة
        </h4>
        <div class="flex flex-wrap gap-2 items-end">
          <input type="text" id="deferredMemberSearch" placeholder="رقم المستخدم" class="px-4 py-2.5 rounded-xl border-2 border-slate-200 bg-white text-sm min-w-[140px] focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/15">
          <button type="button" onclick="deferredLoadMemberHistory()" class="px-4 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">عرض السجل</button>
        </div>
        <div id="deferredMemberHistory" class="mt-3 text-sm text-slate-700 hidden rounded-xl border border-slate-100 bg-white p-3"></div>
      </div>

      <div>
        <div class="flex flex-wrap gap-3 mb-4 items-center">
          <label class="text-sm font-semibold text-slate-700">الدورة المالية:</label>
          <select id="deferredCycleSelect" class="px-4 py-2.5 rounded-xl border-2 border-slate-200 bg-slate-50/50 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/15" onchange="deferredLoadUsers()">
            <option value="">— كل الدورات —</option>
          </select>
          <button type="button" onclick="deferredRefresh()" class="px-4 py-2.5 rounded-xl bg-sky-600 text-white text-sm font-semibold shadow-md hover:bg-sky-700 active:scale-[0.99] transition">
            <i class="fas fa-sync-alt ml-1"></i> تحديث من Google (الدورة المختارة)
          </button>
        </div>
        <p class="text-xs text-slate-500 mb-3">للمزامنة اختر دورة محددة أولاً. عرض «كل الدورات» يُظهر كل الأسطر المؤجلة.</p>
        <div id="deferredUsersList" class="space-y-2">
          <p class="text-slate-400 text-center py-8">جاري التحميل...</p>
        </div>
      </div>

      <div class="rounded-2xl border border-amber-200/90 bg-gradient-to-br from-amber-50/80 to-orange-50/40 p-4 sm:p-5">
        <h4 class="font-bold text-amber-950 mb-2 flex items-center gap-2">
          <i class="fas fa-object-group text-amber-700"></i>
          دمج كل رواتب مستخدم في دورة واحدة
        </h4>
        <p class="text-xs text-amber-900/90 mb-3 leading-relaxed">يُصفّر المؤجل لذلك الرقم ويُسجَّل تدقيق في الدورة التي تختارها (مجموع الرواتب في السجل).</p>
        <div class="flex flex-wrap gap-2 items-end">
          <input type="text" id="deferredMergeMember" placeholder="رقم المستخدم" class="px-4 py-2.5 rounded-xl border-2 border-amber-200/80 bg-white text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/15">
          <select id="deferredMergeCycle" class="px-4 py-2.5 rounded-xl border-2 border-amber-200/80 bg-white text-sm min-w-[180px] focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/15">
            <option value="">— دورة الدمج —</option>
          </select>
          <button type="button" onclick="deferredSubmitMerge()" class="px-4 py-2.5 rounded-xl bg-amber-600 text-white text-sm font-semibold shadow-md hover:bg-amber-700 active:scale-[0.99] transition">دمج وتدقيق</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  function apiCall(url, opts) {
    if (typeof window.apiCall === 'function') return window.apiCall(url, opts);
    return fetch(url, { credentials: 'same-origin', ...opts }).then(r => r.json());
  }
  function showToast(msg, type) {
    if (typeof window.showToast === 'function') window.showToast(msg, type);
    else alert(msg);
  }
  function fmt(v) {
    if (typeof window.formatMoney === 'function') return window.formatMoney(v);
    return (parseFloat(v) || 0).toLocaleString('en-US', { minimumFractionDigits: 2 }) + ' $';
  }

  function fillCycleSelects(cycles) {
    var sel = document.getElementById('deferredCycleSelect');
    var merge = document.getElementById('deferredMergeCycle');
    var opts = (cycles || []).map(function(c) {
      return '<option value="' + c.id + '">' + (c.name || '') + '</option>';
    }).join('');
    if (sel) {
      sel.innerHTML = '<option value="">— كل الدورات —</option>' + opts;
    }
    if (merge) {
      merge.innerHTML = '<option value="">— دورة الدمج —</option>' + opts;
    }
  }

  window.deferredLoadUsers = function() {
    var sel = document.getElementById('deferredCycleSelect');
    var list = document.getElementById('deferredUsersList');
    if (!list) return;
    list.innerHTML = '<p class="text-slate-400 text-center py-8">جاري التحميل...</p>';
    var q = sel && sel.value ? ('?cycleId=' + encodeURIComponent(sel.value)) : '';
    apiCall('/dashboard/deferred-users' + q).then(function(res) {
      if (!res.success) {
        list.innerHTML = '<p class="text-red-500 text-center py-8">' + (res.message || 'فشل') + '</p>';
        return;
      }
      var users = res.users || [];
      if (res.mode === 'all' && res.totalDeferred != null) {
        list.innerHTML = '<p class="text-sm text-slate-600 mb-3">إجمالي المؤجل (كل الدورات): <strong class="text-sky-700">' + fmt(res.totalDeferred) + '</strong></p>';
      } else {
        list.innerHTML = '';
      }
      if (users.length === 0) {
        list.innerHTML += '<p class="text-slate-400 text-center py-8">لا يوجد مستخدمون غير مدققين في هذا العرض</p>';
        return;
      }
      list.innerHTML += users.map(function(u) {
        var cycleInfo = u.cycle_name ? (' · ' + (u.cycle_name || '') + ' #' + (u.cycle_id || '')) : '';
        var before = u.salary_before_discount != null ? (' · قبل الخصم: ' + fmt(u.salary_before_discount)) : '';
        return '<div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50 flex flex-wrap justify-between items-center gap-2">' +
          '<div><span class="font-semibold text-slate-800">رقم المستخدم: ' + (u.member_user_id || '') + '</span>' + cycleInfo + '</div>' +
          '<div class="text-sm text-slate-600">المعرف: ' + (u.extra_id_c || '-') + before + '</div>' +
          '<div class="font-bold text-sky-600">بعد الخصم: ' + fmt(u.balance_d || 0) + '</div>' +
          '</div>';
      }).join('');
    });
  };

  window.deferredRefresh = function() {
    var sel = document.getElementById('deferredCycleSelect');
    if (!sel || !sel.value) {
      showToast('اختر دورة محددة للمزامنة من Google', 'error');
      return;
    }
    apiCall('/dashboard/refresh-deferred', { method: 'POST', body: JSON.stringify({ cycleId: sel.value }) }).then(function(res) {
      showToast(res.message || (res.success ? 'تم التحديث' : 'فشل'), res.success ? 'success' : 'error');
      if (res.success) deferredLoadUsers();
    });
  };

  window.deferredLoadMemberHistory = function() {
    var inp = document.getElementById('deferredMemberSearch');
    var box = document.getElementById('deferredMemberHistory');
    if (!inp || !box) return;
    var id = (inp.value || '').trim();
    if (!id) {
      showToast('أدخل رقم المستخدم', 'error');
      return;
    }
    box.classList.remove('hidden');
    box.innerHTML = '<p class="text-slate-400">جاري التحميل...</p>';
    apiCall('/api/search/member-deferred-history?memberUserId=' + encodeURIComponent(id)).then(function(res) {
      if (!res.success) {
        box.innerHTML = '<p class="text-red-600">' + (res.message || 'فشل') + '</p>';
        return;
      }
      var lines = res.lines || [];
      if (!lines.length) {
        box.innerHTML = '<p class="text-slate-500">لا توجد أسطر مؤجلة لهذا الرقم.</p>';
        return;
      }
      box.innerHTML = '<p class="mb-2 font-semibold">المجموع: ' + fmt(res.totalDeferred) + '</p><ul class="list-disc pr-5 space-y-1">' +
        lines.map(function(l) {
          return '<li>' + (l.cycle_name || '') + ': ' + fmt(l.balance_d) + (l.salary_before_discount != null ? ' (قبل الخصم ' + fmt(l.salary_before_discount) + ')' : '') + '</li>';
        }).join('') + '</ul>';
    });
  };

  window.deferredSubmitMerge = function() {
    var mid = document.getElementById('deferredMergeMember');
    var cyc = document.getElementById('deferredMergeCycle');
    if (!mid || !cyc) return;
    var m = (mid.value || '').trim();
    var cid = cyc.value;
    if (!m || !cid) {
      showToast('أدخل رقم المستخدم واختر دورة الدمج', 'error');
      return;
    }
    if (!confirm('دمج كل رواتب المؤجل لهذا المستخدم في الدورة المختارة وتسجيل التدقيق؟')) return;
    apiCall('/dashboard/deferred-merge', {
      method: 'POST',
      body: JSON.stringify({ memberUserId: m, targetCycleId: parseInt(cid, 10) })
    }).then(function(res) {
      showToast(res.message || (res.success ? 'تم' : 'فشل'), res.success ? 'success' : 'error');
      if (res.success) {
        deferredLoadUsers();
        var hist = document.getElementById('deferredMemberHistory');
        if (hist) { hist.classList.add('hidden'); hist.innerHTML = ''; }
      }
    });
  };

  document.addEventListener('DOMContentLoaded', function() {
    apiCall('/dashboard/stats').then(function(res) {
      if (!res.success) return;
      var cycles = res.cycles || [];
      fillCycleSelects(cycles);
      var urlCycle = (new URLSearchParams(window.location.search)).get('cycleId');
      var sel = document.getElementById('deferredCycleSelect');
      if (sel && urlCycle && cycles.some(function(c) { return String(c.id) === String(urlCycle); })) {
        sel.value = urlCycle;
      }
      deferredLoadUsers();
    });
  });
})();
</script>
