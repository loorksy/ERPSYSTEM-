<div class="deferred-page touch-manipulation w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-0 pb-10 sm:pb-12 min-w-0 [-webkit-tap-highlight-color:transparent]" dir="rtl">
  <!-- أزرار تفتح النماذج -->
  <div class="mb-6 grid grid-cols-1 gap-2 sm:grid-cols-3 sm:gap-3">
    <button type="button" onclick="deferredOpenSearchModal()" class="inline-flex min-h-[3rem] w-full items-center justify-center gap-2 rounded-2xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-white px-4 py-3 text-sm font-bold text-indigo-900 shadow-sm ring-1 ring-indigo-900/5 transition hover:border-indigo-300 hover:shadow-md active:scale-[0.99]">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-100 text-indigo-700"><i class="fas fa-magnifying-glass" aria-hidden="true"></i></span>
      <span class="text-center leading-snug">بحث عن مستخدم</span>
    </button>
    <button type="button" onclick="deferredOpenCycleModal()" class="inline-flex min-h-[3rem] w-full items-center justify-center gap-2 rounded-2xl border border-sky-200 bg-gradient-to-br from-sky-50 to-white px-4 py-3 text-sm font-bold text-sky-900 shadow-sm ring-1 ring-sky-900/5 transition hover:border-sky-300 hover:shadow-md active:scale-[0.99]">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-sky-100 text-sky-800"><i class="fas fa-arrows-rotate" aria-hidden="true"></i></span>
      <span class="text-center leading-snug">الدورة والمزامنة</span>
    </button>
    <button type="button" onclick="deferredOpenMergeModal()" class="inline-flex min-h-[3rem] w-full items-center justify-center gap-2 rounded-2xl border border-amber-200 bg-gradient-to-br from-amber-50 to-white px-4 py-3 text-sm font-bold text-amber-950 shadow-sm ring-1 ring-amber-900/10 transition hover:border-amber-300 hover:shadow-md active:scale-[0.99]">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-amber-100 text-amber-900"><i class="fas fa-layer-group" aria-hidden="true"></i></span>
      <span class="text-center leading-snug">دمج وتدقيق</span>
    </button>
  </div>

  <!-- قائمة المؤجل -->
  <section class="rounded-2xl sm:rounded-3xl border border-slate-200/90 bg-white shadow-sm overflow-hidden min-w-0">
    <div class="flex flex-col gap-3 border-b border-slate-100 bg-slate-50/80 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6 sm:py-5">
      <div class="min-w-0">
        <h2 class="text-lg font-bold text-slate-900">قائمة المؤجل</h2>
        <p class="mt-0.5 text-[11px] text-slate-500">يتم التحديث عند تغيير الدورة من نافذة «الدورة والمزامنة»</p>
      </div>
      <button type="button" onclick="deferredCopyUserIds()" id="deferredCopyIdsBtn" class="inline-flex shrink-0 items-center justify-center gap-2 rounded-xl border border-indigo-200/90 bg-white px-3 py-2.5 text-xs font-semibold text-indigo-900 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50 active:scale-[0.99] sm:min-w-[12rem]" title="نسخ كل أرقام المستخدمين، سطر لكل رقم (للصق في جداول مثل Google Sheets)">
        <i class="fas fa-copy text-indigo-600" aria-hidden="true"></i>
        نسخ أرقام المستخدمين
      </button>
    </div>
    <div class="p-4 sm:p-6">
      <div id="deferredUsersList" class="flex flex-col gap-2.5 min-h-[4rem]">
        <p class="text-slate-400 text-center py-10 text-sm">جاري التحميل...</p>
      </div>
    </div>
  </section>
</div>

<!-- بحث عن مستخدم -->
<div id="deferredSearchModal" class="fixed inset-0 z-[10050] hidden items-center justify-center bg-slate-900/60 p-4 backdrop-blur-sm sm:p-6" dir="rtl" aria-hidden="true" onclick="if(event.target===this)deferredCloseSearchModal()">
  <div class="tc-modal-shell relative flex max-h-[min(92vh,640px)] w-full max-w-md flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
    <div class="flex shrink-0 items-center justify-between gap-3 border-b border-indigo-100 bg-gradient-to-l from-indigo-50/90 to-white px-4 py-3 sm:px-5">
      <div class="flex min-w-0 items-center gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md"><i class="fas fa-magnifying-glass text-sm"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">بحث عن مستخدم</h3>
          <p class="text-[11px] text-slate-500">عرض كل رواتبه المؤجلة</p>
        </div>
      </div>
      <button type="button" onclick="deferredCloseSearchModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
    </div>
    <div class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain p-4 sm:p-5">
      <label for="deferredMemberSearch" class="sr-only">رقم المستخدم</label>
      <input type="text" id="deferredMemberSearch" inputmode="numeric" autocomplete="off" placeholder="رقم المستخدم" class="w-full min-h-[44px] rounded-xl border-2 border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-indigo-500/10">
      <button type="button" onclick="deferredLoadMemberHistory()" class="w-full min-h-[44px] inline-flex items-center justify-center gap-2 rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-md hover:bg-indigo-700 active:scale-[0.99]">
        <i class="fas fa-list-ul text-xs opacity-90" aria-hidden="true"></i>
        عرض السجل
      </button>
      <div id="deferredMemberHistory" class="hidden rounded-xl border border-indigo-100 bg-indigo-50/40 p-3 text-sm text-slate-700 sm:p-4 max-h-56 overflow-y-auto overscroll-contain"></div>
    </div>
  </div>
</div>

<!-- الدورة والمزامنة -->
<div id="deferredCycleModal" class="fixed inset-0 z-[10050] hidden items-center justify-center bg-slate-900/60 p-4 backdrop-blur-sm sm:p-6" dir="rtl" aria-hidden="true" onclick="if(event.target===this)deferredCloseCycleModal()">
  <div class="tc-modal-shell relative flex max-h-[min(92vh,560px)] w-full max-w-md flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
    <div class="flex shrink-0 items-center justify-between gap-3 border-b border-sky-100 bg-gradient-to-l from-sky-50/90 to-white px-4 py-3 sm:px-5">
      <div class="flex min-w-0 items-center gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-sky-600 text-white shadow-md"><i class="fas fa-arrows-rotate text-sm"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">الدورة والمزامنة</h3>
          <p class="text-[11px] text-slate-500">تحديث من Google للدورة المختارة</p>
        </div>
      </div>
      <button type="button" onclick="deferredCloseCycleModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
    </div>
    <div class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain p-4 sm:p-5">
      <div class="space-y-1.5">
        <label for="deferredCycleSelect" class="block text-xs font-semibold text-slate-600">الدورة المالية</label>
        <select id="deferredCycleSelect" class="w-full min-h-[44px] rounded-xl border-2 border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm text-slate-900 focus:border-sky-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-sky-500/10" onchange="deferredLoadUsers()">
          <option value="">— كل الدورات —</option>
        </select>
      </div>
      <button type="button" onclick="deferredRefresh()" class="w-full min-h-[44px] inline-flex items-center justify-center gap-2 rounded-xl bg-sky-600 px-4 py-2.5 text-sm font-semibold text-white shadow-md hover:bg-sky-700 active:scale-[0.99]">
        <i class="fas fa-cloud-arrow-down text-xs opacity-95" aria-hidden="true"></i>
        تحديث من Google
      </button>
      <p class="text-[11px] leading-relaxed text-slate-500 border-t border-slate-100 pt-3">للمزامنة اختر دورة محددة أولاً. عرض «كل الدورات» يُظهر كل الأسطر المؤجلة.</p>
    </div>
  </div>
</div>

<!-- دمج وتدقيق -->
<div id="deferredMergeModal" class="fixed inset-0 z-[10050] hidden items-center justify-center bg-slate-900/60 p-4 backdrop-blur-sm sm:p-6" dir="rtl" aria-hidden="true" onclick="if(event.target===this)deferredCloseMergeModal()">
  <div class="tc-modal-shell relative flex max-h-[min(92vh,640px)] w-full max-w-md flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
    <div class="flex shrink-0 items-center justify-between gap-3 border-b border-amber-100 bg-gradient-to-l from-amber-50/90 to-white px-4 py-3 sm:px-5">
      <div class="flex min-w-0 items-center gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-amber-500 text-white shadow-md"><i class="fas fa-layer-group text-sm"></i></span>
        <div>
          <h3 class="text-base font-bold text-amber-950">دمج وتدقيق</h3>
          <p class="text-[11px] text-amber-900/80">دمج كل رواتب مستخدم في دورة واحدة</p>
        </div>
      </div>
      <button type="button" onclick="deferredCloseMergeModal()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
    </div>
    <div class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain p-4 sm:p-5">
      <p class="text-xs leading-relaxed text-amber-900/90">يُصفّر المؤجل لذلك الرقم ويُسجَّل تدقيق في الدورة التي تختارها (مجموع الرواتب في السجل).</p>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="space-y-1.5 min-w-0">
          <label for="deferredMergeMember" class="block text-xs font-semibold text-amber-900/90">رقم المستخدم</label>
          <input type="text" id="deferredMergeMember" placeholder="رقم المستخدم" class="w-full min-h-[44px] rounded-xl border-2 border-amber-200/90 bg-white px-3.5 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-amber-500 focus:outline-none focus:ring-4 focus:ring-amber-500/15">
        </div>
        <div class="space-y-1.5 min-w-0">
          <label for="deferredMergeCycle" class="block text-xs font-semibold text-amber-900/90">دورة الدمج</label>
          <select id="deferredMergeCycle" class="w-full min-h-[44px] rounded-xl border-2 border-amber-200/90 bg-white px-3.5 py-2.5 text-sm text-slate-900 focus:border-amber-500 focus:outline-none focus:ring-4 focus:ring-amber-500/15">
            <option value="">— دورة الدمج —</option>
          </select>
        </div>
      </div>
      <button type="button" onclick="deferredSubmitMerge()" class="w-full min-h-[44px] inline-flex items-center justify-center gap-2 rounded-xl bg-amber-600 px-4 py-2.5 text-sm font-bold text-white shadow-md hover:bg-amber-700 active:scale-[0.99]">
        <i class="fas fa-check-double text-xs" aria-hidden="true"></i>
        دمج وتدقيق
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  function apiCall(url, opts) {
    if (typeof window.apiCall === 'function') return window.apiCall(url, opts);
    return fetch(url, { credentials: 'same-origin', ...opts }).then(r => r.json());
  }
  function showToast(msg, type) {
    if (typeof window.showToast === 'function') window.showToast(msg, type);
    else alert(msg);
  }
  function fmt(v) {
    if (typeof window.formatMoney === 'function') return window.formatMoney(v);
    return (parseFloat(v) || 0).toLocaleString('en-US', { minimumFractionDigits: 2 }) + ' $';
  }

  function esc(s) {
    if (s == null || s === '') return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function setModalOpen(el, open) {
    if (!el) return;
    if (open) {
      el.classList.remove('hidden');
      el.classList.add('flex');
      el.setAttribute('aria-hidden', 'false');
    } else {
      el.classList.add('hidden');
      el.classList.remove('flex');
      el.setAttribute('aria-hidden', 'true');
    }
  }

  window.deferredOpenSearchModal = function() {
    setModalOpen(document.getElementById('deferredSearchModal'), true);
  };
  window.deferredCloseSearchModal = function() {
    setModalOpen(document.getElementById('deferredSearchModal'), false);
  };
  window.deferredOpenCycleModal = function() {
    setModalOpen(document.getElementById('deferredCycleModal'), true);
  };
  window.deferredCloseCycleModal = function() {
    setModalOpen(document.getElementById('deferredCycleModal'), false);
  };
  window.deferredOpenMergeModal = function() {
    setModalOpen(document.getElementById('deferredMergeModal'), true);
  };
  window.deferredCloseMergeModal = function() {
    setModalOpen(document.getElementById('deferredMergeModal'), false);
  };

  window.__deferredMemberIdsForCopy = [];

  window.deferredCopyUserIds = function() {
    var ids = window.__deferredMemberIdsForCopy || [];
    if (!ids.length) {
      showToast('لا يوجد أرقام مستخدمين في القائمة الحالية', 'info');
      return;
    }
    var text = ids.join('\n');
    function done() {
      showToast('تم نسخ ' + ids.length + ' رقم (سطر لكل رقم)', 'success');
    }
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(done).catch(function() {
        try {
          var ta = document.createElement('textarea');
          ta.value = text;
          ta.setAttribute('readonly', '');
          ta.style.position = 'fixed';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          done();
        } catch (e) {
          showToast('تعذّر النسخ من المتصفح', 'error');
        }
      });
    } else {
      try {
        var ta2 = document.createElement('textarea');
        ta2.value = text;
        ta2.setAttribute('readonly', '');
        ta2.style.position = 'fixed';
        ta2.style.left = '-9999px';
        document.body.appendChild(ta2);
        ta2.select();
        document.execCommand('copy');
        document.body.removeChild(ta2);
        done();
      } catch (e2) {
        showToast('تعذّر النسخ من المتصفح', 'error');
      }
    }
  };

  function fillCycleSelects(cycles) {
    var sel = document.getElementById('deferredCycleSelect');
    var merge = document.getElementById('deferredMergeCycle');
    var opts = (cycles || []).map(function(c) {
      return '<option value="' + c.id + '">' + (c.name || '') + '</option>';
    }).join('');
    if (sel) {
      sel.innerHTML = '<option value="">— كل الدورات —</option>' + opts;
    }
    if (merge) {
      merge.innerHTML = '<option value="">— دورة الدمج —</option>' + opts;
    }
  }

  window.deferredLoadUsers = function() {
    var sel = document.getElementById('deferredCycleSelect');
    var list = document.getElementById('deferredUsersList');
    if (!list) return;
    list.innerHTML = '<p class="text-slate-400 text-center py-10 text-sm">جاري التحميل...</p>';
    var q = sel && sel.value ? ('?cycleId=' + encodeURIComponent(sel.value)) : '';
    apiCall('/dashboard/deferred-users' + q).then(function(res) {
      window.__deferredMemberIdsForCopy = [];
      if (!res.success) {
        list.innerHTML = '<p class="text-red-600 text-center py-10 text-sm">' + esc(res.message || 'فشل') + '</p>';
        return;
      }
      var users = res.users || [];
      var seen = {};
      users.forEach(function(u) {
        var mid = String(u.member_user_id || '').trim();
        if (mid && !seen[mid]) {
          seen[mid] = true;
          window.__deferredMemberIdsForCopy.push(mid);
        }
      });
      if (res.mode === 'all' && res.totalDeferred != null) {
        list.innerHTML = '<div class="rounded-xl border border-sky-100 bg-sky-50/60 px-4 py-3 text-sm text-slate-700 mb-4">إجمالي المؤجل (كل الدورات): <strong class="text-sky-800 tabular-nums">' + fmt(res.totalDeferred) + '</strong></div>';
      } else {
        list.innerHTML = '';
      }
      if (users.length === 0) {
        list.innerHTML += '<div class="rounded-2xl border border-dashed border-slate-200 bg-slate-50/50 px-6 py-12 text-center"><i class="fas fa-inbox text-3xl text-slate-300 mb-3 block" aria-hidden="true"></i><p class="text-slate-500 text-sm">لا يوجد مستخدمون غير مدققين في هذا العرض</p></div>';
        return;
      }
      list.innerHTML += users.map(function(u) {
        var mid = String(u.member_user_id || '').trim();
        var profileUrl = '/member-directory/member/' + encodeURIComponent(mid);
        var cycleInfo = u.cycle_name
          ? esc(u.cycle_name) + ' · #' + esc(String(u.cycle_id || ''))
          : '';
        var extraRaw =
          u.extra_id_c != null && String(u.extra_id_c).trim() !== '' ? String(u.extra_id_c) : '—';
        var extraLine = extraRaw === '—' ? '—' : esc(extraRaw);
        var before =
          u.salary_before_discount != null ? 'قبل الخصم ' + esc(fmt(u.salary_before_discount)) : '';
        return (
          '<a href="' +
          esc(profileUrl) +
          '" aria-label="فتح ملف العضو ' +
          esc(mid) +
          '" class="group flex items-center gap-4 rounded-2xl border border-slate-200/90 bg-white p-4 shadow-sm ring-1 ring-slate-900/[0.02] transition hover:border-indigo-200/90 hover:bg-gradient-to-l hover:from-indigo-50/40 hover:to-white hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 sm:p-4">' +
          '<div class="min-w-0 flex-1 space-y-1.5">' +
          '<p class="text-[0.55rem] font-medium leading-none text-slate-400">مستخدم</p>' +
          '<p class="font-mono text-lg font-bold leading-tight tracking-tight text-slate-900 tabular-nums group-hover:text-indigo-950 sm:text-xl">' +
          esc(mid) +
          '</p>' +
          (cycleInfo
            ? '<p class="line-clamp-2 text-[10px] leading-snug text-slate-500">' + cycleInfo + '</p>'
            : '') +
          '<p class="text-[0.5rem] leading-tight text-slate-400">معرف إضافي: ' +
          extraLine +
          (before ? ' · ' + before : '') +
          '</p>' +
          '</div>' +
          '<div class="flex shrink-0 flex-col items-end justify-center gap-2 ps-2">' +
          '<div class="text-end">' +
          '<p class="text-[0.55rem] font-medium text-slate-400">بعد الخصم</p>' +
          '<p class="text-base font-bold tabular-nums text-sky-600 sm:text-lg">' +
          esc(fmt(u.balance_d || 0)) +
          '</p></div>' +
          '<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-100 text-slate-400 transition group-hover:bg-indigo-100 group-hover:text-indigo-600" aria-hidden="true"><i class="fas fa-chevron-left text-xs"></i></span>' +
          '</div></a>'
        );
      }).join('');
    });
  };

  window.deferredRefresh = function() {
    var sel = document.getElementById('deferredCycleSelect');
    if (!sel || !sel.value) {
      showToast('اختر دورة محددة للمزامنة من Google', 'error');
      return;
    }
    apiCall('/dashboard/refresh-deferred', { method: 'POST', body: JSON.stringify({ cycleId: sel.value }) }).then(function(res) {
      showToast(res.message || (res.success ? 'تم التحديث' : 'فشل'), res.success ? 'success' : 'error');
      if (res.success) deferredLoadUsers();
    });
  };

  window.deferredLoadMemberHistory = function() {
    var inp = document.getElementById('deferredMemberSearch');
    var box = document.getElementById('deferredMemberHistory');
    if (!inp || !box) return;
    var id = (inp.value || '').trim();
    if (!id) {
      showToast('أدخل رقم المستخدم', 'error');
      return;
    }
    box.classList.remove('hidden');
    box.innerHTML = '<p class="text-slate-400 text-sm py-2">جاري التحميل...</p>';
    apiCall('/api/search/member-deferred-history?memberUserId=' + encodeURIComponent(id)).then(function(res) {
      if (!res.success) {
        box.innerHTML = '<p class="text-red-600 text-sm">' + (res.message || 'فشل') + '</p>';
        return;
      }
      var lines = res.lines || [];
      if (!lines.length) {
        box.innerHTML = '<p class="text-slate-500 text-sm">لا توجد أسطر مؤجلة لهذا الرقم.</p>';
        return;
      }
      box.innerHTML = '<p class="mb-2 font-semibold text-slate-800">المجموع: <span class="tabular-nums text-sky-700">' + fmt(res.totalDeferred) + '</span></p><ul class="list-disc pr-5 space-y-1.5 text-sm text-slate-700">' +
        lines.map(function(l) {
          return '<li class="break-words">' + (l.cycle_name || '') + ': ' + fmt(l.balance_d) + (l.salary_before_discount != null ? ' (قبل الخصم ' + fmt(l.salary_before_discount) + ')' : '') + '</li>';
        }).join('') + '</ul>';
    });
  };

  window.deferredSubmitMerge = function() {
    var mid = document.getElementById('deferredMergeMember');
    var cyc = document.getElementById('deferredMergeCycle');
    if (!mid || !cyc) return;
    var m = (mid.value || '').trim();
    var cid = cyc.value;
    if (!m || !cid) {
      showToast('أدخل رقم المستخدم واختر دورة الدمج', 'error');
      return;
    }
    if (!confirm('دمج كل رواتب المؤجل لهذا المستخدم في الدورة المختارة وتسجيل التدقيق؟')) return;
    apiCall('/dashboard/deferred-merge', {
      method: 'POST',
      body: JSON.stringify({ memberUserId: m, targetCycleId: parseInt(cid, 10) })
    }).then(function(res) {
      showToast(res.message || (res.success ? 'تم' : 'فشل'), res.success ? 'success' : 'error');
      if (res.success) {
        deferredCloseMergeModal();
        deferredLoadUsers();
        var hist = document.getElementById('deferredMemberHistory');
        if (hist) { hist.classList.add('hidden'); hist.innerHTML = ''; }
      }
    });
  };

  document.addEventListener('DOMContentLoaded', function() {
    apiCall('/dashboard/stats').then(function(res) {
      if (!res.success) return;
      var cycles = res.cycles || [];
      fillCycleSelects(cycles);
      var urlCycle = (new URLSearchParams(window.location.search)).get('cycleId');
      var sel = document.getElementById('deferredCycleSelect');
      if (sel && urlCycle && cycles.some(function(c) { return String(c.id) === String(urlCycle); })) {
        sel.value = urlCycle;
      }
      deferredLoadUsers();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key !== 'Escape') return;
      deferredCloseSearchModal();
      deferredCloseCycleModal();
      deferredCloseMergeModal();
    });
  });
})();
</script>
