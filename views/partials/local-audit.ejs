<div class="max-w-3xl mx-auto" dir="rtl">
  <h2 class="text-2xl font-bold text-slate-800 mb-2">تدقيق محلي</h2>
  <p class="text-sm text-slate-500 mb-6">الجداول تُخزَّن على الخادم بعد المزامنة أو الرفع لتسريع التدقيق دون استدعاء Google في لحظة التنفيذ. زامن أو ارفع الدورة من قسم Sheet أولاً ثم نفّذ التدقيق المحلي.</p>
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-4">
    <div>
      <label class="text-sm font-medium text-slate-600">الدورة</label>
      <select id="laCycle" class="mt-1 w-full px-3 py-2 rounded-xl border border-slate-200"></select>
    </div>
    <div>
      <label class="text-sm font-medium text-slate-600">رقم المستخدم</label>
      <input type="text" id="laMember" class="mt-1 w-full px-3 py-2 rounded-xl border border-slate-200" placeholder="مثال: 12345">
    </div>
    <button type="button" onclick="laSubmit()" class="w-full py-3 rounded-xl bg-indigo-600 text-white font-semibold">تسجيل كمدقق</button>
    <div class="pt-4 border-t border-slate-100 space-y-2">
      <p class="text-xs font-semibold text-slate-600">محاسبة الدورة (من البيانات المحفوظة)</p>
      <button type="button" onclick="laApplyAuditProfits()" class="w-full py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-semibold">تسجيل أرباح التدقيق (Y+Z و W) في صافي الربح</button>
      <button type="button" onclick="laRebuildDeferred()" class="w-full py-2.5 rounded-xl bg-sky-600 text-white text-sm font-semibold">إعادة بناء رصيد المؤجل بعد خصم التحويل</button>
      <p id="laAccMsg" class="text-sm text-slate-600"></p>
    </div>
    <p id="laMsg" class="text-sm text-slate-600"></p>
  </div>
</div>
<script>
function laSubmit() {
  var cid = document.getElementById('laCycle').value;
  var mid = document.getElementById('laMember').value;
  var msg = document.getElementById('laMsg');
  fetch('/api/local-audit/mark-audited', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'same-origin',
    body: JSON.stringify({ cycleId: cid, memberId: mid })
  }).then(function(r) { return r.json(); }).then(function(res) {
    msg.textContent = res.message || '';
    msg.className = 'text-sm ' + (res.success ? 'text-emerald-600' : 'text-red-600');
  });
}
function laApplyAuditProfits() {
  var cid = document.getElementById('laCycle').value;
  var msg = document.getElementById('laAccMsg');
  if (!cid) { if (msg) { msg.textContent = 'اختر الدورة'; msg.className = 'text-sm text-red-600'; } return; }
  if (msg) msg.textContent = 'جاري التنفيذ...';
  fetch('/api/cycle-accounting/apply-audit-profits/' + cid, { method: 'POST', credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!msg) return;
      msg.textContent = res.message || '';
      msg.className = 'text-sm ' + (res.success ? 'text-emerald-600' : 'text-red-600');
    });
}
function laRebuildDeferred() {
  var cid = document.getElementById('laCycle').value;
  var msg = document.getElementById('laAccMsg');
  if (!cid) { if (msg) { msg.textContent = 'اختر الدورة'; msg.className = 'text-sm text-red-600'; } return; }
  if (msg) msg.textContent = 'جاري التنفيذ...';
  fetch('/api/cycle-accounting/rebuild-deferred/' + cid, { method: 'POST', credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!msg) return;
      msg.textContent = res.message || (res.success ? 'تم' : '');
      msg.className = 'text-sm ' + (res.success ? 'text-emerald-600' : 'text-red-600');
    });
}
fetch('/api/local-audit/cycles', { credentials: 'same-origin' }).then(function(r) { return r.json(); }).then(function(res) {
  var sel = document.getElementById('laCycle');
  if (!sel || !res.success) return;
  sel.innerHTML = '<option value="">— اختر —</option>';
  (res.cycles || []).forEach(function(c) {
    sel.innerHTML += '<option value="' + c.id + '">' + (c.name || c.id) + '</option>';
  });
});
</script>
