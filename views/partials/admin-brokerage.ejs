<div class="max-w-md mx-auto" dir="rtl">
  <h2 class="text-2xl font-bold text-slate-800 mb-2">وساطة إدارية</h2>
  <p class="text-sm text-slate-500 mb-6">نسبة الوساطة تُسجّل ربحاً، والباقي يُضاف للصندوق الرئيسي.</p>
  <form id="abForm" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-3">
    <select id="abCycle" name="cycleId" class="w-full px-4 py-2.5 rounded-xl border border-slate-200"><option value="">— دورة (اختياري) —</option></select>
    <input type="number" name="amount" step="0.01" required placeholder="المبلغ" class="w-full px-4 py-2.5 rounded-xl border border-slate-200">
    <input type="number" name="brokeragePct" step="0.1" required placeholder="نسبة الوساطة %" class="w-full px-4 py-2.5 rounded-xl border border-slate-200">
    <textarea name="notes" placeholder="ملاحظات" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" rows="2"></textarea>
    <button type="submit" class="w-full py-3 rounded-xl bg-indigo-600 text-white font-semibold">تسجيل</button>
  </form>
  <p id="abMsg" class="mt-3 text-sm"></p>
</div>
<script>
fetch('/api/sheet/cycles', { credentials: 'same-origin' }).then(function(r) { return r.json(); }).then(function(res) {
  var sel = document.getElementById('abCycle');
  if (!sel || !res.success) return;
  (res.cycles || []).forEach(function(c) {
    sel.innerHTML += '<option value="' + c.id + '">' + (c.name || c.id) + '</option>';
  });
});
document.getElementById('abForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(e.target);
  fetch('/api/admin-brokerage/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'same-origin',
    body: JSON.stringify({
      cycleId: fd.get('cycleId') || null,
      amount: fd.get('amount'),
      brokeragePct: fd.get('brokeragePct'),
      notes: fd.get('notes')
    })
  }).then(function(r) { return r.json(); }).then(function(res) {
    var p = document.getElementById('abMsg');
    p.textContent = res.message || '';
    p.className = 'mt-3 text-sm ' + (res.success ? 'text-emerald-600' : 'text-red-600');
  });
});
</script>
