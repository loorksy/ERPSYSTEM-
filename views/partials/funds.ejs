<div class="funds-page funds-list-page w-full max-w-6xl mx-auto min-w-0 px-4 sm:px-0 pb-10" dir="rtl">
  <div class="mb-6 erp-toolbar-actions erp-toolbar-actions--2">
    <button type="button" onclick="fundsEditMain()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-slate-700 text-white text-[11px] leading-snug sm:text-sm font-semibold shadow-md hover:bg-slate-800 active:scale-[0.99] transition text-center touch-manipulation">
      <i class="fas fa-piggy-bank text-[10px] sm:text-sm shrink-0 opacity-95" aria-hidden="true"></i>
      <span class="text-center">تعديل الرئيسي</span>
    </button>
    <button type="button" onclick="fundsOpenAdd()" class="inline-flex items-center justify-center gap-1 rounded-xl px-1.5 py-2 min-h-[2.75rem] sm:min-h-0 sm:px-4 sm:py-2.5 bg-gradient-to-br from-indigo-600 to-indigo-500 text-white text-[11px] leading-snug sm:text-sm font-semibold shadow-md shadow-indigo-500/25 hover:brightness-105 active:scale-[0.99] transition touch-manipulation">
      <i class="fas fa-plus text-[10px] sm:text-sm shrink-0 opacity-95" aria-hidden="true"></i>
      <span class="text-center">إضافة صندوق</span>
    </button>
  </div>

  <!-- تعديل الصندوق الرئيسي -->
  <div id="fundEditMainModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-sm" onclick="if(event.target===this) fundsCloseEditMain()">
    <div class="relative w-full max-w-md overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl shadow-slate-900/15 ring-1 ring-slate-900/5" onclick="event.stopPropagation()">
      <div class="flex items-center gap-3 border-b border-amber-100 bg-gradient-to-l from-amber-50/90 to-white px-5 py-4">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-amber-600 text-white shadow-md shadow-amber-600/25">
          <i class="fas fa-piggy-bank" aria-hidden="true"></i>
        </div>
        <div class="min-w-0 flex-1">
          <h4 class="text-lg font-bold text-slate-900">تعديل الصندوق الرئيسي</h4>
          <p class="text-xs text-slate-500 mt-0.5">الاسم والرقم الظاهران في القوائم والتقارير</p>
        </div>
        <button type="button" onclick="fundsCloseEditMain()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 transition hover:bg-slate-100 hover:text-slate-600" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
      </div>
      <div class="p-5 sm:p-6 space-y-3">
        <div>
          <label class="text-sm font-semibold text-slate-700">اسم الصندوق</label>
          <input type="text" id="fundMainEditName" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">رقم الصندوق</label>
          <input type="text" id="fundMainEditNumber" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
        </div>
        <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end">
          <button type="button" onclick="fundsCloseEditMain()" class="w-full sm:w-auto px-5 py-3 rounded-xl border border-slate-200 bg-white text-slate-700 font-semibold hover:bg-slate-50">إلغاء</button>
          <button type="button" onclick="fundsSubmitEditMain()" class="w-full sm:w-auto px-6 py-3 rounded-xl bg-amber-600 text-white font-bold shadow-md hover:bg-amber-700">حفظ</button>
        </div>
      </div>
    </div>
  </div>
  <div id="fundsCards" class="agencies-grid">
    <div class="col-span-full acc-approvals-empty text-slate-400 text-center">
      <i class="fas fa-spinner fa-spin text-3xl text-indigo-400" aria-hidden="true"></i>
      <span class="text-sm font-medium">جاري التحميل...</span>
    </div>
  </div>
</div>

<div id="fundAddModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-sm" onclick="if(event.target===this) fundsCloseAdd()">
  <div class="relative w-full max-w-lg max-h-[min(90vh,720px)] overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-2xl shadow-slate-900/15 ring-1 ring-slate-900/5 flex flex-col" onclick="event.stopPropagation()">
    <div class="flex items-center gap-3 border-b border-indigo-100 bg-gradient-to-l from-indigo-50/90 to-white px-5 py-4 shrink-0">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md shadow-indigo-600/25">
        <i class="fas fa-plus" aria-hidden="true"></i>
      </div>
      <div class="min-w-0 flex-1">
        <h4 class="text-lg font-bold text-slate-900">إضافة صندوق</h4>
        <p class="text-xs text-slate-500 mt-0.5">بيانات الصندوق والرصيد المرجعي الافتتاحي</p>
      </div>
      <button type="button" onclick="fundsCloseAdd()" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 transition hover:bg-slate-100 hover:text-slate-600" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
    </div>
    <form id="fundAddForm" class="space-y-3 p-5 sm:p-6 overflow-y-auto flex-1 min-h-0">
      <div>
        <label class="text-sm font-semibold text-slate-700">اسم الصندوق</label>
        <input type="text" id="fundAddName" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200" required>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">رقم الصندوق</label>
        <input type="text" id="fundAddNumber" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">شركة التحويل (اختياري)</label>
        <select id="fundAddTc" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
          <option value="">— لا يوجد —</option>
        </select>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">الدولة</label>
        <select id="fundAddCountry" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200" onchange="fundsSyriaGov(this.value)"></select>
      </div>
      <div id="fundSyriaGovWrap" class="hidden">
        <label class="text-sm font-semibold text-slate-700">المحافظة (سوريا)</label>
        <select id="fundAddSyriaGov" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200"></select>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">رصيد مرجعي — أول عملة</label>
        <div class="flex gap-2 mt-1">
          <input type="number" id="fundRefAmt1" step="0.01" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200" placeholder="المبلغ">
          <select id="fundRefCur1" class="w-32 px-2 rounded-xl border border-slate-200">
            <option value="USD">USD</option>
            <option value="TRY">TRY</option>
            <option value="SYP">SYP</option>
            <option value="EUR">EUR</option>
            <option value="EGP">EGP</option>
          </select>
        </div>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">رصيد مرجعي — عملة ثانية (اختياري)</label>
        <div class="flex gap-2 mt-1">
          <input type="number" id="fundRefAmt2" step="0.01" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200" placeholder="0">
          <select id="fundRefCur2" class="w-32 px-2 rounded-xl border border-slate-200">
            <option value="">—</option>
            <option value="TRY">TRY</option>
            <option value="SYP">SYP</option>
            <option value="USD">USD</option>
            <option value="EUR">EUR</option>
            <option value="EGP">EGP</option>
          </select>
        </div>
      </div>
      <div class="flex flex-col-reverse gap-2 pt-2 sm:flex-row sm:justify-end sticky bottom-0 bg-white pb-1">
        <button type="button" onclick="fundsCloseAdd()" class="w-full sm:w-auto px-5 py-3 rounded-xl border border-slate-200 bg-white text-slate-700 font-semibold hover:bg-slate-50">إلغاء</button>
        <button type="submit" class="w-full sm:w-auto px-6 py-3 rounded-xl bg-indigo-600 text-white font-bold shadow-md hover:bg-indigo-700">حفظ</button>
      </div>
    </form>
  </div>
</div>

<script>
  window.FUNDS_COUNTRIES = [
    'سوريا','تركيا','مصر','العراق','الجزائر','الأردن','المغرب','فلسطين','لبنان','السعودية','الإمارات','الكويت','قطر','البحرين','عُمان','اليمن','السودان','تونس','ليبيا','موريتانيا','الصومال','جيبوتي'
  ];
  window.FUNDS_SYRIA_GOV = ['دمشق','ريف دمشق','حلب','حمص','حماة','اللاذقية','طرطوس','درعا','السويداء','القنيطرة','الرقة','دير الزور','الحسكة','إدلب'];
</script>
