<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#1a1a2e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - <%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen bg-slate-100 font-[Tajawal] text-slate-800 max-lg:overflow-x-hidden">

  <!-- Mobile Header (يُخفى عند فتح نافذة إنشاء/تعديل الدورة) -->
  <header id="mobileHeader" class="hidden lg:hidden fixed top-0 left-0 right-0 h-[60px] bg-white border-b border-slate-200 px-4 items-center justify-between z-[1000] shadow-sm max-lg:flex">
    <button class="w-[42px] h-[42px] flex items-center justify-center rounded-xl text-slate-800 text-xl active:bg-slate-50" id="menuToggle" aria-label="القائمة">
      <i class="fas fa-bars"></i>
    </button>
    <div class="flex items-center gap-2 font-bold text-lg text-indigo-600">
      <i class="fas fa-chart-line text-xl"></i>
      <span>LorkERP</span>
    </div>
    <div class="cursor-pointer" id="mobileUserBtn">
      <div class="w-9 h-9 rounded-full bg-gradient-to-br from-indigo-600 to-indigo-400 text-white flex items-center justify-center font-bold text-sm">
        <%= user.displayName.charAt(0) %>
      </div>
    </div>
  </header>

  <!-- Sidebar Overlay -->
  <div class="hidden fixed inset-0 bg-black/50 z-[1000] backdrop-blur-sm" id="sidebarOverlay"></div>

  <!-- Sidebar -->
  <aside class="sidebar-shell fixed top-0 right-0 w-[260px] h-screen bg-[#1a1a2e] z-[1001] flex flex-col transition-[width,transform] duration-300 overflow-y-auto overflow-x-hidden max-lg:translate-x-[calc(100%+4px)]" id="sidebar">
    <!-- Logo + طي (لابتوب فقط) -->
    <div class="p-5 flex items-center justify-between gap-2 min-h-[4.25rem]" id="sidebarLogoRow">
      <div class="flex items-center gap-3 min-w-0 flex-1 overflow-hidden">
        <div class="w-10 h-10 bg-gradient-to-br from-indigo-600 to-indigo-400 rounded-xl flex items-center justify-center shrink-0">
          <i class="fas fa-chart-line text-white text-lg"></i>
        </div>
        <div class="sidebar-brand-text min-w-0">
          <h2 class="text-white text-xl font-bold leading-tight truncate">LorkERP</h2>
          <span class="text-slate-400 text-xs">نظام المحاسبة</span>
        </div>
      </div>
      <div class="flex items-center gap-1 shrink-0">
        <button type="button" class="hidden lg:inline-flex w-9 h-9 rounded-xl text-slate-400 items-center justify-center text-lg hover:bg-white/[0.08] hover:text-white transition-colors" id="sidebarCollapseToggle" aria-expanded="true" aria-controls="sidebar" aria-label="طي القائمة" title="طي القائمة">
          <i class="fas fa-angles-right text-sm" aria-hidden="true"></i>
        </button>
        <button type="button" class="lg:hidden w-9 h-9 rounded-xl text-slate-400 items-center justify-center text-lg hover:bg-white/[0.08]" id="sidebarClose" aria-label="إغلاق القائمة">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>

    <!-- User -->
    <div class="py-4 px-5 mx-3 bg-white/[0.08] rounded-xl flex items-center gap-3 sidebar-user-row">
      <div class="w-11 h-11 rounded-full bg-gradient-to-br from-indigo-600 to-cyan-500 text-white flex items-center justify-center font-bold text-lg shrink-0">
        <%= user.displayName.charAt(0) %>
      </div>
      <div class="sidebar-user-text min-w-0">
        <h4 class="text-white text-[0.95rem] font-semibold truncate"><%= user.displayName %></h4>
        <span class="text-slate-400 text-xs"><%= user.role === 'admin' ? 'مدير النظام' : 'مستخدم' %></span>
      </div>
    </div>

    <%- include('partials/sidebar-nav') %>

    <div class="py-4 px-5 border-t border-white/[0.08] text-center">
      <p class="sidebar-footer-text text-white/30 text-xs">LorkERP v1.0</p>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main-with-sidebar min-h-screen transition-[margin] duration-300 max-lg:pt-[60px] max-lg:pb-[65px]" id="mainContent">
    <div class="p-4 lg:p-8 2xl:px-12">
      <% if (page === 'home') { %>
        <%- include('partials/home') %>
      <% } else if (page === 'sheet') { %>
        <%- include('partials/sheet') %>
      <% } else if (page === 'payroll-google') { %>
        <%- include('partials/payroll-google') %>
      <% } else if (page === 'deferred-balance') { %>
        <%- include('partials/deferred-balance') %>
      <% } else if (page === 'search') { %>
        <%- include('partials/search') %>
          <% } else if (page === 'clients') { %>
        <%- include('partials/clients') %>
      <% } else if (page === 'messages') { %>
        <%- include('partials/messages') %>
      <% } else if (page === 'approvals') { %>
        <%- include('partials/approvals') %>
      <% } else if (page === 'sub-agencies') { %>
        <%- include('partials/sub-agencies') %>
      <% } else if (page === 'main-agency') { %>
        <%- include('partials/main-agency') %>
      <% } else if (page === 'transfer-companies') { %>
        <%- include('partials/transfer-companies') %>
      <% } else if (page === 'funds') { %>
        <%- include('partials/funds') %>
      <% } else if (page === 'shipping') { %>
        <%- include('partials/shipping') %>
      <% } else if (page === 'client-portal') { %>
        <%- include('partials/client-portal') %>
      <% } else if (page === 'settings') { %>
        <%- include('partials/settings') %>
      <% } else if (page === 'debts') { %>
        <%- include('partials/debts') %>
      <% } else if (page === 'debt-company') { %>
        <%- include('partials/debt-company') %>
      <% } else if (page === 'debt-fund') { %>
        <%- include('partials/debt-fund') %>
      <% } else if (page === 'fx-spread') { %>
        <%- include('partials/fx-spread') %>
      <% } else if (page === 'expenses-page') { %>
        <%- include('partials/expenses-page') %>
      <% } else if (page === 'profit-sources') { %>
        <%- include('partials/profit-sources') %>
      <% } else if (page === 'profit-source-detail') { %>
        <%- include('partials/profit-source-detail') %>
      <% } else if (page === 'admin-brokerage') { %>
        <%- include('partials/admin-brokerage') %>
      <% } else if (page === 'payables-overview') { %>
        <%- include('partials/payables-overview') %>
      <% } else if (page === 'receivables-to-us') { %>
        <%- include('partials/receivables-to-us') %>
      <% } else if (page === 'payment-due') { %>
        <%- include('partials/payment-due') %>
      <% } else if (page === 'member-directory') { %>
        <%- include('partials/member-directory') %>
      <% } else if (page === 'member-directory-detail') { %>
        <%- include('partials/member-directory-detail') %>
      <% } else if (page === 'member-adjustments') { %>
        <%- include('partials/member-adjustments') %>
      <% } %>
    </div>
  </main>

  <!-- Toast -->
  <div class="fixed top-5 left-5 z-[9999] flex flex-col gap-2 max-md:left-3 max-md:right-3 max-md:top-[72px]" id="toastContainer"></div>

  <!-- Mobile Bottom Nav: شبكة 5 أعمدة متساوية + زر + في المنتصف -->
  <nav id="mobileBottomNav" class="hidden max-lg:grid max-lg:grid-cols-5 max-lg:items-end max-lg:gap-0 max-lg:overflow-visible fixed bottom-0 left-0 right-0 min-h-[65px] bg-white border-t border-slate-200 z-[999] max-lg:has-[#quickActionRadialMobile[data-radial-open=true]]:z-[1005] shadow-[0_-2px_10px_rgba(0,0,0,0.05)] pb-[env(safe-area-inset-bottom,0)] px-0.5 pt-1">
    <a href="/dashboard" class="flex min-w-0 justify-self-stretch flex-col items-center justify-end gap-0.5 text-[0.65rem] font-medium py-1 px-0.5 rounded-lg transition-all duration-300 pb-2 <%= page === 'home' ? 'text-indigo-600' : 'text-slate-400' %>">
      <i class="fas fa-home text-lg"></i>
      <span class="truncate max-w-full">الرئيسية</span>
    </a>
    <a href="/sheet" class="flex min-w-0 justify-self-stretch flex-col items-center justify-end gap-0.5 text-[0.65rem] font-medium py-1 px-0.5 rounded-lg transition-all duration-300 pb-2 <%= page === 'sheet' ? 'text-indigo-600' : 'text-slate-400' %>">
      <i class="fas fa-file-excel text-lg"></i>
      <span class="truncate max-w-full">Sheet</span>
    </a>
    <div class="relative z-[1] flex min-w-0 justify-self-stretch flex-col items-center justify-end overflow-visible pb-1">
      <div class="group relative -mt-5 mx-auto h-14 w-14 shrink-0" id="quickActionRadialMobile" data-radial-open="false">
        <button type="button" id="quickActionFabMobile" class="quick-action-fab relative z-[6] mx-auto flex h-12 w-12 cursor-pointer items-center justify-center rounded-full border-4 border-white bg-gradient-to-br from-[#6366f1] from-[48%] to-[#4338ca] text-white shadow-[0_6px_18px_rgba(79,70,229,0.38)] transition-all duration-200 ease-out hover:brightness-110 hover:shadow-[0_8px_22px_rgba(79,70,229,0.45)] focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 group-data-[radial-open=true]:scale-[0.93] group-data-[radial-open=true]:bg-gradient-to-br group-data-[radial-open=true]:from-[#4f46e5] group-data-[radial-open=true]:to-[#3730a3] group-data-[radial-open=true]:shadow-[0_4px_16px_rgba(26,26,46,0.2)]" aria-haspopup="true" aria-expanded="false" aria-label="إجراء سريع">
          <i class="fas fa-plus text-xl block leading-none transition-transform duration-[380ms] [transition-timing-function:cubic-bezier(0.34,1.35,0.64,1)] group-data-[radial-open=true]:rotate-45"></i>
        </button>
        <div class="quick-action-radial-subs pointer-events-none absolute left-1/2 top-1/2 z-[5] h-0 w-0 group-data-[radial-open=true]:pointer-events-auto" aria-hidden="true">
          <button type="button" class="quick-action-radial-sub absolute left-0 top-0 -ml-[1.25rem] -mt-[1.25rem] flex h-10 w-auto min-w-[3.25rem] scale-[0.35] cursor-pointer items-center justify-center rounded-full border-[3px] border-white bg-gradient-to-br from-rose-400 to-rose-600 px-[0.35rem] text-[0.62rem] font-bold leading-tight text-white opacity-0 shadow-[0_6px_14px_rgba(15,23,42,0.18)] transition-all duration-300 [transition-timing-function:cubic-bezier(0.34,1.35,0.64,1)] duration-200 ease-out hover:brightness-110 hover:shadow-[0_8px_18px_rgba(15,23,42,0.22)] group-data-[radial-open=true]:-translate-x-[3.5rem] group-data-[radial-open=true]:-translate-y-[4.6rem] group-data-[radial-open=true]:scale-100 group-data-[radial-open=true]:opacity-100 group-data-[radial-open=true]:delay-[40ms] lg:group-data-[radial-open=true]:-translate-x-[3.85rem] lg:group-data-[radial-open=true]:-translate-y-[4.4rem]" data-quick-type="qa-out" title="صادر" aria-label="صادر">صادر</button>
          <button type="button" class="quick-action-radial-sub absolute left-0 top-0 -ml-[1.25rem] -mt-[1.25rem] flex h-10 w-auto min-w-[3.25rem] scale-[0.35] cursor-pointer items-center justify-center rounded-full border-[3px] border-white bg-gradient-to-br from-emerald-400 to-emerald-700 px-[0.35rem] text-[0.62rem] font-bold leading-tight text-white opacity-0 shadow-[0_6px_14px_rgba(15,23,42,0.18)] transition-all duration-300 [transition-timing-function:cubic-bezier(0.34,1.35,0.64,1)] duration-200 ease-out hover:brightness-110 hover:shadow-[0_8px_18px_rgba(15,23,42,0.22)] group-data-[radial-open=true]:translate-x-[3.5rem] group-data-[radial-open=true]:-translate-y-[4.6rem] group-data-[radial-open=true]:scale-100 group-data-[radial-open=true]:opacity-100 group-data-[radial-open=true]:delay-[90ms] lg:group-data-[radial-open=true]:translate-x-[3.85rem] lg:group-data-[radial-open=true]:-translate-y-[4.4rem]" data-quick-type="qa-in" title="وارد" aria-label="وارد">وارد</button>
        </div>
      </div>
    </div>
    <a href="/clients" class="flex min-w-0 justify-self-stretch flex-col items-center justify-end gap-0.5 text-[0.65rem] font-medium py-1 px-0.5 rounded-lg transition-all duration-300 pb-2 <%= page === 'clients' ? 'text-indigo-600' : 'text-slate-400' %>">
      <i class="fas fa-users text-lg"></i>
      <span class="truncate max-w-full">العملاء</span>
    </a>
    <a href="/search" class="flex min-w-0 justify-self-stretch flex-col items-center justify-end gap-0.5 text-[0.65rem] font-medium py-1 px-0.5 rounded-lg transition-all duration-300 pb-2 <%= page === 'search' ? 'text-indigo-600' : 'text-slate-400' %>">
      <i class="fas fa-search text-lg"></i>
      <span class="truncate max-w-full">البحث</span>
    </a>
  </nav>

  <!-- زر + شعاعي يسار الشاشة (لابتوب) -->
  <div class="group relative hidden h-[3.75rem] w-[3.75rem] shrink-0 max-lg:!hidden lg:fixed lg:bottom-8 lg:left-[2.35rem] lg:right-auto lg:z-[1004] lg:block" id="quickActionRadialDesktop" data-radial-open="false">
    <button type="button" id="quickActionFabDesktop" class="quick-action-fab relative z-[6] mx-auto flex h-14 w-14 cursor-pointer items-center justify-center rounded-full border-4 border-white bg-gradient-to-br from-[#6366f1] from-[48%] to-[#4338ca] text-white shadow-[0_6px_18px_rgba(79,70,229,0.38)] transition-all duration-200 ease-out hover:brightness-110 hover:shadow-[0_8px_22px_rgba(79,70,229,0.45)] focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 group-data-[radial-open=true]:scale-[0.93] group-data-[radial-open=true]:bg-gradient-to-br group-data-[radial-open=true]:from-[#4f46e5] group-data-[radial-open=true]:to-[#3730a3] group-data-[radial-open=true]:shadow-[0_4px_16px_rgba(26,26,46,0.2)]" aria-haspopup="true" aria-expanded="false" aria-label="إجراء سريع">
      <i class="fas fa-plus text-2xl block leading-none transition-transform duration-[380ms] [transition-timing-function:cubic-bezier(0.34,1.35,0.64,1)] group-data-[radial-open=true]:rotate-45"></i>
    </button>
    <div class="quick-action-radial-subs pointer-events-none absolute left-1/2 top-1/2 z-[5] h-0 w-0 group-data-[radial-open=true]:pointer-events-auto" aria-hidden="true">
      <button type="button" class="quick-action-radial-sub absolute left-0 top-0 -ml-[1.375rem] -mt-[1.375rem] flex h-11 w-auto min-w-[3.25rem] scale-[0.35] cursor-pointer items-center justify-center rounded-full border-[3px] border-white bg-gradient-to-br from-rose-400 to-rose-600 px-[0.35rem] text-[0.75rem] font-bold leading-tight text-white opacity-0 shadow-[0_6px_14px_rgba(15,23,42,0.18)] transition-all duration-300 [transition-timing-function:cubic-bezier(0.34,1.35,0.64,1)] duration-200 ease-out hover:brightness-110 hover:shadow-[0_8px_18px_rgba(15,23,42,0.22)] group-data-[radial-open=true]:-translate-x-[3.85rem] group-data-[radial-open=true]:-translate-y-[4.4rem] group-data-[radial-open=true]:scale-100 group-data-[radial-open=true]:opacity-100 group-data-[radial-open=true]:delay-[40ms]" data-quick-type="qa-out" title="صادر" aria-label="صادر">صادر</button>
      <button type="button" class="quick-action-radial-sub absolute left-0 top-0 -ml-[1.375rem] -mt-[1.375rem] flex h-11 w-auto min-w-[3.25rem] scale-[0.35] cursor-pointer items-center justify-center rounded-full border-[3px] border-white bg-gradient-to-br from-emerald-400 to-emerald-700 px-[0.35rem] text-[0.75rem] font-bold leading-tight text-white opacity-0 shadow-[0_6px_14px_rgba(15,23,42,0.18)] transition-all duration-300 [transition-timing-function:cubic-bezier(0.34,1.35,0.64,1)] duration-200 ease-out hover:brightness-110 hover:shadow-[0_8px_18px_rgba(15,23,42,0.22)] group-data-[radial-open=true]:translate-x-[3.85rem] group-data-[radial-open=true]:-translate-y-[4.4rem] group-data-[radial-open=true]:scale-100 group-data-[radial-open=true]:opacity-100 group-data-[radial-open=true]:delay-[90ms]" data-quick-type="qa-in" title="وارد" aria-label="وارد">وارد</button>
    </div>
  </div>

  <div id="quickActionBackdrop" class="pointer-events-none fixed inset-0 z-[1002] hidden bg-slate-900/35 opacity-0 backdrop-blur-[2px] transition-opacity duration-[220ms] ease-in-out" aria-hidden="true"></div>

  <div id="qaCascadeOverlay" class="hidden fixed inset-0 z-[1003] items-center justify-center p-4 bg-black/45" aria-hidden="true">
    <div id="qaCascadePanel" class="bg-white rounded-2xl shadow-xl max-w-md w-full max-h-[90vh] overflow-y-auto p-5 text-right" dir="rtl"></div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.min.js"></script>
  <script src="/js/quick-actions.js"></script>
  <script src="/js/app.js"></script>
  <% if (page === 'sheet') { %>
    <script src="/js/sheets.js"></script>
  <% } %>
  <% if (page === 'settings') { %>
    <script src="/js/ai-settings.js"></script>
  <% } %>
  <% if (page === 'shipping') { %>
    <script src="/js/shipping.js"></script>
  <% } %>
  <% if (page === 'sub-agencies') { %>
    <script src="/js/sub-agencies.js"></script>
  <% } %>
  <% if (page === 'funds') { %>
    <script src="/js/funds.js"></script>
  <% } %>
  <% if (page === 'transfer-companies') { %>
    <script src="/js/transfer-companies.js"></script>
  <% } %>
  <% if (page === 'approvals') { %>
    <script src="/js/approvals.js"></script>
  <% } %>
  <% if (page === 'debts' || page === 'debt-company' || page === 'debt-fund') { %>
    <script src="/js/debts.js"></script>
  <% } %>
  <% if (page === 'fx-spread') { %>
    <script src="/js/fx-spread.js"></script>
  <% } %>
  <% if (page === 'expenses-page') { %>
    <script src="/js/expenses-page.js"></script>
  <% } %>
  <% if (page === 'profit-sources') { %>
    <script src="/js/profit-sources.js"></script>
  <% } %>
  <% if (page === 'profit-source-detail') { %>
    <script src="/js/profit-source-detail.js"></script>
  <% } %>
  <% if (page === 'payables-overview') { %>
    <script src="/js/payables-overview.js"></script>
  <% } %>
  <% if (page === 'receivables-to-us') { %>
    <script src="/js/receivables-to-us.js"></script>
  <% } %>
  <% if (page === 'payment-due') { %>
    <script src="/js/payment-due.js"></script>
  <% } %>
  <% if (page === 'member-directory') { %>
    <script src="/js/member-directory.js"></script>
  <% } %>
  <% if (page === 'member-directory-detail') { %>
    <script src="/js/member-directory-detail.js"></script>
  <% } %>
  <% if (page === 'member-adjustments') { %>
    <script src="/js/member-adjustments.js"></script>
  <% } %>
</body>
</html>
